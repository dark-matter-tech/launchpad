// rockit.encoding.qpack — QPACK header compression for HTTP/3
//
// Implements QPACK header compression as defined in RFC 9204. QPACK adapts
// HPACK for out-of-order delivery over QUIC, using a 99-entry static table,
// absolute indexing for the dynamic table, and separate encoder/decoder
// streams. Reuses HPACK integer encoding primitives.
//
// Standards: RFC 9204 — QPACK: Field Compression for HTTP/3
//
// Usage:
//   import rockit.encoding.qpack
//   import rockit.encoding.hpack
//   val enc = qpackCreateEncoder(4096)
//   val result = qpackEncode(enc, headers)

// == Error Constants ==========================================================

fun QPACK_ERROR(): String { return "QPACK_ERROR" }

// == Static Table (RFC 9204 Appendix A) =======================================
// 99 entries indexed 0-98 (unlike HPACK's 1-61)

fun qpackStaticSize(): Int { return 99 }

// Return the header name for a static table index (0-98)
fun qpackStaticName(index: Int): String {
    if (index == 0) { return ":authority" }
    if (index == 1) { return ":path" }
    if (index == 2) { return "age" }
    if (index == 3) { return "content-disposition" }
    if (index == 4) { return "content-length" }
    if (index == 5) { return "cookie" }
    if (index == 6) { return "date" }
    if (index == 7) { return "etag" }
    if (index == 8) { return "if-modified-since" }
    if (index == 9) { return "if-none-match" }
    if (index == 10) { return "last-modified" }
    if (index == 11) { return "link" }
    if (index == 12) { return "location" }
    if (index == 13) { return "referer" }
    if (index == 14) { return "set-cookie" }
    if (index == 15) { return ":method" }
    if (index == 16) { return ":method" }
    if (index == 17) { return ":method" }
    if (index == 18) { return ":method" }
    if (index == 19) { return ":method" }
    if (index == 20) { return ":method" }
    if (index == 21) { return ":method" }
    if (index == 22) { return ":scheme" }
    if (index == 23) { return ":scheme" }
    if (index == 24) { return ":status" }
    if (index == 25) { return ":status" }
    if (index == 26) { return ":status" }
    if (index == 27) { return ":status" }
    if (index == 28) { return ":status" }
    if (index == 29) { return "accept" }
    if (index == 30) { return "accept" }
    if (index == 31) { return "accept-encoding" }
    if (index == 32) { return "accept-ranges" }
    if (index == 33) { return "access-control-allow-headers" }
    if (index == 34) { return "access-control-allow-headers" }
    if (index == 35) { return "access-control-allow-origin" }
    if (index == 36) { return "cache-control" }
    if (index == 37) { return "cache-control" }
    if (index == 38) { return "cache-control" }
    if (index == 39) { return "cache-control" }
    if (index == 40) { return "cache-control" }
    if (index == 41) { return "cache-control" }
    if (index == 42) { return "content-encoding" }
    if (index == 43) { return "content-encoding" }
    if (index == 44) { return "content-type" }
    if (index == 45) { return "content-type" }
    if (index == 46) { return "content-type" }
    if (index == 47) { return "content-type" }
    if (index == 48) { return "content-type" }
    if (index == 49) { return "content-type" }
    if (index == 50) { return "content-type" }
    if (index == 51) { return "content-type" }
    if (index == 52) { return "content-type" }
    if (index == 53) { return "content-type" }
    if (index == 54) { return "content-type" }
    if (index == 55) { return "range" }
    if (index == 56) { return "strict-transport-security" }
    if (index == 57) { return "strict-transport-security" }
    if (index == 58) { return "strict-transport-security" }
    if (index == 59) { return "vary" }
    if (index == 60) { return "vary" }
    if (index == 61) { return "x-content-type-options" }
    if (index == 62) { return "x-xss-protection" }
    if (index == 63) { return ":status" }
    if (index == 64) { return ":status" }
    if (index == 65) { return ":status" }
    if (index == 66) { return ":status" }
