    if (index == 21) { return "PUT" }
    if (index == 22) { return "http" }
    if (index == 23) { return "https" }
    if (index == 24) { return "103" }
    if (index == 25) { return "200" }
    if (index == 26) { return "304" }
    if (index == 27) { return "404" }
    if (index == 28) { return "503" }
    if (index == 29) { return "*/*" }
    if (index == 30) { return "application/dns-message" }
    if (index == 31) { return "gzip, deflate, br" }
    if (index == 32) { return "bytes" }
    if (index == 33) { return "cache-control" }
    if (index == 34) { return "content-type" }
    if (index == 35) { return "*" }
