// Return the header value for a static table index (0-98)
fun qpackStaticValue(index: Int): String {
    if (index == 1) { return "/" }
    if (index == 2) { return "0" }
    if (index == 4) { return "0" }
    if (index == 15) { return "CONNECT" }
    if (index == 16) { return "DELETE" }
    if (index == 17) { return "GET" }
    if (index == 18) { return "HEAD" }
    if (index == 19) { return "OPTIONS" }
