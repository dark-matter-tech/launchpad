// Decode Huffman-encoded data
// data: raw bytes, pos: start offset, byteLen: number of Huffman bytes
fun hpackHuffmanDecode(buf: String, pos: Int, byteLen: Int): String {
    var result: String = ""
    var bitBuffer: Int = 0
    var bitsAvail: Int = 0
    var decodeError: Bool = false
    var i: Int = 0
    while (i < byteLen) {
        val b = charCodeAt(buf, pos + i)
        bitBuffer = bitBuffer * 256 + b
        bitsAvail = bitsAvail + 8
        // Try to decode symbols while we have enough bits
        var keepDecoding: Bool = true
        while (keepDecoding) {
            if (bitsAvail < 5) {
                keepDecoding = false
            } else {
                var matched: Bool = false
                // Gap H2: Check for EOS symbol (256) before checking 0-255
                // EOS symbol has code length 30, so only check if we have enough bits
                if (bitsAvail >= 30) {
                    val eosCode = hpackHuffmanCode(256)
                    val eosShift = bitsAvail - 30
                    val eosExtracted = bitBuffer / hpackPow2(eosShift)
                    if (eosExtracted == eosCode) {
                        // RFC 7541 Section 5.2: EOS symbol MUST NOT be decoded
                        decodeError = true
                        keepDecoding = false
                        matched = true
                    }
                }
                // Try each symbol from 0-255
                var sym: Int = 0
                while (sym <= 255) {
                    if (matched == false) {
                        val codeLen = hpackHuffmanLen(sym)
                        if (bitsAvail >= codeLen) {
                            val code = hpackHuffmanCode(sym)
                            // Extract top codeLen bits from bitBuffer
                            val shift = bitsAvail - codeLen
                            val extracted = bitBuffer / hpackPow2(shift)
                            if (extracted == code) {
                                result = stringConcat(result, hpackByteToChar(sym))
                                // Remove matched bits
                                bitBuffer = bitBuffer - extracted * hpackPow2(shift)
                                bitsAvail = bitsAvail - codeLen
                                matched = true
                            }
                        }
                    }
                    sym = sym + 1
                }
                if (matched == false) {
                    // Not enough bits to match — need more data from next byte
                    keepDecoding = false
                }
            }
        }
        i = i + 1
    }
    // Gap H1: Validate Huffman padding (RFC 7541 Section 5.2)
    // After decoding, remaining bits must be fewer than 8 and all 1s (EOS prefix)
    if (bitsAvail > 0) {
        if (bitsAvail > 7) {
            // Padding exceeds 7 bits — MUST be treated as decoding error
            decodeError = true
        } else {
            // Check that remaining bits are all 1s
            val padMask = hpackPow2(bitsAvail) - 1
            if (bitBuffer != padMask) {
                // Padding is not EOS prefix (not all 1s) — MUST be decoding error
                decodeError = true
            }
        }
    }
    if (decodeError) {
        return "hpack-huffman-error"
    }
    return result
}

// == Huffman Encoding (RFC 7541 Appendix B) ===================================

// Compute the Huffman encoded length in bytes for a string.
// Sums the bit lengths for each character and rounds up to full bytes.
fun hpackHuffmanEncodedLength(s: String): Int {
    var totalBits: Int = 0
    var i: Int = 0
    val sLen = stringLength(s)
    while (i < sLen) {
        val ch = charCodeAt(s, i)
        totalBits = totalBits + hpackHuffmanLen(ch)
        i = i + 1
    }
    // Round up to bytes: (totalBits + 7) / 8
    return (totalBits + 7) / 8
}

// Huffman encode a string per RFC 7541 Appendix B.
// Bit-packs symbols using hpackHuffmanCode()/hpackHuffmanLen(), then pads
// remaining bits with EOS prefix (all 1s).
fun hpackHuffmanEncode(s: String): String {
    var result: String = ""
    var bitBuffer: Int = 0
    var bitsInBuffer: Int = 0
    var i: Int = 0
    val sLen = stringLength(s)
    while (i < sLen) {
        val ch = charCodeAt(s, i)
        val code = hpackHuffmanCode(ch)
        val codeLen = hpackHuffmanLen(ch)
        // Shift bitBuffer left by codeLen bits and add the code
        // Since no bitwise OR, we use addition (bits don't overlap)
        bitBuffer = bitBuffer * hpackPow2(codeLen) + code
        bitsInBuffer = bitsInBuffer + codeLen
        // Extract complete bytes from the buffer
        while (bitsInBuffer >= 8) {
            bitsInBuffer = bitsInBuffer - 8
            val byteVal = bitBuffer / hpackPow2(bitsInBuffer)
            result = stringConcat(result, hpackByteToChar(byteVal))
            // Remove the extracted byte from the buffer
            bitBuffer = bitBuffer - byteVal * hpackPow2(bitsInBuffer)
        }
        i = i + 1
    }
    // Pad remaining bits with 1s (EOS prefix pattern)
    if (bitsInBuffer > 0) {
        val padBits = 8 - bitsInBuffer
        // Shift left by padBits and fill with 1s
        val padMask = hpackPow2(padBits) - 1
        val lastByte = bitBuffer * hpackPow2(padBits) + padMask
        result = stringConcat(result, hpackByteToChar(lastByte))
    }
    return result
}

// == Dynamic Table (RFC 7541 Section 2.3) =====================================

// Create an HPACK encoder/decoder context with dynamic table
fun hpackCreateContext(): Map {
    val ctx = mapCreate()
    mapPut(ctx, "dynamicEntries", listCreate())
    mapPut(ctx, "dynamicSize", 0)
    mapPut(ctx, "maxSize", 4096)
    mapPut(ctx, "protocolMaxSize", 4096)
    mapPut(ctx, "maxHeaderFieldSize", 8192)
    mapPut(ctx, "maxTotalDecodedSize", 65536)
    return ctx
}

// Set the protocol-level maximum dynamic table size (e.g., SETTINGS_HEADER_TABLE_SIZE)
// hpackDynamicResize will reject sizes exceeding this limit.
fun hpackSetProtocolMaxSize(ctx: Map, maxSize: Int): Unit {
    mapPut(ctx, "protocolMaxSize", maxSize)
    // Clamp current table size if it exceeds the new protocol max
    val currentMax = toInt(mapGet(ctx, "maxSize"))
    if (currentMax > maxSize) {
        mapPut(ctx, "maxSize", maxSize)
        hpackDynamicEvict(ctx, maxSize)
    }
}

// Add an entry to the dynamic table (newest at index 0)
// Entry size = len(name) + len(value) + 32 per RFC 7541 Section 4.1
fun hpackDynamicAdd(ctx: Map, name: String, value: String): Unit {
    val entrySize = stringLength(name) + stringLength(value) + 32
    val maxSize = toInt(mapGet(ctx, "maxSize"))
    // If single entry exceeds maxSize, evict all and don't add
    if (entrySize > maxSize) {
        val entries = mapGet(ctx, "dynamicEntries")
        while (listSize(entries) > 0) {
            listRemoveAt(entries, listSize(entries) - 1)
        }
        mapPut(ctx, "dynamicSize", 0)
        return
    }
    // Evict until there's room
    hpackDynamicEvict(ctx, maxSize - entrySize)
    // Prepend new entry
    val entry = mapCreate()
    mapPut(entry, "name", name)
    mapPut(entry, "value", value)
    val oldEntries = mapGet(ctx, "dynamicEntries")
    val newEntries = listCreate()
    listAppend(newEntries, entry)
    var _hi: Int = 0
    while (_hi < listSize(oldEntries)) {
        listAppend(newEntries, listGet(oldEntries, _hi))
        _hi = _hi + 1
    }
    mapPut(ctx, "dynamicEntries", newEntries)
    val entries = newEntries
    val currentSize = toInt(mapGet(ctx, "dynamicSize"))
    mapPut(ctx, "dynamicSize", currentSize + entrySize)
}

// Evict entries from the end until dynamicSize <= targetSize
fun hpackDynamicEvict(ctx: Map, targetSize: Int): Unit {
    val entries = mapGet(ctx, "dynamicEntries")
    var currentSize: Int = toInt(mapGet(ctx, "dynamicSize"))
    while (currentSize > targetSize) {
        if (listSize(entries) == 0) {
            currentSize = 0
        } else {
            val lastIdx = listSize(entries) - 1
            val last = listGet(entries, lastIdx)
            val name = toString(mapGet(last, "name"))
            val value = toString(mapGet(last, "value"))
            val entrySize = stringLength(name) + stringLength(value) + 32
            currentSize = currentSize - entrySize
            listRemoveAt(entries, lastIdx)
        }
    }
    if (currentSize < 0) { currentSize = 0 }
    mapPut(ctx, "dynamicSize", currentSize)
}

// Resize the dynamic table maximum size, evicting as needed
fun hpackDynamicResize(ctx: Map, newMaxSize: Int): Unit {
    val protocolMax = toInt(mapGet(ctx, "protocolMaxSize"))
    if (newMaxSize > protocolMax) {
        return
    }
    mapPut(ctx, "maxSize", newMaxSize)
    hpackDynamicEvict(ctx, newMaxSize)
}

// Unified lookup: index 1-61 = static, 62+ = dynamic (62 = newest)
// Returns map with "name" and "value", or empty-named map if invalid
fun hpackLookup(ctx: Map, index: Int): Map {
    if (index >= 1) {
        if (index <= 61) {
            return hpackStaticEntry(index)
        }
    }
    val dynIdx = index - 62
    val entries = mapGet(ctx, "dynamicEntries")
    if (dynIdx >= 0) {
        if (dynIdx < listSize(entries)) {
            val entry = listGet(entries, dynIdx)
            val result = mapCreate()
            mapPut(result, "name", toString(mapGet(entry, "name")))
            mapPut(result, "value", toString(mapGet(entry, "value")))
            return result
        }
    }
    val empty = mapCreate()
    mapPut(empty, "name", "")
    mapPut(empty, "value", "")
    return empty
}

// Unified name-only lookup: index 1-61 = static, 62+ = dynamic
fun hpackLookupName(ctx: Map, index: Int): String {
    if (index >= 1) {
        if (index <= 61) {
            return hpackStaticName(index)
        }
    }
    val dynIdx = index - 62
    val entries = mapGet(ctx, "dynamicEntries")
    if (dynIdx >= 0) {
        if (dynIdx < listSize(entries)) {
            val entry = listGet(entries, dynIdx)
            return toString(mapGet(entry, "name"))
        }
    }
    return ""
}

// Return the current number of entries in the dynamic table
fun hpackDynamicTableSize(ctx: Map): Int {
    return toInt(mapGet(ctx, "dynamicSize"))
}

// Return the number of entries in the dynamic table
fun hpackDynamicTableLength(ctx: Map): Int {
    val entries = mapGet(ctx, "dynamicEntries")
    return listSize(entries)
}

// Set the maximum allowed size of a single header field (name + value + 32)
fun hpackSetMaxHeaderFieldSize(ctx: Map, maxSize: Int): Unit {
    mapPut(ctx, "maxHeaderFieldSize", maxSize)
}

// Set the maximum allowed total decoded size for a header block
fun hpackSetMaxTotalDecodedSize(ctx: Map, maxSize: Int): Unit {
    mapPut(ctx, "maxTotalDecodedSize", maxSize)
}

// == Sensitive Header Detection ================================================

// Return true if a header name is sensitive and should never be indexed
fun hpackIsSensitive(name: String): Bool {
    if (name == "authorization") { return true }
    if (name == "cookie") { return true }
    if (name == "set-cookie") { return true }
    if (name == "proxy-authorization") { return true }
    return false
}

// == Header Block Encoding/Decoding ===========================================

// Encode a dynamic table size update instruction
fun hpackEncodeDynamicSizeUpdate(newMaxSize: Int): String {
    // 001xxxxx prefix, 5-bit integer
    return hpackEncodeInt(newMaxSize, 5, 32)
}

// Encode a list of header name-value pairs into an HPACK header block
// headers: list of maps, each with "name" and "value" keys
// Strategy (in priority order):
//   1. Exact static table match → indexed representation (0x80 prefix, Section 6.1)
//   2. Exact dynamic table match → indexed representation (0x80 prefix, Section 6.1)
//   3. Sensitive headers → literal-never-indexed (0x10 prefix, Section 6.2.3)
//   4. Dynamic table name-only match → literal-with-incremental-indexing (0x40 prefix)
//   5. Static table name-only match → literal-with-incremental-indexing (0x40 prefix)
//   6. No match → literal-with-incremental-indexing, new name (0x40 prefix)
fun hpackEncode(ctx: Map, headers: List): String {
    var result: String = ""
    var i: Int = 0
    while (i < listSize(headers)) {
        val header = listGet(headers, i)
        val name = toString(mapGet(header, "name"))
        val value = toString(mapGet(header, "value"))
        var encoded: Bool = false

        // 1. Check for exact static table match (Section 6.1 — Indexed Representation)
        val exactIdx = hpackStaticLookup(name, value)
        if (exactIdx > 0) {
            // Indexed header field: 1xxxxxxx, 7-bit prefix
            result = stringConcat(result, hpackEncodeInt(exactIdx, 7, 128))
            encoded = true
        }

        // 2. Check for exact dynamic table match (Section 6.1 — Indexed Representation)
        if (encoded == false) {
            val dynEntries = mapGet(ctx, "dynamicEntries")
            var dynExactIdx: Int = 0
            var di: Int = 0
            while (di < listSize(dynEntries)) {
                val dynEntry = listGet(dynEntries, di)
                if (toString(mapGet(dynEntry, "name")) == name) {
                    if (toString(mapGet(dynEntry, "value")) == value) {
                        if (dynExactIdx == 0) {
                            dynExactIdx = 62 + di
                        }
                    }
                }
                di = di + 1
            }
            if (dynExactIdx > 0) {
                result = stringConcat(result, hpackEncodeInt(dynExactIdx, 7, 128))
                encoded = true
            }
        }

        // 3. Sensitive headers use never-indexed encoding (Section 6.2.3)
        if (encoded == false) {
            if (hpackIsSensitive(name)) {
                val nameIdx = hpackStaticLookupName(name)
                if (nameIdx > 0) {
                    result = stringConcat(result, hpackEncodeInt(nameIdx, 4, 16))
                    result = stringConcat(result, hpackEncodeString(value))
                } else {
                    result = stringConcat(result, hpackByteToChar(16))
                    result = stringConcat(result, hpackEncodeString(name))
                    result = stringConcat(result, hpackEncodeString(value))
                }
                encoded = true
            }
        }

        // 4. Check dynamic table for name-only match (literal with incremental indexing)
        if (encoded == false) {
            val dynEntries2 = mapGet(ctx, "dynamicEntries")
            var dynNameIdx: Int = 0
            var dni: Int = 0
            while (dni < listSize(dynEntries2)) {
                val dynEntry = listGet(dynEntries2, dni)
                if (toString(mapGet(dynEntry, "name")) == name) {
                    if (dynNameIdx == 0) {
                        dynNameIdx = 62 + dni
                    }
                }
                dni = dni + 1
            }
            if (dynNameIdx > 0) {
                // Literal with incremental indexing, referencing dynamic table name
                result = stringConcat(result, hpackEncodeInt(dynNameIdx, 6, 64))
                result = stringConcat(result, hpackEncodeString(value))
                hpackDynamicAdd(ctx, name, value)
                encoded = true
            }
        }

        // 5. Check static table for name-only match (literal with incremental indexing)
        if (encoded == false) {
            val nameIdx = hpackStaticLookupName(name)
            if (nameIdx > 0) {
                // Literal with incremental indexing (Section 6.2.1)
                // 6-bit prefix: 01xxxxxx → prefix bits = 64 (0x40)
                result = stringConcat(result, hpackEncodeInt(nameIdx, 6, 64))
                result = stringConcat(result, hpackEncodeString(value))
                hpackDynamicAdd(ctx, name, value)
                encoded = true
            }
        }

        // 6. No match anywhere — literal with incremental indexing, new name
        if (encoded == false) {
            // Literal with incremental indexing (Section 6.2.1), new name
            // 0100 0000 = 0x40 (incremental indexing, name index 0)
            result = stringConcat(result, hpackByteToChar(64))
            result = stringConcat(result, hpackEncodeString(name))
            result = stringConcat(result, hpackEncodeString(value))
            hpackDynamicAdd(ctx, name, value)
        }

        i = i + 1
    }
    return result
}

// Decode an HPACK header block into a list of header name-value maps
// data: raw bytes, dataLen: number of bytes to decode
// Includes HPACK bomb protection (max field size, max total decoded size)
// and RFC 7541 Section 4.2 size update validation (must be at start of block).
fun hpackDecode(ctx: Map, buf: String, bufLen: Int): List {
    val headers = listCreate()
    var pos: Int = 0
    var seenNonUpdate: Bool = false
    var totalDecodedSize: Int = 0
    val maxHeaderFieldSize = toInt(mapGet(ctx, "maxHeaderFieldSize"))
    val maxTotalDecodedSize = toInt(mapGet(ctx, "maxTotalDecodedSize"))
    while (pos < bufLen) {
        val b = charCodeAt(buf, pos)
        if (b / 128 == 1) {
            // Indexed header field (Section 6.1): top bit is 1
            seenNonUpdate = true
            val idxResult = hpackDecodeInt(buf, pos, 7)
            val index = toInt(mapGet(idxResult, "value"))
            pos = toInt(mapGet(idxResult, "pos"))
            // Gap H3: Check for integer overflow
            val idxOverflow = mapGet(idxResult, "overflow")
            if (idxOverflow == true) {
                val errEntry = mapCreate()
                mapPut(errEntry, "name", "hpack-error")
                mapPut(errEntry, "value", "integer overflow in indexed header")
                listAppend(headers, errEntry)
                return headers
            }
            // Gap H4: Index 0 is invalid (RFC 7541 Section 6.1)
            if (index == 0) {
                val errEntry = mapCreate()
                mapPut(errEntry, "name", "hpack-error")
                mapPut(errEntry, "value", "indexed header field index 0 is invalid")
                listAppend(headers, errEntry)
                return headers
            }
            if (index >= 1) {
                val entry = hpackLookup(ctx, index)
                val entryName = toString(mapGet(entry, "name"))
                if (stringLength(entryName) > 0) {
                    val entryValue = toString(mapGet(entry, "value"))
                    val fieldSize = stringLength(entryName) + stringLength(entryValue) + 32
                    if (fieldSize > maxHeaderFieldSize) {
                        val errEntry = mapCreate()
                        mapPut(errEntry, "name", "hpack-error")
                        mapPut(errEntry, "value", "header field exceeds max size")
                        listAppend(headers, errEntry)
                    } else {
                        totalDecodedSize = totalDecodedSize + fieldSize
                        if (totalDecodedSize > maxTotalDecodedSize) {
                            val errEntry = mapCreate()
                            mapPut(errEntry, "name", "hpack-error")
                            mapPut(errEntry, "value", "total decoded size exceeds limit")
                            listAppend(headers, errEntry)
                        } else {
                            listAppend(headers, entry)
                        }
                    }
                }
            }
        } else { if (b / 64 == 1) {
            // Literal with incremental indexing (Section 6.2.1): 01xxxxxx
            seenNonUpdate = true
            val idxResult = hpackDecodeInt(buf, pos, 6)
            val nameIdx = toInt(mapGet(idxResult, "value"))
            pos = toInt(mapGet(idxResult, "pos"))
            var name: String = ""
            if (nameIdx > 0) {
                name = hpackLookupName(ctx, nameIdx)
            } else {
                val nameResult = hpackDecodeString(buf, pos)
                name = toString(mapGet(nameResult, "value"))
                pos = toInt(mapGet(nameResult, "pos"))
            }
            val valueResult = hpackDecodeString(buf, pos)
            val value = toString(mapGet(valueResult, "value"))
            pos = toInt(mapGet(valueResult, "pos"))
            val fieldSize = stringLength(name) + stringLength(value) + 32
            if (fieldSize > maxHeaderFieldSize) {
                val errEntry = mapCreate()
                mapPut(errEntry, "name", "hpack-error")
                mapPut(errEntry, "value", "header field exceeds max size")
                listAppend(headers, errEntry)
            } else {
                totalDecodedSize = totalDecodedSize + fieldSize
                if (totalDecodedSize > maxTotalDecodedSize) {
                    val errEntry = mapCreate()
                    mapPut(errEntry, "name", "hpack-error")
                    mapPut(errEntry, "value", "total decoded size exceeds limit")
                    listAppend(headers, errEntry)
                } else {
                    val entry = mapCreate()
                    mapPut(entry, "name", name)
                    mapPut(entry, "value", value)
                    listAppend(headers, entry)
                    // Add to dynamic table (incremental indexing)
                    hpackDynamicAdd(ctx, name, value)
                }
            }
        } else { if (b / 32 == 1) {
            // Dynamic table size update (Section 6.3): 001xxxxx
            if (seenNonUpdate == true) {
                // RFC 7541 Section 4.2: size updates MUST appear at start of block
                val errEntry = mapCreate()
                mapPut(errEntry, "name", "hpack-error")
                mapPut(errEntry, "value", "dynamic table size update not at start of block")
                listAppend(headers, errEntry)
                val sizeResult = hpackDecodeInt(buf, pos, 5)
                pos = toInt(mapGet(sizeResult, "pos"))
            } else {
                val sizeResult = hpackDecodeInt(buf, pos, 5)
                val newSize = toInt(mapGet(sizeResult, "value"))
                pos = toInt(mapGet(sizeResult, "pos"))
                hpackDynamicResize(ctx, newSize)
            }
        } else { if (b / 16 == 1) {
            // Literal never indexed (Section 6.2.3): 0001xxxx
            seenNonUpdate = true
            val idxResult = hpackDecodeInt(buf, pos, 4)
            val nameIdx = toInt(mapGet(idxResult, "value"))
            pos = toInt(mapGet(idxResult, "pos"))
            var name: String = ""
            if (nameIdx > 0) {
                name = hpackLookupName(ctx, nameIdx)
            } else {
                val nameResult = hpackDecodeString(buf, pos)
                name = toString(mapGet(nameResult, "value"))
                pos = toInt(mapGet(nameResult, "pos"))
            }
            val valueResult = hpackDecodeString(buf, pos)
            val value = toString(mapGet(valueResult, "value"))
            pos = toInt(mapGet(valueResult, "pos"))
            val fieldSize = stringLength(name) + stringLength(value) + 32
            if (fieldSize > maxHeaderFieldSize) {
                val errEntry = mapCreate()
                mapPut(errEntry, "name", "hpack-error")
                mapPut(errEntry, "value", "header field exceeds max size")
                listAppend(headers, errEntry)
            } else {
                totalDecodedSize = totalDecodedSize + fieldSize
                if (totalDecodedSize > maxTotalDecodedSize) {
                    val errEntry = mapCreate()
                    mapPut(errEntry, "name", "hpack-error")
                    mapPut(errEntry, "value", "total decoded size exceeds limit")
                    listAppend(headers, errEntry)
                } else {
                    val entry = mapCreate()
                    mapPut(entry, "name", name)
                    mapPut(entry, "value", value)
                    listAppend(headers, entry)
                }
            }
        } else {
            // Literal without indexing (Section 6.2.2): 0000xxxx
            seenNonUpdate = true
            val idxResult = hpackDecodeInt(buf, pos, 4)
            val nameIdx = toInt(mapGet(idxResult, "value"))
            pos = toInt(mapGet(idxResult, "pos"))
            var name: String = ""
            if (nameIdx > 0) {
                name = hpackLookupName(ctx, nameIdx)
            } else {
                val nameResult = hpackDecodeString(buf, pos)
                name = toString(mapGet(nameResult, "value"))
                pos = toInt(mapGet(nameResult, "pos"))
            }
            val valueResult = hpackDecodeString(buf, pos)
            val value = toString(mapGet(valueResult, "value"))
            pos = toInt(mapGet(valueResult, "pos"))
            val fieldSize = stringLength(name) + stringLength(value) + 32
            if (fieldSize > maxHeaderFieldSize) {
                val errEntry = mapCreate()
                mapPut(errEntry, "name", "hpack-error")
                mapPut(errEntry, "value", "header field exceeds max size")
                listAppend(headers, errEntry)
            } else {
                totalDecodedSize = totalDecodedSize + fieldSize
                if (totalDecodedSize > maxTotalDecodedSize) {
                    val errEntry = mapCreate()
                    mapPut(errEntry, "name", "hpack-error")
                    mapPut(errEntry, "value", "total decoded size exceeds limit")
                    listAppend(headers, errEntry)
                } else {
                    val entry = mapCreate()
                    mapPut(entry, "name", name)
                    mapPut(entry, "value", value)
                    listAppend(headers, entry)
                }
            }
        } } } }
    }
    return headers
}

// == Helpers ==================================================================

// Compute 2^n for small n (0-30)
fun hpackPow2(n: Int): Int {
    var result: Int = 1
    var i: Int = 0
    while (i < n) {
        result = result * 2
        i = i + 1
    }
    return result
}

// Bitwise AND for values up to 255: a & mask
fun hpackAnd(a: Int, mask: Int): Int {
    var result: Int = 0
    var bit: Int = 1
    var va: Int = a
    var vm: Int = mask
    var n: Int = 0
    while (n < 8) {
        val aBit = va - (va / 2) * 2
        val mBit = vm - (vm / 2) * 2
        if (aBit == 1) {
            if (mBit == 1) {
                result = result + bit
            }
        }
        va = va / 2
        vm = vm / 2
        bit = bit * 2
        n = n + 1
    }
    return result
}
