    if (sym == 29) { return 268435449 }    // 28 bits
    if (sym == 30) { return 268435450 }    // 28 bits
    if (sym == 31) { return 268435451 }    // 28 bits
    if (sym == 32) { return 20 }           // 6 bits  (space)
    if (sym == 33) { return 1016 }         // 10 bits !
    if (sym == 34) { return 1017 }         // 10 bits "
    if (sym == 35) { return 4084 }         // 12 bits #
    if (sym == 36) { return 8185 }         // 13 bits $
    if (sym == 37) { return 21 }           // 6 bits  %
    if (sym == 38) { return 248 }          // 8 bits  &
