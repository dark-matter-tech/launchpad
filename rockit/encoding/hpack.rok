// rockit.encoding.hpack — HPACK header compression
//
// Implements HPACK header compression for HTTP/2, including the static table
// (61 entries), dynamic table with eviction, integer encoding/decoding, string
// literal encoding/decoding, and Huffman decoding. Encoder uses incremental
// indexing for non-sensitive headers, never-indexed for sensitive headers.
//
// Standards: RFC 7541 — HPACK: Header Compression for HTTP/2
//
// Usage:
//   import rockit.encoding.hpack
//   val ctx = hpackCreateContext()
//   val encoded = hpackEncode(ctx, headers)
//   val decoded = hpackDecode(ctx, data, dataLen)

// == Representation Type Constants ============================================

// Indexed header field representation (Section 6.1)
fun HPACK_INDEXED(): Int { return 1 }

// Literal with incremental indexing (Section 6.2.1)
fun HPACK_LITERAL_INCREMENTAL(): Int { return 2 }

// Literal without indexing (Section 6.2.2)
fun HPACK_LITERAL_NONE(): Int { return 3 }

// Literal never indexed (Section 6.2.3)
fun HPACK_LITERAL_NEVER(): Int { return 4 }

// == Static Table (RFC 7541 Appendix A) =======================================

// Return the header name for a static table index (1-61)
fun hpackStaticName(index: Int): String {
    if (index == 1) { return ":authority" }
    if (index == 2) { return ":method" }
    if (index == 3) { return ":method" }
    if (index == 4) { return ":path" }
    if (index == 5) { return ":path" }
    if (index == 6) { return ":scheme" }
    if (index == 7) { return ":scheme" }
    if (index == 8) { return ":status" }
    if (index == 9) { return ":status" }
    if (index == 10) { return ":status" }
    if (index == 11) { return ":status" }
    if (index == 12) { return ":status" }
    if (index == 13) { return ":status" }
    if (index == 14) { return ":status" }
    if (index == 15) { return "accept-charset" }
    if (index == 16) { return "accept-encoding" }
    if (index == 17) { return "accept-language" }
    if (index == 18) { return "accept-ranges" }
    if (index == 19) { return "accept" }
    if (index == 20) { return "access-control-allow-origin" }
    if (index == 21) { return "age" }
    if (index == 22) { return "allow" }
    if (index == 23) { return "authorization" }
    if (index == 24) { return "cache-control" }
    if (index == 25) { return "content-disposition" }
    if (index == 26) { return "content-encoding" }
    if (index == 27) { return "content-language" }
    if (index == 28) { return "content-length" }
    if (index == 29) { return "content-location" }
    if (index == 30) { return "content-range" }
    if (index == 31) { return "content-type" }
    if (index == 32) { return "cookie" }
    if (index == 33) { return "date" }
    if (index == 34) { return "etag" }
    if (index == 35) { return "expect" }
    if (index == 36) { return "expires" }
    if (index == 37) { return "from" }
    if (index == 38) { return "host" }
    if (index == 39) { return "if-match" }
    if (index == 40) { return "if-modified-since" }
    if (index == 41) { return "if-none-match" }
    if (index == 42) { return "if-range" }
    if (index == 43) { return "if-unmodified-since" }
    if (index == 44) { return "last-modified" }
    if (index == 45) { return "link" }
    if (index == 46) { return "location" }
    if (index == 47) { return "max-forwards" }
    if (index == 48) { return "proxy-authenticate" }
    if (index == 49) { return "proxy-authorization" }
    if (index == 50) { return "range" }
    if (index == 51) { return "referer" }
    if (index == 52) { return "refresh" }
    if (index == 53) { return "retry-after" }
    if (index == 54) { return "server" }
    if (index == 55) { return "set-cookie" }
    if (index == 56) { return "strict-transport-security" }
    if (index == 57) { return "transfer-encoding" }
    if (index == 58) { return "user-agent" }
    if (index == 59) { return "vary" }
    if (index == 60) { return "via" }
    if (index == 61) { return "www-authenticate" }
    return ""
}

// Return the header value for a static table index (1-61)
fun hpackStaticValue(index: Int): String {
    if (index == 2) { return "GET" }
    if (index == 3) { return "POST" }
    if (index == 4) { return "/" }
    if (index == 5) { return "/index.html" }
    if (index == 6) { return "http" }
    if (index == 7) { return "https" }
    if (index == 8) { return "200" }
    if (index == 9) { return "204" }
    if (index == 10) { return "206" }
    if (index == 11) { return "304" }
    if (index == 12) { return "400" }
    if (index == 13) { return "404" }
    if (index == 14) { return "500" }
    if (index == 16) { return "gzip, deflate" }
    return ""
}

// Return a map with "name" and "value" for a static table index
fun hpackStaticEntry(index: Int): Map {
    val entry = mapCreate()
    mapPut(entry, "name", hpackStaticName(index))
    mapPut(entry, "value", hpackStaticValue(index))
    return entry
}

// Look up exact match (name+value) in static table, return index or 0
fun hpackStaticLookup(name: String, value: String): Int {
    var i: Int = 1
    while (i <= 61) {
        if (hpackStaticName(i) == name) {
            if (hpackStaticValue(i) == value) {
                return i
            }
        }
        i = i + 1
    }
    return 0
}

// Look up name-only match in static table, return first index or 0
fun hpackStaticLookupName(name: String): Int {
    var i: Int = 1
    while (i <= 61) {
        if (hpackStaticName(i) == name) {
            return i
        }
        i = i + 1
    }
    return 0
}

// == Integer Encoding/Decoding (RFC 7541 Section 5.1) =========================

// Encode an integer with the given prefix size (5, 6, or 7 bits)
// prefixBits: the high bits to OR into the first byte
fun hpackEncodeInt(value: Int, prefixSize: Int, prefixBits: Int): String {
    val maxPrefix = hpackPow2(prefixSize) - 1
    if (value < maxPrefix) {
        return intToChar(prefixBits + value)
    }
    var result: String = intToChar(prefixBits + maxPrefix)
    var remaining: Int = value - maxPrefix
    while (remaining >= 128) {
        result = stringConcat(result, intToChar(128 + remaining - (remaining / 128) * 128))
        remaining = remaining / 128
    }
    result = stringConcat(result, intToChar(remaining))
    return result
}

// Decode an integer from data at position pos with the given prefix size
// Returns map with "value" and "pos" (updated position)
fun hpackDecodeInt(buf: String, pos: Int, prefixSize: Int): Map {
    val result = mapCreate()
    val bufLen = stringLength(buf)
    if (pos >= bufLen) {
        mapPut(result, "value", 0)
        mapPut(result, "pos", pos)
        return result
    }
    val maxPrefix = hpackPow2(prefixSize) - 1
    val mask = maxPrefix
    val b = charCodeAt(buf, pos)
    var value: Int = hpackAnd(b, mask)
    var newPos: Int = pos + 1
    if (value < maxPrefix) {
        mapPut(result, "value", value)
        mapPut(result, "pos", newPos)
        return result
    }
    // Multi-byte integer
    var m: Int = 0
    var done: Bool = false
    while (done == false) {
        if (newPos >= bufLen) {
            done = true
        } else {
            val nextByte = charCodeAt(buf, newPos)
            value = value + (nextByte - (nextByte / 128) * 128) * hpackPow2(m)
            newPos = newPos + 1
            if (nextByte < 128) {
                done = true
            }
            m = m + 7
        }
    }
    mapPut(result, "value", value)
    mapPut(result, "pos", newPos)
    return result
}

// == String Encoding/Decoding (RFC 7541 Section 5.2) ==========================

// Encode a string literal (raw, no Huffman: H=0)
fun hpackEncodeString(s: String): String {
    val len = stringLength(s)
    // H=0 means prefix bits are 0, prefix size is 7
    var result: String = hpackEncodeInt(len, 7, 0)
    result = stringConcat(result, s)
    return result
}

// Decode a string literal from data at pos
// Returns map with "value" (string) and "pos" (updated position)
fun hpackDecodeString(buf: String, pos: Int): Map {
    val result = mapCreate()
    val bufLen = stringLength(buf)
    if (pos >= bufLen) {
        mapPut(result, "value", "")
        mapPut(result, "pos", pos)
        return result
    }
    val firstByte = charCodeAt(buf, pos)
    val huffman = firstByte / 128  // H bit
    // Decode length with 7-bit prefix
    val lenResult = hpackDecodeInt(buf, pos, 7)
    val strLen = toInt(mapGet(lenResult, "value"))
    var newPos: Int = toInt(mapGet(lenResult, "pos"))
    if (huffman == 1) {
        // Huffman-encoded string
        val decoded = hpackHuffmanDecode(buf, newPos, strLen)
        mapPut(result, "value", decoded)
        mapPut(result, "pos", newPos + strLen)
        return result
    }
    // Raw string
    var s: String = ""
    var i: Int = 0
    while (i < strLen) {
        if (newPos + i < bufLen) {
            s = stringConcat(s, intToChar(charCodeAt(buf, newPos + i)))
        }
        i = i + 1
    }
    mapPut(result, "value", s)
    mapPut(result, "pos", newPos + strLen)
    return result
}

// == Huffman Decoding (RFC 7541 Appendix B) ===================================

// Get the Huffman code for a symbol (0-256). Symbol 256 = EOS.
// Returns the code as an integer.
fun hpackHuffmanCode(sym: Int): Int {
    if (sym == 0) { return 8184 }          // 13 bits
    if (sym == 1) { return 8388568 }       // 23 bits
    if (sym == 2) { return 268435426 }     // 28 bits
    if (sym == 3) { return 268435427 }     // 28 bits
    if (sym == 4) { return 268435428 }     // 28 bits
    if (sym == 5) { return 268435429 }     // 28 bits
