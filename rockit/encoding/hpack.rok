    if (sym == 10) { return 1073741820 }   // 30 bits
    if (sym == 11) { return 268435433 }    // 28 bits
    if (sym == 12) { return 268435434 }    // 28 bits
    if (sym == 13) { return 1073741821 }   // 30 bits
    if (sym == 14) { return 268435435 }    // 28 bits
    if (sym == 15) { return 268435436 }    // 28 bits
    if (sym == 16) { return 268435437 }    // 28 bits
    if (sym == 17) { return 268435438 }    // 28 bits
    if (sym == 18) { return 268435439 }    // 28 bits
    if (sym == 19) { return 268435440 }    // 28 bits
    if (sym == 20) { return 268435441 }    // 28 bits
    if (sym == 21) { return 268435442 }    // 28 bits
    if (sym == 22) { return 1073741822 }   // 30 bits
    if (sym == 23) { return 268435443 }    // 28 bits
    if (sym == 24) { return 268435444 }    // 28 bits
    if (sym == 25) { return 268435445 }    // 28 bits
