// Get the Huffman code length in bits for a symbol (0-256)
// Values from RFC 7541 Appendix B.
fun hpackHuffmanLen(sym: Int): Int {
    if (sym == 0) { return 13 }
    if (sym == 1) { return 23 }
    if (sym == 2) { return 28 }
    if (sym == 3) { return 28 }
    if (sym == 4) { return 28 }
    if (sym == 5) { return 28 }
    if (sym == 6) { return 28 }
    if (sym == 7) { return 28 }
    if (sym == 8) { return 28 }
    if (sym == 9) { return 24 }
    if (sym == 10) { return 30 }
    if (sym == 11) { return 28 }
    if (sym == 12) { return 28 }
    if (sym == 13) { return 30 }
    if (sym == 14) { return 28 }
    if (sym == 15) { return 28 }
    if (sym == 16) { return 28 }
    if (sym == 17) { return 28 }
    if (sym == 18) { return 28 }
    if (sym == 19) { return 28 }
    if (sym == 20) { return 28 }
    if (sym == 21) { return 28 }
    if (sym == 22) { return 30 }
    if (sym == 23) { return 28 }
    if (sym == 24) { return 28 }
    if (sym == 25) { return 28 }
    if (sym == 26) { return 28 }
