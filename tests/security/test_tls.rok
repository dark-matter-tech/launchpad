// Tests for rockit.security.tls
// TLS context creation and connection tests
// NOTE: These tests require native compilation (LLVM backend + OpenSSL).
// They will fail under the bytecode interpreter until probe supports native test execution.
import rockit.testing.probe
import rockit.security.tls

// == Constants ================================================================

@Test fun testTlsErrorConstant() {
    assertEqualsStr("TLS_ERROR", TLS_ERROR())
}

@Test fun testTlsIsErrorOnErrorMap() {
    val m = mapCreate()
    mapPut(m, "type", TLS_ERROR())
    assertTrue(tlsIsError(m))
}

@Test fun testTlsIsErrorOnNormalMap() {
    val m = mapCreate()
    mapPut(m, "type", "ok")
    assertFalse(tlsIsError(m))
}

// == Context Creation =========================================================

@Test fun testTlsDefaultContextCreation() {
    val ctx = tlsDefaultContext()
    assertGreaterThanOrEqual(ctx, 0)
}

@Test fun testTlsServerContextNoFiles() {
    // Server context with non-existent cert/key should fail
    val ctx = tlsServerContext("/nonexistent/cert.pem", "/nonexistent/key.pem")
    assertEquals(-1, ctx)
}

// == Connection ===============================================================

@Test fun testTlsConnectToExample() {
    // Live test: connect to example.com:443
    val ctx = tlsDefaultContext()
    val result = tlsConnectTo(ctx, "example.com", 443)
    assertFalse(tlsIsError(result))
    val conn = toInt(mapGet(result, "conn"))
    assertGreaterThanOrEqual(conn, 0)
    tlsDisconnect(conn)
}

@Test fun testTlsConnectBadHost() {
    val ctx = tlsDefaultContext()
    val result = tlsConnectTo(ctx, "nonexistent.invalid", 443)
    assertTrue(tlsIsError(result))
}

@Test fun testTlsSendRecv() {
    // Live test: send HTTP request over TLS to example.com
    val ctx = tlsDefaultContext()
    val result = tlsConnectTo(ctx, "example.com", 443)
    if (tlsIsError(result)) { return }  // skip if no network
    val conn = toInt(mapGet(result, "conn"))
    val req = "GET / HTTP/1.1\r\nHost: example.com\r\nConnection: close\r\n\r\n"
    val sent = tlsSendData(conn, req)
    assertGreaterThan(sent, 0)
    val resp = tlsRecvData(conn, 4096)
    assertStringContains(resp, "HTTP/1.1")
    tlsDisconnect(conn)
}
