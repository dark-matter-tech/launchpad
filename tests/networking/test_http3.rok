// =============================================================================
// == Gap 14: Content-Length vs Body Length Validation (RFC 9114 Section 4.1.2)
// =============================================================================

@Test fun testGap14_ContentLengthMatchValidation() {
    // Build a synthetic response map and verify the concept
    val resp = mapCreate()
    mapPut(resp, "type", "H3_RESPONSE")
    mapPut(resp, "status", 200)
    mapPut(resp, "body", "hello")
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":status")
    mapPut(h1, "value", "200")
    listAppend(headers, h1)
    val h2 = mapCreate()
    mapPut(h2, "name", "content-length")
    mapPut(h2, "value", "5")
    listAppend(headers, h2)
    mapPut(resp, "headers", headers)
    // Content-Length = 5, body length = 5 (match)
    val clStr = h3Header(resp, "content-length")
    assertEquals(5, toInt(clStr))
    assertEquals(5, stringLength(h3Body(resp)))
}

@Test fun testGap14_ContentLengthMismatch() {
    // Mismatch: Content-Length says 10 but body is 5 bytes
    val resp = mapCreate()
    mapPut(resp, "type", "H3_RESPONSE")
    mapPut(resp, "body", "hello")
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":status")
    mapPut(h1, "value", "200")
    listAppend(headers, h1)
    val h2 = mapCreate()
    mapPut(h2, "name", "content-length")
    mapPut(h2, "value", "10")
    listAppend(headers, h2)
    mapPut(resp, "headers", headers)
    val clStr = h3Header(resp, "content-length")
    assertEquals(10, toInt(clStr))
    // Body length is 5, not 10 -- mismatch
    assertTrue(toInt(clStr) != stringLength(h3Body(resp)))
}

@Test fun testGap14_NoContentLength() {
    // No Content-Length header means no validation needed
    val resp = mapCreate()
    mapPut(resp, "type", "H3_RESPONSE")
    mapPut(resp, "body", "whatever")
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":status")
    mapPut(h1, "value", "200")
    listAppend(headers, h1)
    mapPut(resp, "headers", headers)
    val clStr = h3Header(resp, "content-length")
    assertEqualsStr("", clStr)
}

@Test fun testGap14_MessageErrorCode() {
    assertEquals(270, H3_MESSAGE_ERROR())
}

