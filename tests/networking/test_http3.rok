@Test fun testGap12_DuplicateControlStreamDetected() {
    // If peerControlStreamId is already set (>= 0), a second control stream
    // should be detected by h3ProcessPeerStreams
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 42)  // Already has a control stream
    mapPut(conn, "peerEncoderStreamId", 0 - 1)
    mapPut(conn, "peerDecoderStreamId", 0 - 1)
    mapPut(conn, "peerSettingsReceived", false)
    // Verify the existing ID is set
    assertEquals(42, toInt(mapGet(conn, "peerControlStreamId")))
    assertTrue(toInt(mapGet(conn, "peerControlStreamId")) >= 0)
}

@Test fun testGap12_DuplicateEncoderStreamDetected() {
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 0 - 1)
    mapPut(conn, "peerEncoderStreamId", 50)  // Already has encoder stream
    mapPut(conn, "peerDecoderStreamId", 0 - 1)
    assertTrue(toInt(mapGet(conn, "peerEncoderStreamId")) >= 0)
}

@Test fun testGap12_DuplicateDecoderStreamDetected() {
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 0 - 1)
    mapPut(conn, "peerEncoderStreamId", 0 - 1)
