@Test fun testGap8_PseudoHeaderAfterRegularHeader() {
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":status")
    mapPut(h1, "value", "200")
    listAppend(headers, h1)
    val h2 = mapCreate()
    mapPut(h2, "name", "content-type")
    mapPut(h2, "value", "text/plain")
    listAppend(headers, h2)
    // Pseudo-header after regular header -- invalid
    val h3hdr = mapCreate()
    mapPut(h3hdr, "name", ":status")
    mapPut(h3hdr, "value", "304")
    listAppend(headers, h3hdr)
    val result = h3ValidateResponseHeaders(headers)
    assertTrue(h3ToBool(mapGet(result, "valid")) == false)
    assertEqualsStr("Pseudo-header after regular header", toString(mapGet(result, "error")))
}

