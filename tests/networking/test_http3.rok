}

@Test fun testGap15_ValidatePushPromiseExceedsMax() {
    val conn = mapCreate()
    mapPut(conn, "maxPushIdSent", true)
    mapPut(conn, "maxPushIdValue", 5)
    mapPut(conn, "usedPushIds", listCreate())
    val result = h3ValidatePushPromise(conn, 10)
    assertTrue(h3ToBool(mapGet(result, "valid")) == false)
    assertEqualsStr("Push ID exceeds MAX_PUSH_ID", toString(mapGet(result, "error")))
}

@Test fun testGap15_ValidatePushPromiseDuplicate() {
    val conn = mapCreate()
    mapPut(conn, "maxPushIdSent", true)
    mapPut(conn, "maxPushIdValue", 10)
    val usedIds = listCreate()
    listAppend(usedIds, 3)
    mapPut(conn, "usedPushIds", usedIds)
    val result = h3ValidatePushPromise(conn, 3)
    assertTrue(h3ToBool(mapGet(result, "valid")) == false)
    assertEqualsStr("Duplicate push ID", toString(mapGet(result, "error")))
}

@Test fun testGap15_ValidatePushPromiseValid() {
    val conn = mapCreate()
    mapPut(conn, "maxPushIdSent", true)
    mapPut(conn, "maxPushIdValue", 10)
    mapPut(conn, "usedPushIds", listCreate())
    val result = h3ValidatePushPromise(conn, 5)
    assertTrue(h3ToBool(mapGet(result, "valid")))
}

@Test fun testGap15_RecordPushId() {
    val conn = mapCreate()
    mapPut(conn, "usedPushIds", listCreate())
    h3RecordPushId(conn, 3)
    h3RecordPushId(conn, 7)
    val usedIds = mapGet(conn, "usedPushIds")
    assertEquals(2, listSize(usedIds))
    assertTrue(listContains(usedIds, 3))
    assertTrue(listContains(usedIds, 7))
}

@Test fun testGap15_RecordPushIdCreatesListIfMissing() {
    val conn = mapCreate()
