// =============================================================================
// == Gap 4: First Control Stream Frame Must Be SETTINGS (RFC 9114 Section 6.2.1)
// =============================================================================

@Test fun testGap4_ReadControlStreamFrameStructure() {
    // Verify h3ReadControlStreamFrame returns expected map keys
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 0 - 1)
    mapPut(conn, "peerSettingsReceived", false)
    val quicConn = mapCreate()
    val result = h3ReadControlStreamFrame(conn, quicConn)
    assertTrue(mapContains(result, "ok"))
    assertTrue(mapContains(result, "error"))
    assertTrue(mapContains(result, "errorCode"))
    assertTrue(mapContains(result, "frameType"))
}

@Test fun testGap4_ReadControlStreamNoPeerStream() {
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 0 - 1)
    mapPut(conn, "peerSettingsReceived", false)
    val quicConn = mapCreate()
    val result = h3ReadControlStreamFrame(conn, quicConn)
    assertTrue(h3ToBool(mapGet(result, "ok")) == false)
    assertEquals(H3_INTERNAL_ERROR(), toInt(mapGet(result, "errorCode")))
}

