// == Split-Frame Handling Across Recv Boundaries ==============================

@Test fun testH3DecodeFrameCheckCompleteFrame() {
    // A complete DATA frame: type(0) + length(5) + "hello"
    val frame = h3EncodeFrame(H3_DATA(), "hello")
    val check = h3DecodeFrameCheck(frame, 0)
    assertTrue(h3ToBool(mapGet(check, "complete")))
}

@Test fun testH3DecodeFrameCheckIncompletePayload() {
    // Build a frame header that says payload is 10 bytes, but only provide 3
    var buf: String = quicEncodeVarint(H3_DATA())       // type varint
    buf = stringConcat(buf, quicEncodeVarint(10))        // length varint = 10
    buf = stringConcat(buf, "abc")                       // only 3 bytes of payload
    val check = h3DecodeFrameCheck(buf, 0)
    assertTrue(h3ToBool(mapGet(check, "complete")) == false)
}

@Test fun testH3DecodeFrameCheckIncompleteHeader() {
    // A 2-byte varint that is truncated to 1 byte
    // varint encoding of 16383 requires 2 bytes: 0x7f 0xff
    var buf: String = quicByteToChar(127)  // First byte of 2-byte varint (0x7f)
    // Missing second byte -- header is incomplete
    val check = h3DecodeFrameCheck(buf, 0)
    // The first byte 0x7f has top-2 bits = 01 (2-byte varint), so we need 2 bytes
    // But we only have 1 byte for the type, which is actually complete since
    // 0x7f top-2 bits = 01 means 2 bytes needed. We have only 1.
    assertTrue(h3ToBool(mapGet(check, "complete")) == false)
}

@Test fun testH3DecodeFrameCheckEmptyBuffer() {
    val check = h3DecodeFrameCheck("", 0)
    assertTrue(h3ToBool(mapGet(check, "complete")) == false)
}

@Test fun testH3DecodeFrameCheckMultipleFrames() {
    // Two complete frames concatenated
    val frame1 = h3EncodeFrame(H3_HEADERS(), "hdr")
    val frame2 = h3EncodeFrame(H3_DATA(), "body")
    var buf: String = frame1
    buf = stringConcat(buf, frame2)
    // First frame should be complete
    val check1 = h3DecodeFrameCheck(buf, 0)
    assertTrue(h3ToBool(mapGet(check1, "complete")))
}

@Test fun testH3VarintBytesNeeded() {
    // Single-byte varint: top 2 bits = 00
    var buf1: String = quicByteToChar(0)
    assertEquals(1, h3VarintBytesNeeded(buf1, 0))
    // Single-byte varint: top 2 bits = 00, value 63
    var buf2: String = quicByteToChar(63)
    assertEquals(1, h3VarintBytesNeeded(buf2, 0))
    // Two-byte varint: top 2 bits = 01
    var buf3: String = quicByteToChar(64)
    assertEquals(2, h3VarintBytesNeeded(buf3, 0))
    // Four-byte varint: top 2 bits = 10
    var buf4: String = quicByteToChar(128)
    assertEquals(4, h3VarintBytesNeeded(buf4, 0))
    // Eight-byte varint: top 2 bits = 11
    var buf5: String = quicByteToChar(192)
    assertEquals(8, h3VarintBytesNeeded(buf5, 0))
}

@Test fun testH3VarintBytesNeededEmptyBuffer() {
    assertEquals(0, h3VarintBytesNeeded("", 0))
}

@Test fun testH3SplitFrameReassembly() {
    // Simulate a frame split across boundaries by encoding a frame,
    // then verifying DecodeFrameCheck detects incomplete vs complete states
    val payload = "Hello, HTTP/3 split!"
    val fullFrame = h3EncodeFrame(H3_DATA(), payload)
    val fullLen = stringLength(fullFrame)
    // Take only half the frame -- should be incomplete
    val halfLen = fullLen / 2
    val partialBuf = substring(fullFrame, 0, halfLen)
    val checkPartial = h3DecodeFrameCheck(partialBuf, 0)
    assertTrue(h3ToBool(mapGet(checkPartial, "complete")) == false)
    // Full frame should be complete
    val checkFull = h3DecodeFrameCheck(fullFrame, 0)
    assertTrue(h3ToBool(mapGet(checkFull, "complete")))
}

// == Graceful Shutdown Improvements ===========================================

@Test fun testH3GracefulCloseReturnStructure() {
    // h3GracefulClose now returns a map with observability fields
    // Test with null QUIC connection
    val conn = mapCreate()
    mapPut(conn, "quic", null)
    val result = h3GracefulClose(conn, 5)
    assertTrue(mapContains(result, "initialGoaway"))
    assertTrue(mapContains(result, "finalGoaway"))
    assertTrue(mapContains(result, "drainedIterations"))
}

@Test fun testH3GracefulCloseNullQuic() {
    val conn = mapCreate()
    mapPut(conn, "quic", null)
    val result = h3GracefulClose(conn, 5)
    assertEquals(0, toInt(mapGet(result, "initialGoaway")))
    assertEquals(0, toInt(mapGet(result, "finalGoaway")))
    assertEquals(0, toInt(mapGet(result, "drainedIterations")))
}

@Test fun testH3GracefulCloseMaxStreamId() {
    // RFC 9114 Section 5.2: initial GOAWAY uses maximum stream ID
    // 1073741823 = 2^30 - 1 (max QUIC varint in 4 bytes)
    val maxStreamId = 1073741823
    val goaway = h3EncodeGoaway(maxStreamId)
    val frameResult = h3DecodeFrame(goaway, 0)
    val decodedId = h3DecodeGoaway(toString(mapGet(frameResult, "payload")))
    assertEquals(maxStreamId, decodedId)
}

@Test fun testH3GracefulCloseTwoPhaseGoaway() {
    // Verify that the two-phase GOAWAY pattern is correct:
    // Initial GOAWAY has maxStreamId, final GOAWAY has actual last processed
    val initialId = 1073741823
    val finalId = 4
    val initialGoaway = h3EncodeGoaway(initialId)
    val finalGoaway = h3EncodeGoaway(finalId)
    // Decode initial
    val r1 = h3DecodeFrame(initialGoaway, 0)
    assertEquals(H3_GOAWAY(), toInt(mapGet(r1, "type")))
    val decoded1 = h3DecodeGoaway(toString(mapGet(r1, "payload")))
    assertEquals(initialId, decoded1)
    // Decode final
    val r2 = h3DecodeFrame(finalGoaway, 0)
    assertEquals(H3_GOAWAY(), toInt(mapGet(r2, "type")))
    val decoded2 = h3DecodeGoaway(toString(mapGet(r2, "payload")))
    assertEquals(finalId, decoded2)
    // Final must be <= initial
    assertTrue(decoded2 <= decoded1)
}

@Test fun testH3ShuttingDownFlagSetOnGracefulClose() {
    // Verify the shuttingDown flag behavior
    val conn = mapCreate()
    mapPut(conn, "shuttingDown", false)
    assertTrue(h3ToBool(mapGet(conn, "shuttingDown")) == false)
    mapPut(conn, "shuttingDown", true)
    assertTrue(h3ToBool(mapGet(conn, "shuttingDown")))
}

// =============================================================================
// == Gap 1: Frame Sequence Validation on Request Streams (RFC 9114 Section 4.1)
// =============================================================================

@Test fun testGap1_FrameSequenceValidHeadersDataHeaders() {
    // Valid sequence: HEADERS, DATA, HEADERS (trailers)
    // The frame type constants are validated by encoding/decoding
    val headersFrame = h3EncodeFrame(H3_HEADERS(), "hdr")
    val dataFrame = h3EncodeFrame(H3_DATA(), "body")
    val trailersFrame = h3EncodeFrame(H3_HEADERS(), "trail")
    // Verify all three frame types decode correctly
    val r1 = h3DecodeFrame(headersFrame, 0)
    assertEquals(H3_HEADERS(), toInt(mapGet(r1, "type")))
    val r2 = h3DecodeFrame(dataFrame, 0)
    assertEquals(H3_DATA(), toInt(mapGet(r2, "type")))
    val r3 = h3DecodeFrame(trailersFrame, 0)
    assertEquals(H3_HEADERS(), toInt(mapGet(r3, "type")))
}

@Test fun testGap1_DataBeforeHeadersIsError() {
    // DATA before HEADERS should cause H3_FRAME_UNEXPECTED.
    // We test this by verifying h3IsH2OnlyFrameType does NOT match DATA (type 0),
    // and that DATA type 0 is distinct from HEADERS type 1.
    // The sequence validation itself is in h3ReadResponse.
    assertEquals(0, H3_DATA())
    assertEquals(1, H3_HEADERS())
    assertTrue(H3_DATA() != H3_HEADERS())
    // Frame type 0 (DATA) is not an H2-only type
    assertTrue(h3IsH2OnlyFrameType(H3_DATA()) == false)
}

@Test fun testGap1_FrameSequenceStateConstants() {
    // State 0 = awaiting initial HEADERS
    // State 1 = HEADERS received, expecting DATA or trailing HEADERS
    // State 2 = trailing HEADERS received, no more frames allowed
    // Verify H3_FRAME_UNEXPECTED error code is used for violations
    assertEquals(261, H3_FRAME_UNEXPECTED())
}

