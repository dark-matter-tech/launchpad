// == Gap 9: Header Field Name Case Validation (RFC 9114 Section 4.2)
// =============================================================================

@Test fun testGap9_ValidateLowercaseHeaderName() {
    assertTrue(h3ValidateHeaderName("content-type"))
    assertTrue(h3ValidateHeaderName("x-custom-header"))
    assertTrue(h3ValidateHeaderName("accept"))
    assertTrue(h3ValidateHeaderName(":status"))
}

@Test fun testGap9_RejectUppercaseHeaderName() {
    assertTrue(h3ValidateHeaderName("Content-Type") == false)
    assertTrue(h3ValidateHeaderName("X-Custom") == false)
    assertTrue(h3ValidateHeaderName("Accept") == false)
}

@Test fun testGap9_ValidateEmptyHeaderName() {
    assertTrue(h3ValidateHeaderName(""))
}

@Test fun testGap9_LowercaseHeaderName() {
    assertEqualsStr("content-type", h3LowercaseHeaderName("Content-Type"))
    assertEqualsStr("accept", h3LowercaseHeaderName("ACCEPT"))
    assertEqualsStr("x-custom", h3LowercaseHeaderName("x-custom"))
}

@Test fun testGap9_InboundUppercaseRejected() {
    // Uppercase header in inbound response headers triggers validation failure
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":status")
    mapPut(h1, "value", "200")
    listAppend(headers, h1)
    val h2 = mapCreate()
    mapPut(h2, "name", "Content-Type")  // Uppercase C and T
    mapPut(h2, "value", "text/plain")
    listAppend(headers, h2)
    val result = h3ValidateResponseHeaders(headers)
    assertTrue(h3ToBool(mapGet(result, "valid")) == false)
    assertEqualsStr("Uppercase character in header field name", toString(mapGet(result, "error")))
}

@Test fun testGap9_OutboundAutoLowercase() {
    // Outbound request header validation auto-lowercases names
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", "Content-Type")
    mapPut(h1, "value", "application/json")
    listAppend(headers, h1)
    val result = h3ValidateRequestHeaders(headers)
    assertTrue(h3ToBool(mapGet(result, "valid")))
    val sanitized = mapGet(result, "headers")
    assertEquals(1, listSize(sanitized))
    assertEqualsStr("content-type", toString(mapGet(listGet(sanitized, 0), "name")))
}

