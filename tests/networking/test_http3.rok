// Tests for rockit.networking.http3
import rockit.encoding.hpack
import rockit.encoding.qpack
import rockit.encoding.base64
import rockit.networking.http3
import rockit.networking.quic
import rockit.networking.url
import rockit.testing.probe

// == Frame Type Constants (RFC 9114 Section 7.2) ==============================

@Test fun testH3FrameTypeConstants() {
    assertEquals(0, H3_DATA())
    assertEquals(1, H3_HEADERS())
    assertEquals(3, H3_CANCEL_PUSH())
    assertEquals(4, H3_SETTINGS())
    assertEquals(5, H3_PUSH_PROMISE())
    assertEquals(7, H3_GOAWAY())
    assertEquals(13, H3_MAX_PUSH_ID())
}

// == HTTP/2-Only Frame Type Constants (RFC 9114 Section 7.2.8, Gap 2) =========

@Test fun testH3H2OnlyFrameTypeConstants() {
    assertEquals(2, H3_H2_PRIORITY())
    assertEquals(6, H3_H2_PING())
    // Gap A: WINDOW_UPDATE is frame type 8, CONTINUATION is frame type 9
    assertEquals(8, H3_H2_WINDOW_UPDATE())
    assertEquals(9, H3_H2_CONTINUATION())
}

// == Error Code Constants (RFC 9114 Section 8.1) ==============================

@Test fun testH3ErrorCodeNoError() {
    // H3_NO_ERROR = 0x0100 = 256
    assertEquals(256, H3_NO_ERROR())
}

@Test fun testH3ErrorCodeGeneralProtocol() {
    assertEquals(257, H3_GENERAL_PROTOCOL_ERROR())
}

@Test fun testH3ErrorCodeInternalError() {
    assertEquals(258, H3_INTERNAL_ERROR())
}

@Test fun testH3ErrorCodeStreamCreation() {
    assertEquals(259, H3_STREAM_CREATION_ERROR())
}

@Test fun testH3ErrorCodeClosedCritical() {
    assertEquals(260, H3_CLOSED_CRITICAL_STREAM())
}

@Test fun testH3ErrorCodeFrameUnexpected() {
    assertEquals(261, H3_FRAME_UNEXPECTED())
}

@Test fun testH3ErrorCodeFrameError() {
    assertEquals(262, H3_FRAME_ERROR())
}

@Test fun testH3ErrorCodeExcessiveLoad() {
    assertEquals(263, H3_EXCESSIVE_LOAD())
}

@Test fun testH3ErrorCodeIdError() {
    assertEquals(264, H3_ID_ERROR())
}

@Test fun testH3ErrorCodeSettingsError() {
    assertEquals(265, H3_SETTINGS_ERROR())
}

@Test fun testH3ErrorCodeMissingSettings() {
    assertEquals(266, H3_MISSING_SETTINGS())
}

@Test fun testH3ErrorCodeRequestRejected() {
    assertEquals(267, H3_REQUEST_REJECTED())
}

@Test fun testH3ErrorCodeRequestCancelled() {
    assertEquals(268, H3_REQUEST_CANCELLED())
}

@Test fun testH3ErrorCodeRequestIncomplete() {
    assertEquals(269, H3_REQUEST_INCOMPLETE())
}

@Test fun testH3ErrorCodeMessageError() {
    assertEquals(270, H3_MESSAGE_ERROR())
}

@Test fun testH3ErrorCodeConnectError() {
    assertEquals(271, H3_CONNECT_ERROR())
}

@Test fun testH3ErrorCodeVersionFallback() {
    // H3_VERSION_FALLBACK = 0x0110 = 272
    assertEquals(272, H3_VERSION_FALLBACK())
}

@Test fun testH3ErrorCodeRange() {
    // All 17 error codes should be in range 0x0100 to 0x0110
    assertGreaterThanOrEqual(H3_NO_ERROR(), 256)
    assertLessThanOrEqual(H3_VERSION_FALLBACK(), 272)
    // Verify consecutive values
    assertEquals(H3_NO_ERROR() + 1, H3_GENERAL_PROTOCOL_ERROR())
    assertEquals(H3_GENERAL_PROTOCOL_ERROR() + 1, H3_INTERNAL_ERROR())
    assertEquals(H3_VERSION_FALLBACK() - 1, H3_CONNECT_ERROR())
}

// == Settings Constants (RFC 9114 Section 7.2.4.1) ============================

@Test fun testH3SettingsConstants() {
    assertEquals(1, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY())
    assertEquals(6, H3_SETTINGS_MAX_FIELD_SECTION_SIZE())
    assertEquals(7, H3_SETTINGS_QPACK_BLOCKED_STREAMS())
}

// == Stream Type Constants (RFC 9114 Section 6.2) =============================

@Test fun testH3StreamTypeConstants() {
    assertEquals(0, H3_STREAM_CONTROL())
    assertEquals(1, H3_STREAM_PUSH())
    assertEquals(2, H3_STREAM_QPACK_ENCODER())
    assertEquals(3, H3_STREAM_QPACK_DECODER())
}

// == Error Handling ===========================================================

@Test fun testH3Error() {
    val err = h3Error("test error")
    assertTrue(h3IsError(err))
    assertEqualsStr("test error", toString(mapGet(err, "error")))
    assertEquals(0, h3Status(err))
    assertEqualsStr("", h3Body(err))
}

@Test fun testH3ErrorConstant() {
    assertEqualsStr("H3_ERROR", H3_ERROR())
}

@Test fun testH3ErrorWithCode() {
    val err = h3ErrorWithCode("settings error", H3_SETTINGS_ERROR())
    assertTrue(h3IsError(err))
    assertEqualsStr("settings error", toString(mapGet(err, "error")))
    assertEquals(H3_SETTINGS_ERROR(), toInt(mapGet(err, "errorCode")))
}

// == Frame Encoding/Decoding ==================================================

@Test fun testH3EncodeDataFrame() {
    val frame = h3EncodeFrame(H3_DATA(), "hello")
    // Type: varint(0) = 1 byte, Length: varint(5) = 1 byte, Payload: 5 bytes
    assertEquals(7, stringLength(frame))
    // Type byte = 0
    assertEquals(0, charCodeAt(frame, 0))
    // Length byte = 5
    assertEquals(5, charCodeAt(frame, 1))
    // Payload starts at offset 2
    assertEquals(104, charCodeAt(frame, 2))  // 'h'
}

@Test fun testH3EncodeHeadersFrame() {
    val frame = h3EncodeFrame(H3_HEADERS(), "hdrx")
    assertEquals(6, stringLength(frame))
    assertEquals(1, charCodeAt(frame, 0))  // Type = 1 (HEADERS)
    assertEquals(4, charCodeAt(frame, 1))  // Length = 4
}

@Test fun testH3EncodeSettingsFrame() {
    val frame = h3EncodeFrame(H3_SETTINGS(), "")
    assertEquals(2, stringLength(frame))
    assertEquals(4, charCodeAt(frame, 0))  // Type = 4 (SETTINGS)
    assertEquals(0, charCodeAt(frame, 1))  // Length = 0 (empty payload)
}

@Test fun testH3EncodeGoawayFrame() {
    val frame = h3EncodeFrame(H3_GOAWAY(), intToChar(0))
    assertEquals(3, stringLength(frame))
    assertEquals(7, charCodeAt(frame, 0))  // Type = 7 (GOAWAY)
    assertEquals(1, charCodeAt(frame, 1))  // Length = 1
}

@Test fun testH3EncodeCancelPushFrame() {
    val payload = quicEncodeVarint(42)
    val frame = h3EncodeFrame(H3_CANCEL_PUSH(), payload)
    assertEquals(3, charCodeAt(frame, 0))  // Type = 3 (CANCEL_PUSH)
}

@Test fun testH3EncodePushPromiseFrame() {
    val frame = h3EncodeFrame(H3_PUSH_PROMISE(), "test")
    assertEquals(5, charCodeAt(frame, 0))  // Type = 5 (PUSH_PROMISE)
    assertEquals(4, charCodeAt(frame, 1))  // Length = 4
}

@Test fun testH3EncodeMaxPushIdFrame() {
    val payload = quicEncodeVarint(10)
    val frame = h3EncodeFrame(H3_MAX_PUSH_ID(), payload)
    assertEquals(13, charCodeAt(frame, 0))  // Type = 13 (MAX_PUSH_ID)
}

@Test fun testH3DecodeDataFrame() {
    val frame = h3EncodeFrame(H3_DATA(), "hello")
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_DATA(), toInt(mapGet(result, "type")))
    assertEquals(5, toInt(mapGet(result, "length")))
    assertEqualsStr("hello", toString(mapGet(result, "payload")))
    assertEquals(7, toInt(mapGet(result, "bytesRead")))
}

@Test fun testH3DecodeHeadersFrame() {
    val frame = h3EncodeFrame(H3_HEADERS(), "hdrdata")
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_HEADERS(), toInt(mapGet(result, "type")))
    assertEquals(7, toInt(mapGet(result, "length")))
    assertEqualsStr("hdrdata", toString(mapGet(result, "payload")))
}

@Test fun testH3DecodeEmptyPayload() {
    val frame = h3EncodeFrame(H3_SETTINGS(), "")
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(result, "type")))
    assertEquals(0, toInt(mapGet(result, "length")))
    assertEqualsStr("", toString(mapGet(result, "payload")))
    assertEquals(2, toInt(mapGet(result, "bytesRead")))
}

@Test fun testH3DecodeFrameAtOffset() {
    // Put padding before the frame
    var buf: String = intToChar(0)
    buf = stringConcat(buf, intToChar(0))
    buf = stringConcat(buf, h3EncodeFrame(H3_DATA(), "test"))
    val result = h3DecodeFrame(buf, 2)
    assertEquals(H3_DATA(), toInt(mapGet(result, "type")))
    assertEqualsStr("test", toString(mapGet(result, "payload")))
}

@Test fun testH3DecodeFromEmpty() {
    val result = h3DecodeFrame("", 0)
    assertEquals(0 - 1, toInt(mapGet(result, "type")))
    assertEquals(0, toInt(mapGet(result, "bytesRead")))
}

// == Frame Roundtrip Tests ====================================================

@Test fun testH3FrameRoundtripData() {
    val payload = "Hello, HTTP/3!"
    val frame = h3EncodeFrame(H3_DATA(), payload)
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_DATA(), toInt(mapGet(result, "type")))
    assertEqualsStr(payload, toString(mapGet(result, "payload")))
}

@Test fun testH3FrameRoundtripHeaders() {
    val payload = "encoded-headers"
    val frame = h3EncodeFrame(H3_HEADERS(), payload)
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_HEADERS(), toInt(mapGet(result, "type")))
    assertEqualsStr(payload, toString(mapGet(result, "payload")))
}

@Test fun testH3FrameRoundtripSettings() {
    val frame = h3EncodeFrame(H3_SETTINGS(), "")
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(result, "type")))
    assertEquals(0, toInt(mapGet(result, "length")))
}

@Test fun testH3FrameRoundtripGoaway() {
    val payload = quicEncodeVarint(100)
    val frame = h3EncodeFrame(H3_GOAWAY(), payload)
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_GOAWAY(), toInt(mapGet(result, "type")))
    // Decode the stream ID from the payload
    val goawayPayload = toString(mapGet(result, "payload"))
    val streamResult = quicDecodeVarint(goawayPayload, 0)
    assertEquals(100, toInt(mapGet(streamResult, "value")))
}

@Test fun testH3FrameRoundtripCancelPush() {
    val pushIdPayload = quicEncodeVarint(7)
    val frame = h3EncodeFrame(H3_CANCEL_PUSH(), pushIdPayload)
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_CANCEL_PUSH(), toInt(mapGet(result, "type")))
    val decoded = quicDecodeVarint(toString(mapGet(result, "payload")), 0)
    assertEquals(7, toInt(mapGet(decoded, "value")))
}

@Test fun testH3FrameRoundtripPushPromise() {
    val frame = h3EncodeFrame(H3_PUSH_PROMISE(), "promise-data")
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_PUSH_PROMISE(), toInt(mapGet(result, "type")))
    assertEqualsStr("promise-data", toString(mapGet(result, "payload")))
}

@Test fun testH3FrameRoundtripMaxPushId() {
    val pushIdPayload = quicEncodeVarint(255)
    val frame = h3EncodeFrame(H3_MAX_PUSH_ID(), pushIdPayload)
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_MAX_PUSH_ID(), toInt(mapGet(result, "type")))
    val decoded = quicDecodeVarint(toString(mapGet(result, "payload")), 0)
    assertEquals(255, toInt(mapGet(decoded, "value")))
}

// == Multiple Frames in Sequence ==============================================

@Test fun testH3MultipleFramesDecode() {
    // Encode two frames in sequence
    val frame1 = h3EncodeFrame(H3_HEADERS(), "hdr")
    val frame2 = h3EncodeFrame(H3_DATA(), "body")
    var buf: String = frame1
    buf = stringConcat(buf, frame2)
    // Decode first frame
    val r1 = h3DecodeFrame(buf, 0)
    assertEquals(H3_HEADERS(), toInt(mapGet(r1, "type")))
    assertEqualsStr("hdr", toString(mapGet(r1, "payload")))
    val bytesRead1 = toInt(mapGet(r1, "bytesRead"))
    // Decode second frame
    val r2 = h3DecodeFrame(buf, bytesRead1)
    assertEquals(H3_DATA(), toInt(mapGet(r2, "type")))
    assertEqualsStr("body", toString(mapGet(r2, "payload")))
}

// == Settings Frame Encoding/Decoding =========================================

@Test fun testH3EncodeDecodeSettings() {
    val params = listCreate()
    val p1 = mapCreate()
    mapPut(p1, "id", H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY())
    mapPut(p1, "value", 4096)
    listAppend(params, p1)
    val p2 = mapCreate()
    mapPut(p2, "id", H3_SETTINGS_QPACK_BLOCKED_STREAMS())
    mapPut(p2, "value", 100)
    listAppend(params, p2)
    val frame = h3EncodeSettings(params)
    // Decode the frame
    val frameResult = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(frameResult, "type")))
    // Decode settings payload using new API
    val payload = toString(mapGet(frameResult, "payload"))
    val settingsResult = h3DecodeSettings(payload)
    assertEqualsStr("H3_SETTINGS_LIST", toString(mapGet(settingsResult, "type")))
    val decoded = mapGet(settingsResult, "params")
    assertEquals(2, listSize(decoded))
    val d1 = listGet(decoded, 0)
    assertEquals(H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY(), toInt(mapGet(d1, "id")))
    assertEquals(4096, toInt(mapGet(d1, "value")))
    val d2 = listGet(decoded, 1)
    assertEquals(H3_SETTINGS_QPACK_BLOCKED_STREAMS(), toInt(mapGet(d2, "id")))
    assertEquals(100, toInt(mapGet(d2, "value")))
}

@Test fun testH3EncodeDecodeEmptySettings() {
    val frame = h3EncodeSettings(listCreate())
    val frameResult = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(frameResult, "type")))
    val settingsResult = h3DecodeSettings(toString(mapGet(frameResult, "payload")))
    val decoded = mapGet(settingsResult, "params")
    assertEquals(0, listSize(decoded))
}

@Test fun testH3BuildClientSettings() {
    val frame = h3BuildClientSettings()
    val frameResult = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(frameResult, "type")))
    val settingsResult = h3DecodeSettings(toString(mapGet(frameResult, "payload")))
    val decoded = mapGet(settingsResult, "params")
    assertEquals(2, listSize(decoded))
}

