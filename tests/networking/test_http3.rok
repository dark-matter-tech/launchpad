    val usedIds = mapGet(conn, "usedPushIds")
    assertEquals(1, listSize(usedIds))
    assertTrue(listContains(usedIds, 5))
}

// =============================================================================
// == Gap 16: Request Stream ID Tracking (RFC 9114 Section 5.2)
// =============================================================================

@Test fun testGap16_NextRequestStreamIdInitialized() {
    // Connection should start with nextRequestStreamId = 0
    val conn = mapCreate()
    mapPut(conn, "nextRequestStreamId", 0)
    assertEquals(0, toInt(mapGet(conn, "nextRequestStreamId")))
}

@Test fun testGap16_NextRequestStreamIdIncrement() {
    // QUIC bidirectional client-initiated streams increment by 4
    val conn = mapCreate()
    mapPut(conn, "nextRequestStreamId", 0)
    // Simulate: after opening stream 0, next should be 4
    val streamId = 0
    mapPut(conn, "nextRequestStreamId", streamId + 4)
    assertEquals(4, toInt(mapGet(conn, "nextRequestStreamId")))
    // After opening stream 4, next should be 8
    val streamId2 = 4
    mapPut(conn, "nextRequestStreamId", streamId2 + 4)
    assertEquals(8, toInt(mapGet(conn, "nextRequestStreamId")))
}

// =============================================================================
// == Gap 17: Connection Close with HTTP/3 Error Code (RFC 9114 Section 8.1)
// =============================================================================

@Test fun testGap17_CloseWithErrorFunction() {
    // Verify h3CloseWithError exists and handles null quic gracefully
    val conn = mapCreate()
    mapPut(conn, "quic", null)
    mapPut(conn, "controlStreamId", 0)
    mapPut(conn, "nextRequestStreamId", 0)
    // Should not crash with null quic
    h3CloseWithError(conn, H3_SETTINGS_ERROR(), "test error")
    // Verify the function can be called without error
    assertTrue(true)
}

@Test fun testGap17_ErrorCodesForCloseWithError() {
    // Verify the error codes that would be used with h3CloseWithError
    assertEquals(261, H3_FRAME_UNEXPECTED())
    assertEquals(265, H3_SETTINGS_ERROR())
    assertEquals(266, H3_MISSING_SETTINGS())
    assertEquals(264, H3_ID_ERROR())
    assertEquals(259, H3_STREAM_CREATION_ERROR())
    assertEquals(260, H3_CLOSED_CRITICAL_STREAM())
}

@Test fun testGap17_GoawayIncludedInClose() {
    // h3CloseWithError should send GOAWAY with nextRequestStreamId
    val conn = mapCreate()
    mapPut(conn, "nextRequestStreamId", 8)
    // Verify the GOAWAY would use the correct stream ID
    val goaway = h3EncodeGoaway(8)
    val frame = h3DecodeFrame(goaway, 0)
    assertEquals(H3_GOAWAY(), toInt(mapGet(frame, "type")))
    val goawayId = h3DecodeGoaway(toString(mapGet(frame, "payload")))
    assertEquals(8, goawayId)
}

// =============================================================================
// == Gap 18: Control Stream Closure Active Detection (RFC 9114 Section 6.2.1)
// =============================================================================

@Test fun testGap18_ClosedCriticalStreamErrorCode() {
    assertEquals(260, H3_CLOSED_CRITICAL_STREAM())
}

@Test fun testGap18_ControlStreamClosureHandling() {
    // The h3ReadControlStreamFrame detects control stream closure via FIN
    // and returns H3_CLOSED_CRITICAL_STREAM.
    // Since quicRecvStream stub returns fin=true, we verify the mechanism.
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 10)
    mapPut(conn, "peerSettingsReceived", false)
    val quicConn = mapCreate()
    // The stub quicRecvStream returns fin=true for any stream
    val result = h3ReadControlStreamFrame(conn, quicConn)
    assertTrue(h3ToBool(mapGet(result, "ok")) == false)
    assertEquals(H3_CLOSED_CRITICAL_STREAM(), toInt(mapGet(result, "errorCode")))
}

@Test fun testGap18_ProcessPeerStreamsDetectsControlClosure() {
    // When peer control stream exists and returns FIN,
    // h3ProcessPeerStreams should report H3_CLOSED_CRITICAL_STREAM
    val conn = mapCreate()
    mapPut(conn, "peerControlStreamId", 10)
    mapPut(conn, "peerEncoderStreamId", 0 - 1)
    mapPut(conn, "peerDecoderStreamId", 0 - 1)
    mapPut(conn, "peerSettingsReceived", true)
    val quicConn = mapCreate()
    // quicRecvStream stub returns fin=true, so control stream appears closed
    val result = h3ProcessPeerStreams(conn, quicConn)
    assertTrue(h3ToBool(mapGet(result, "ok")) == false)
    assertEquals(H3_CLOSED_CRITICAL_STREAM(), toInt(mapGet(result, "errorCode")))
}

// =============================================================================
// == Cross-Gap Integration Tests
// =============================================================================

@Test fun testIntegration_SettingsValidationChain() {
    // Test the full chain: encode -> decode (with H2 rejection) -> apply
    val params = listCreate()
    val p1 = mapCreate()
    mapPut(p1, "id", H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY())
    mapPut(p1, "value", 4096)
    listAppend(params, p1)
    val frame = h3EncodeSettings(params)
    val frameResult = h3DecodeFrame(frame, 0)
    val payload = toString(mapGet(frameResult, "payload"))
    val settingsResult = h3DecodeSettings(payload)
    assertEqualsStr("H3_SETTINGS_LIST", toString(mapGet(settingsResult, "type")))
    val settingsList = mapGet(settingsResult, "params")
    // Apply to connection
    val conn = mapCreate()
    val peerSettings = mapCreate()
    mapPut(peerSettings, "maxFieldSectionSize", 0)
    mapPut(peerSettings, "qpackMaxTableCapacity", 0)
    mapPut(peerSettings, "qpackBlockedStreams", 0)
    mapPut(conn, "peerSettings", peerSettings)
    val applyResult = h3ApplyPeerSettings(conn, settingsList)
    assertTrue(h3ToBool(mapGet(applyResult, "ok")))
    assertEquals(4096, toInt(mapGet(peerSettings, "qpackMaxTableCapacity")))
}

@Test fun testIntegration_HeaderValidationFullPipeline() {
    // Full validation of request headers: auto-lowercase + connection-specific check
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", "Accept")
    mapPut(h1, "value", "text/html")
    listAppend(headers, h1)
    val h2 = mapCreate()
    mapPut(h2, "name", "x-request-id")
    mapPut(h2, "value", "abc123")
    listAppend(headers, h2)
    val result = h3ValidateRequestHeaders(headers)
    assertTrue(h3ToBool(mapGet(result, "valid")))
    val sanitized = mapGet(result, "headers")
    assertEquals(2, listSize(sanitized))
    // "Accept" should be lowercased to "accept"
    assertEqualsStr("accept", toString(mapGet(listGet(sanitized, 0), "name")))
    assertEqualsStr("text/html", toString(mapGet(listGet(sanitized, 0), "value")))
    // "x-request-id" is already lowercase
    assertEqualsStr("x-request-id", toString(mapGet(listGet(sanitized, 1), "name")))
}

@Test fun testIntegration_GoawayMonotonicChain() {
    // Simulate receiving multiple GOAWAYs: 100 -> 50 -> 10 (valid)
    val conn = mapCreate()
    mapPut(conn, "peerGoawayStreamId", 0 - 1)
    // First GOAWAY (no previous, always valid)
    val r1 = h3ValidateGoawayId(conn, 100)
    assertTrue(h3ToBool(mapGet(r1, "valid")))
    mapPut(conn, "peerGoawayStreamId", 100)
    // Second GOAWAY (decreasing, valid)
    val r2 = h3ValidateGoawayId(conn, 50)
    assertTrue(h3ToBool(mapGet(r2, "valid")))
    mapPut(conn, "peerGoawayStreamId", 50)
    // Third GOAWAY (decreasing to 10, valid)
    val r3 = h3ValidateGoawayId(conn, 10)
    assertTrue(h3ToBool(mapGet(r3, "valid")))
    mapPut(conn, "peerGoawayStreamId", 10)
    // Fourth GOAWAY (increasing, INVALID)
    val r4 = h3ValidateGoawayId(conn, 20)
    assertTrue(h3ToBool(mapGet(r4, "valid")) == false)
}

@Test fun testIntegration_PushIdLifecycle() {
    // Full push lifecycle: set MAX_PUSH_ID, validate, record, detect duplicate
    val conn = mapCreate()
    mapPut(conn, "maxPushIdSent", true)
    mapPut(conn, "maxPushIdValue", 5)
    mapPut(conn, "usedPushIds", listCreate())
    // Validate push ID 0 (valid)
    val r1 = h3ValidatePushPromise(conn, 0)
    assertTrue(h3ToBool(mapGet(r1, "valid")))
    h3RecordPushId(conn, 0)
    // Validate push ID 3 (valid)
    val r2 = h3ValidatePushPromise(conn, 3)
    assertTrue(h3ToBool(mapGet(r2, "valid")))
    h3RecordPushId(conn, 3)
    // Validate push ID 0 again (duplicate)
    val r3 = h3ValidatePushPromise(conn, 0)
    assertTrue(h3ToBool(mapGet(r3, "valid")) == false)
    // Validate push ID 6 (exceeds MAX_PUSH_ID of 5)
    val r4 = h3ValidatePushPromise(conn, 6)
    assertTrue(h3ToBool(mapGet(r4, "valid")) == false)
}

@Test fun testIntegration_FrameTypeGates() {
    // Verify all frame types are categorized correctly
    // H2-only frame types (must be rejected everywhere)
    assertTrue(h3IsH2OnlyFrameType(2))   // PRIORITY
    assertTrue(h3IsH2OnlyFrameType(6))   // PING
    assertTrue(h3IsH2OnlyFrameType(8))   // WINDOW_UPDATE
    assertTrue(h3IsH2OnlyFrameType(9))   // CONTINUATION
    // Control-stream-only (must be rejected on request streams)
    assertTrue(h3IsControlStreamOnlyFrame(4))   // SETTINGS
    assertTrue(h3IsControlStreamOnlyFrame(7))   // GOAWAY
    assertTrue(h3IsControlStreamOnlyFrame(13))  // MAX_PUSH_ID
    assertTrue(h3IsControlStreamOnlyFrame(3))   // CANCEL_PUSH
    // Request-stream-valid types
    assertTrue(h3IsControlStreamOnlyFrame(0) == false)   // DATA
    assertTrue(h3IsControlStreamOnlyFrame(1) == false)   // HEADERS
    assertTrue(h3IsControlStreamOnlyFrame(5) == false)   // PUSH_PROMISE
    // None of the valid H3 types should be H2-only
    assertTrue(h3IsH2OnlyFrameType(0) == false)
    assertTrue(h3IsH2OnlyFrameType(1) == false)
    assertTrue(h3IsH2OnlyFrameType(3) == false)
    assertTrue(h3IsH2OnlyFrameType(4) == false)
    assertTrue(h3IsH2OnlyFrameType(5) == false)
    assertTrue(h3IsH2OnlyFrameType(7) == false)
    assertTrue(h3IsH2OnlyFrameType(13) == false)
}

// =============================================================================
// == Gap A: Corrected H2-Only Frame Constants (RFC 9114 Section 7.2.8)
// =============================================================================

@Test fun testGapA_WindowUpdateIs8() {
    // WINDOW_UPDATE is HTTP/2 frame type 0x08 = 8
    assertEquals(8, H3_H2_WINDOW_UPDATE())
}

@Test fun testGapA_ContinuationIs9() {
    // CONTINUATION is HTTP/2 frame type 0x09 = 9
    assertEquals(9, H3_H2_CONTINUATION())
}

@Test fun testGapA_AllFourH2OnlyTypes() {
    // All four HTTP/2-only frame types must be detected
    assertTrue(h3IsH2OnlyFrameType(2))   // PRIORITY
    assertTrue(h3IsH2OnlyFrameType(6))   // PING
    assertTrue(h3IsH2OnlyFrameType(8))   // WINDOW_UPDATE
    assertTrue(h3IsH2OnlyFrameType(9))   // CONTINUATION
    // Adjacent types must NOT be flagged
    assertTrue(h3IsH2OnlyFrameType(7) == false)   // GOAWAY (valid H3)
    assertTrue(h3IsH2OnlyFrameType(10) == false)  // not defined
}

// =============================================================================
// == Gap C: Settings ID 0x00 Rejection (RFC 9114 Section 7.2.4.1)
// =============================================================================

@Test fun testGapC_SettingsId0IsH2Only() {
    // Settings ID 0x00 is defined in HTTP/2 as HEADER_TABLE_SIZE
    // and MUST be rejected in HTTP/3
    assertTrue(h3IsH2OnlySettingsId(0))
}

@Test fun testGapC_DecodeSettingsRejectsId0() {
    // Build SETTINGS payload with settings ID 0x00
    var payload: String = quicEncodeVarint(0)   // ID = 0x00
    payload = stringConcat(payload, quicEncodeVarint(4096))  // value
    val result = h3DecodeSettings(payload)
    assertEqualsStr(H3_ERROR(), toString(mapGet(result, "type")))
    assertEquals(H3_SETTINGS_ERROR(), toInt(mapGet(result, "errorCode")))
}

// =============================================================================
// == Gap E: CONNECT Pseudo-Headers (RFC 9114 Section 4.4)
// =============================================================================

@Test fun testGapE_ConnectPseudoHeaders() {
    // For CONNECT, only :method and :authority should be present
    // Build pseudo-headers as h3Request would for CONNECT
    val allHeaders = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":method")
    mapPut(h1, "value", "CONNECT")
    listAppend(allHeaders, h1)
    val hAuth = mapCreate()
    mapPut(hAuth, "name", ":authority")
    mapPut(hAuth, "value", "proxy.example.com:443")
    listAppend(allHeaders, hAuth)
    // Verify only 2 pseudo-headers for CONNECT
    assertEquals(2, listSize(allHeaders))
    assertEqualsStr(":method", toString(mapGet(listGet(allHeaders, 0), "name")))
    assertEqualsStr("CONNECT", toString(mapGet(listGet(allHeaders, 0), "value")))
    assertEqualsStr(":authority", toString(mapGet(listGet(allHeaders, 1), "name")))
}

@Test fun testGapE_NonConnectPseudoHeaders() {
    // For non-CONNECT, all four pseudo-headers should be present
    val allHeaders = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":method")
    mapPut(h1, "value", "GET")
    listAppend(allHeaders, h1)
    val h2m = mapCreate()
    mapPut(h2m, "name", ":scheme")
    mapPut(h2m, "value", "https")
    listAppend(allHeaders, h2m)
    val hAuth = mapCreate()
    mapPut(hAuth, "name", ":authority")
    mapPut(hAuth, "value", "example.com")
    listAppend(allHeaders, hAuth)
    val h4 = mapCreate()
    mapPut(h4, "name", ":path")
    mapPut(h4, "value", "/")
    listAppend(allHeaders, h4)
    // Verify 4 pseudo-headers for GET
    assertEquals(4, listSize(allHeaders))
    assertEqualsStr(":scheme", toString(mapGet(listGet(allHeaders, 1), "name")))
    assertEqualsStr(":path", toString(mapGet(listGet(allHeaders, 3), "name")))
}

// =============================================================================
// == Gap F: Trailers Must Not Contain Pseudo-Headers (RFC 9114 Section 4.3)
// =============================================================================

@Test fun testGapF_TrailerPseudoHeaderDetection() {
    // Simulate trailer validation: pseudo-headers start with ':' (code 58)
    val trailers = listCreate()
    val t1 = mapCreate()
    mapPut(t1, "name", "grpc-status")
    mapPut(t1, "value", "0")
    listAppend(trailers, t1)
    // Check no pseudo-headers
    var hasPseudo: Bool = false
    var ti: Int = 0
    while (ti < listSize(trailers)) {
        val tHdr = listGet(trailers, ti)
        val tName = toString(mapGet(tHdr, "name"))
        if (stringLength(tName) > 0) {
            if (charCodeAt(tName, 0) == 58) {
                hasPseudo = true
            }
        }
        ti = ti + 1
    }
    assertTrue(hasPseudo == false)
}

@Test fun testGapF_TrailerWithPseudoHeaderRejected() {
    // A trailer containing :status should be rejected
    val trailers = listCreate()
    val t1 = mapCreate()
    mapPut(t1, "name", ":status")
    mapPut(t1, "value", "200")
    listAppend(trailers, t1)
    // Check pseudo-header presence
    var hasPseudo: Bool = false
    var ti: Int = 0
    while (ti < listSize(trailers)) {
        val tHdr = listGet(trailers, ti)
        val tName = toString(mapGet(tHdr, "name"))
        if (stringLength(tName) > 0) {
            if (charCodeAt(tName, 0) == 58) {
                hasPseudo = true
            }
        }
        ti = ti + 1
    }
    assertTrue(hasPseudo)
}

// =============================================================================
// == Gap G: SETTINGS Greasing (RFC 9114 Section 7.2.4.1)
// =============================================================================

@Test fun testGapG_ClientSettingsContainsGrease() {
    // h3BuildClientSettings should include a greasing setting (ID=33, value=0)
    val frame = h3BuildClientSettings()
    val frameResult = h3DecodeFrame(frame, 0)
    val payload = toString(mapGet(frameResult, "payload"))
    val settingsList = h3DecodeSettingsList(payload)
    // Should now have 3 settings: QPACK_MAX_TABLE_CAPACITY, QPACK_BLOCKED_STREAMS, grease
    assertEquals(3, listSize(settingsList))
    // Third setting should be the grease entry with ID 33
    val grease = listGet(settingsList, 2)
    assertEquals(33, toInt(mapGet(grease, "id")))
    assertEquals(0, toInt(mapGet(grease, "value")))
}

@Test fun testGapG_GreaseIdForm() {
    // Grease ID 33 = 0x1f * 0 + 0x21 — verify the formula
    val n: Int = 0
    val greaseId: Int = 31 * n + 33
    assertEquals(33, greaseId)
    // This should NOT be treated as H2-only
    assertTrue(h3IsH2OnlySettingsId(33) == false)
}
