// == Response Accessors =======================================================

@Test fun testH3ResponseAccessors() {
    val resp = mapCreate()
    mapPut(resp, "type", "H3_RESPONSE")
    mapPut(resp, "status", 200)
    mapPut(resp, "body", "response body")
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", "content-type")
    mapPut(h, "value", "text/plain")
    listAppend(headers, h)
    mapPut(resp, "headers", headers)
    assertEquals(200, h3Status(resp))
    assertEqualsStr("response body", h3Body(resp))
    val respHeaders = h3Headers(resp)
    assertEquals(1, listSize(respHeaders))
}

@Test fun testH3StatusError() {
    val err = h3Error("not found")
    assertEquals(0, h3Status(err))
    assertEqualsStr("", h3Body(err))
}

// == Trailer Accessor (Gap 6) =================================================

@Test fun testH3TrailersAccessorEmpty() {
    val resp = mapCreate()
    mapPut(resp, "trailers", listCreate())
    val trailers = h3Trailers(resp)
    assertEquals(0, listSize(trailers))
}

@Test fun testH3TrailersAccessorNull() {
    val resp = mapCreate()
    val trailers = h3Trailers(resp)
    assertEquals(0, listSize(trailers))
}

@Test fun testH3TrailersAccessorWithData() {
    val resp = mapCreate()
    val trailers = listCreate()
    val t1 = mapCreate()
    mapPut(t1, "name", "x-checksum")
    mapPut(t1, "value", "abc123")
    listAppend(trailers, t1)
    mapPut(resp, "trailers", trailers)
    val result = h3Trailers(resp)
    assertEquals(1, listSize(result))
    assertEqualsStr("x-checksum", toString(mapGet(listGet(result, 0), "name")))
}

// == Path Normalization =======================================================

@Test fun testH3NormalizePath() {
    assertEqualsStr("/", h3NormalizePath(""))
    assertEqualsStr("/api", h3NormalizePath("/api"))
    assertEqualsStr("/api", h3NormalizePath("api"))
    assertEqualsStr("/index.html", h3NormalizePath("/index.html"))
}

// == Varint-based Framing (vs HTTP/2 fixed-size) ==============================

@Test fun testH3FramingUsesVarints() {
    // HTTP/3 frame header size depends on type and length values
    // Small type (0) + small length (5) = 2 bytes header (vs HTTP/2's fixed 9)
    val smallFrame = h3EncodeFrame(0, "hello")
    assertEquals(7, stringLength(smallFrame))  // 2 header + 5 payload
    // Larger type (13 = MAX_PUSH_ID) still fits in 1-byte varint
    val largerType = h3EncodeFrame(13, "x")
    assertEquals(3, stringLength(largerType))  // 1 + 1 + 1
}

// == Integration: QPACK Encoded Headers in HTTP/3 Frame =======================

@Test fun testH3FrameWithQpackHeaders() {
    // Encode headers with QPACK, then wrap in HTTP/3 HEADERS frame
    val enc = qpackCreateEncoder(4096)
    val dec = qpackCreateDecoder(4096)
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":status")
    mapPut(h1, "value", "200")
    listAppend(headers, h1)
    val h2 = mapCreate()
    mapPut(h2, "name", "content-type")
    mapPut(h2, "value", "text/plain")
    listAppend(headers, h2)
    // QPACK encode
    val qpackResult = qpackEncode(enc, headers)
    val encodedHeaders = toString(mapGet(qpackResult, "encoded"))
    // Wrap in HEADERS frame
    val frame = h3EncodeFrame(H3_HEADERS(), encodedHeaders)
    // Decode frame
    val frameResult = h3DecodeFrame(frame, 0)
    assertEquals(H3_HEADERS(), toInt(mapGet(frameResult, "type")))
    // QPACK decode
    val headerPayload = toString(mapGet(frameResult, "payload"))
    val decResult = qpackDecode(dec, headerPayload, "")
    val decoded = mapGet(decResult, "headers")
    assertEquals(2, listSize(decoded))
    assertEqualsStr(":status", toString(mapGet(listGet(decoded, 0), "name")))
    assertEqualsStr("200", toString(mapGet(listGet(decoded, 0), "value")))
    assertEqualsStr("content-type", toString(mapGet(listGet(decoded, 1), "name")))
    assertEqualsStr("text/plain", toString(mapGet(listGet(decoded, 1), "value")))
}

// == RFC 9114 Wire-Level Validation ===========================================
// Byte-exact tests validating HTTP/3's varint-based framing format.

// SETTINGS with QPACK_MAX_TABLE_CAPACITY=4096
// Frame: varint(4) + varint(payloadLen) + varint(1) + varint(4096)
@Test fun testRfc9114_SettingsWireFormat() {
    val params = listCreate()
    val p = mapCreate()
    mapPut(p, "id", H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY())
    mapPut(p, "value", 4096)
    listAppend(params, p)
    val frame = h3EncodeSettings(params)
    // Decode frame header
    val frameResult = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(frameResult, "type")))
    // Verify first byte is frame type = 4 (single-byte varint)
    assertEquals(4, charCodeAt(frame, 0))
    // Decode payload and verify setting
    val payload = toString(mapGet(frameResult, "payload"))
    val settingsResult = h3DecodeSettings(payload)
    val decoded = mapGet(settingsResult, "params")
    assertEquals(1, listSize(decoded))
    assertEquals(H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY(), toInt(mapGet(listGet(decoded, 0), "id")))
    assertEquals(4096, toInt(mapGet(listGet(decoded, 0), "value")))
}

// DATA frame type is single byte 0x00, not multi-byte varint
@Test fun testRfc9114_DataFrameMinimal() {
    val frame = h3EncodeFrame(H3_DATA(), "x")
    // Type byte: DATA = 0x00 (single byte varint)
    assertEquals(0, charCodeAt(frame, 0))
    // Length byte: 1 (single byte varint)
    assertEquals(1, charCodeAt(frame, 1))
    // Total: 1 type + 1 length + 1 payload = 3 bytes
    assertEquals(3, stringLength(frame))
}

// GOAWAY stream ID is varint-encoded (unlike HTTP/2's fixed 4 bytes)
@Test fun testRfc9114_GoawayUsesVarint() {
    // Small stream ID: varint(0) = 1 byte
    val frame0 = h3EncodeGoaway(0)
    val result0 = h3DecodeFrame(frame0, 0)
    assertEquals(H3_GOAWAY(), toInt(mapGet(result0, "type")))
    val streamId0 = h3DecodeGoaway(toString(mapGet(result0, "payload")))
    assertEquals(0, streamId0)
    // Payload is 1 byte (single-byte varint for 0)
    assertEquals(1, toInt(mapGet(result0, "length")))

    // Larger stream ID: 16383 requires 2-byte varint (0x4000 prefix)
    val frame1 = h3EncodeGoaway(16383)
    val result1 = h3DecodeFrame(frame1, 0)
    val streamId1 = h3DecodeGoaway(toString(mapGet(result1, "payload")))
    assertEquals(16383, streamId1)
    // Payload is 2 bytes (two-byte varint for 16383)
    assertEquals(2, toInt(mapGet(result1, "length")))
}

// RFC 9114 Section 7.2.8: Frame types 0x02 (PRIORITY) and 0x06 (PING) are
// HTTP/2-only and MUST NOT be used in HTTP/3
@Test fun testRfc9114_NoH2OnlyFrameTypes() {
    // HTTP/3 frame types skip 0x02 and 0x06
    // DATA=0, HEADERS=1, CANCEL_PUSH=3, SETTINGS=4, PUSH_PROMISE=5, GOAWAY=7
    assertEquals(0, H3_DATA())
    assertEquals(1, H3_HEADERS())
    assertEquals(3, H3_CANCEL_PUSH())    // Not 2 (PRIORITY is H2-only)
    assertEquals(4, H3_SETTINGS())
    assertEquals(5, H3_PUSH_PROMISE())
    assertEquals(7, H3_GOAWAY())         // Not 6 (PING is H2-only)
    assertEquals(13, H3_MAX_PUSH_ID())
}

// RFC 9114 Section 7.2.4.1: HTTP/2 settings IDs 0x02-0x05 MUST NOT appear
// in HTTP/3 SETTINGS. Only QPACK_MAX_TABLE_CAPACITY(1), MAX_FIELD_SECTION_SIZE(6),
// QPACK_BLOCKED_STREAMS(7) are valid.
@Test fun testRfc9114_NoH2OnlySettings() {
    // Valid HTTP/3 settings IDs
    assertEquals(1, H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY())
    assertEquals(6, H3_SETTINGS_MAX_FIELD_SECTION_SIZE())
    assertEquals(7, H3_SETTINGS_QPACK_BLOCKED_STREAMS())
    // Verify none of these are in the H2-reserved range (2-5)
    assertTrue(H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY() < 2)
    assertTrue(H3_SETTINGS_MAX_FIELD_SECTION_SIZE() > 5)
    assertTrue(H3_SETTINGS_QPACK_BLOCKED_STREAMS() > 5)
}

// == Additional RFC 9114 Varint Frame Tests ====================================

// Two-byte varint frame type: type 64 requires 2-byte varint (0x40, 0x40)
@Test fun testRfc9114_LargeFrameType() {
    val payload = "x"
    val frame = h3EncodeFrame(64, payload)
    // Type 64 -> 2-byte varint: 0x40, 0x40
    assertEquals(64, charCodeAt(frame, 0))   // 0x40 (varint prefix)
    assertEquals(64, charCodeAt(frame, 1))   // 0x40 (value)
    // Length: 1 -> 1-byte varint
    assertEquals(1, charCodeAt(frame, 2))
    // Total: 2 (type varint) + 1 (length varint) + 1 (payload)
    assertEquals(4, stringLength(frame))
    // Verify decode
    val result = h3DecodeFrame(frame, 0)
    assertEquals(64, toInt(mapGet(result, "type")))
    assertEquals(1, toInt(mapGet(result, "length")))
    assertEqualsStr("x", toString(mapGet(result, "payload")))
}

// Large payload length: 100 bytes -> length varint is 2 bytes (0x40, 0x64)
@Test fun testRfc9114_LargePayloadLength() {
    // Build a payload of 100 bytes
    var payload: String = ""
    var i: Int = 0
    while (i < 100) {
        payload = stringConcat(payload, "x")
        i = i + 1
    }
    assertEquals(100, stringLength(payload))
    // DATA frame (type 0 = 1-byte varint)
    val frame = h3EncodeFrame(H3_DATA(), payload)
    // Type: DATA = 0 -> 1-byte varint
    assertEquals(0, charCodeAt(frame, 0))
    // Length: 100 = 0x64 -> requires 2-byte varint (64 <= 100 <= 16383)
    // 2-byte varint of 100: 0x4000 + 100 = 0x4064 -> bytes 0x40, 0x64
    assertEquals(64, charCodeAt(frame, 1))    // 0x40
    assertEquals(100, charCodeAt(frame, 2))   // 0x64
    // Total: 1 (type) + 2 (length varint) + 100 (payload)
    assertEquals(103, stringLength(frame))
    // Verify decode
    val result = h3DecodeFrame(frame, 0)
    assertEquals(H3_DATA(), toInt(mapGet(result, "type")))
    assertEquals(100, toInt(mapGet(result, "length")))
}

// SETTINGS with all 3 valid HTTP/3 params
@Test fun testRfc9114_SettingsMultipleParams() {
    val params = listCreate()
    val p1 = mapCreate()
    mapPut(p1, "id", H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY())
    mapPut(p1, "value", 4096)
    listAppend(params, p1)
    val p2 = mapCreate()
    mapPut(p2, "id", H3_SETTINGS_MAX_FIELD_SECTION_SIZE())
    mapPut(p2, "value", 8192)
    listAppend(params, p2)
    val p3 = mapCreate()
    mapPut(p3, "id", H3_SETTINGS_QPACK_BLOCKED_STREAMS())
    mapPut(p3, "value", 100)
    listAppend(params, p3)
    val frame = h3EncodeSettings(params)
    // Decode the frame
    val frameResult = h3DecodeFrame(frame, 0)
    assertEquals(H3_SETTINGS(), toInt(mapGet(frameResult, "type")))
    // Decode settings payload -- should have all 3 params
    val payload = toString(mapGet(frameResult, "payload"))
    val settingsResult = h3DecodeSettings(payload)
    val decoded = mapGet(settingsResult, "params")
    assertEquals(3, listSize(decoded))
    // Verify each parameter
    val d1 = listGet(decoded, 0)
    assertEquals(H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY(), toInt(mapGet(d1, "id")))
    assertEquals(4096, toInt(mapGet(d1, "value")))
    val d2 = listGet(decoded, 1)
    assertEquals(H3_SETTINGS_MAX_FIELD_SECTION_SIZE(), toInt(mapGet(d2, "id")))
    assertEquals(8192, toInt(mapGet(d2, "value")))
    val d3 = listGet(decoded, 2)
    assertEquals(H3_SETTINGS_QPACK_BLOCKED_STREAMS(), toInt(mapGet(d3, "id")))
    assertEquals(100, toInt(mapGet(d3, "value")))
}

