// =============================================================================
// == Gap 7: Duplicate Settings Detection (RFC 9114 Section 7.2.4)
// =============================================================================

@Test fun testGap7_DuplicateSettingsRejected() {
    // Build payload with duplicate setting ID 1
    var payload: String = quicEncodeVarint(1)   // ID = QPACK_MAX_TABLE_CAPACITY
    payload = stringConcat(payload, quicEncodeVarint(4096))
    payload = stringConcat(payload, quicEncodeVarint(1))   // Duplicate ID
    payload = stringConcat(payload, quicEncodeVarint(8192))
    val result = h3DecodeSettings(payload)
    assertEqualsStr(H3_ERROR(), toString(mapGet(result, "type")))
    assertEquals(H3_SETTINGS_ERROR(), toInt(mapGet(result, "errorCode")))
}

@Test fun testGap7_UniqueSettingsAccepted() {
    // Build payload with unique setting IDs
    var payload: String = quicEncodeVarint(1)
    payload = stringConcat(payload, quicEncodeVarint(4096))
    payload = stringConcat(payload, quicEncodeVarint(6))
    payload = stringConcat(payload, quicEncodeVarint(8192))
    val result = h3DecodeSettings(payload)
    assertEqualsStr("H3_SETTINGS_LIST", toString(mapGet(result, "type")))
    val params = mapGet(result, "params")
    assertEquals(2, listSize(params))
}

@Test fun testGap7_DecodeSettingsListCompat() {
    // Test the legacy compatibility function
    var payload: String = quicEncodeVarint(1)
    payload = stringConcat(payload, quicEncodeVarint(4096))
    val result = h3DecodeSettingsList(payload)
    assertEquals(1, listSize(result))
    assertEquals(1, toInt(mapGet(listGet(result, 0), "id")))
    assertEquals(4096, toInt(mapGet(listGet(result, 0), "value")))
}

@Test fun testGap7_DecodeSettingsListErrorReturnsEmpty() {
    // Duplicate IDs should return empty list via legacy function
    var payload: String = quicEncodeVarint(1)
    payload = stringConcat(payload, quicEncodeVarint(4096))
    payload = stringConcat(payload, quicEncodeVarint(1))
    payload = stringConcat(payload, quicEncodeVarint(8192))
    val result = h3DecodeSettingsList(payload)
    assertEquals(0, listSize(result))
}

