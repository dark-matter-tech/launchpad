// Tests for rockit.networking.http2 — Interop tests against Go h2c server
//
// These tests start a Go cleartext HTTP/2 server, run requests against it,
// and verify correct protocol behavior end-to-end.
//
// Requires: Go installed, compiler rebuilt with Phase 1 TCP binary-safety fix.
// Skips gracefully if Go is not available.

import rockit.testing.probe
import rockit.networking.http2
import rockit.networking.url
import rockit.encoding.hpack

// == Helper: Server Lifecycle =================================================

// Start the Go h2c server, return the port as a string (or "" on failure)
fun interopStartServer(): String {
    // Check if Go is available
    val goCheck = systemExec("which go")
    if (goCheck != 0) {
        return ""
    }
    // Clean up stale port file
    if (fileExists("interop/go/.port")) {
        fileDelete("interop/go/.port")
    }
    // Start server in background (nohup + redirect so systemExec returns immediately)
    systemExec("nohup sh -c 'cd interop/go && go run h2c_server.go' > /dev/null 2>&1 &")
    // Poll for port file (up to 10 seconds)
    var waited: Int = 0
    while (waited < 10000) {
        sleepMillis(500)
        waited = waited + 500
        if (fileExists("interop/go/.port")) {
            val port = stringTrim(fileRead("interop/go/.port"))
            if (stringLength(port) > 0) {
                return port
            }
        }
    }
    return ""
}

// Connect to the interop server
fun interopConnect(port: String): Map {
    val url = stringConcat("http://127.0.0.1:", port)
    return h2Connect(url)
}

// Shut down the server by hitting /shutdown
fun interopShutdown(conn: Map): Unit {
    h2Get(conn, "/shutdown")
    sleepMillis(500)
}

// == Interop Tests ============================================================

@Test fun testInteropH2Ping() {
    val port = interopStartServer()
    if (stringLength(port) == 0) {
        // Go not available — skip
        return
    }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) {
        return
    }
    val resp = h2Get(conn, "/ping")
    assertEquals(200, h2ResponseStatus(resp))
    assertEqualsStr("pong", h2ResponseBody(resp))
    interopShutdown(conn)
    h2Close(conn)
}

@Test fun testInteropH2EchoHeaders() {
    val port = interopStartServer()
    if (stringLength(port) == 0) { return }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) { return }
    val resp = h2Get(conn, "/echo-headers")
    assertEquals(200, h2ResponseStatus(resp))
    val body = h2ResponseBody(resp)
    // Verify pseudo-headers were echoed
    assertTrue(stringContains(body, ":method: GET"))
    assertTrue(stringContains(body, ":path: /echo-headers"))
    interopShutdown(conn)
    h2Close(conn)
}

@Test fun testInteropH2PostBody() {
    val port = interopStartServer()
    if (stringLength(port) == 0) { return }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) { return }
    val resp = h2Post(conn, "/echo", "hello", "text/plain")
    assertEquals(200, h2ResponseStatus(resp))
    assertEqualsStr("hello", h2ResponseBody(resp))
    interopShutdown(conn)
    h2Close(conn)
}

@Test fun testInteropH2StatusCodes() {
    val port = interopStartServer()
    if (stringLength(port) == 0) { return }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) { return }
    val resp = h2Get(conn, "/status/404")
    assertEquals(404, h2ResponseStatus(resp))
    interopShutdown(conn)
    h2Close(conn)
}

@Test fun testInteropH2Trailers() {
    val port = interopStartServer()
    if (stringLength(port) == 0) { return }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) { return }
    val resp = h2Get(conn, "/trailers")
    assertEquals(200, h2ResponseStatus(resp))
    assertEqualsStr("trailer-test", h2ResponseBody(resp))
    // Check for trailer headers
    val trailers = h2ResponseTrailers(resp)
    // Trailers may or may not be received depending on timing
    // At minimum, verify no crash occurred
    assertTrue(true)
    interopShutdown(conn)
    h2Close(conn)
}

@Test fun testInteropH2SettingsExchange() {
    val port = interopStartServer()
    if (stringLength(port) == 0) { return }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) { return }
    // After connect, peer settings should be populated
    val peerSettings = mapGet(conn, "peerSettings")
    // Peer should have sent initial window size
    val windowSize = toInt(mapGet(peerSettings, "initialWindowSize"))
    assertTrue(windowSize > 0)
    interopShutdown(conn)
    h2Close(conn)
}

@Test fun testInteropH2FrameLog() {
    val port = interopStartServer()
    if (stringLength(port) == 0) { return }
    val conn = interopConnect(port)
    if (h2IsOpen(conn) == false) { return }
    // Make a request to generate frame log entries
    h2Get(conn, "/ping")
    // Shutdown writes the frame log
    interopShutdown(conn)
    h2Close(conn)
    // Read and verify frame log
    sleepMillis(500)
    val logExists = fileExists("interop/go/.frames.log")
    if (logExists) {
        val log = fileRead("interop/go/.frames.log")
        // Verify some frame activity was logged
        assertTrue(stringLength(log) > 0)
    }
}
