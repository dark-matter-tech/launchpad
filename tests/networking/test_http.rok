    val block = "X-Test:   value with spaces   "
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    assertEqualsStr("value with spaces", toString(mapGet(headers, "X-Test")))
}

@Test fun testHeaderColonWithoutSpace() {
    // Header with colon but no space after it should still parse
    val block = "X-NoSpace:value"
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    assertEqualsStr("value", toString(mapGet(headers, "X-NoSpace")))
}

@Test fun testHeaderColonWithExtraSpaces() {
    // Header with extra spaces around colon value
    val block = "X-Extra:    lots of space    "
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    assertEqualsStr("lots of space", toString(mapGet(headers, "X-Extra")))
}

