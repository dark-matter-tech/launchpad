// == Gap B: 204/304 treated as no-body responses ============================

@Test fun testParse204NoContent() {
    val raw = "HTTP/1.1 204 No Content\r\nX-Custom: yes\r\n\r\nsome unexpected body"
    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(204, toInt(mapGet(result, "status")))
    assertEqualsStr("", toString(mapGet(result, "body")))
    assertEqualsStr("", toString(mapGet(result, "error")))
}

@Test fun testParse304NotModified() {
    val raw = "HTTP/1.1 304 Not Modified\r\nContent-Length: 500\r\n\r\n"
    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(304, toInt(mapGet(result, "status")))
    assertEqualsStr("", toString(mapGet(result, "body")))
    assertEqualsStr("", toString(mapGet(result, "error")))
}

