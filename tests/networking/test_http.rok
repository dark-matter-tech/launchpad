}

// == Gap C: Chunk hex overflow protection ===================================

@Test fun testParseHexOverflowProtection() {
    // Huge hex value should be capped at HTTP_MAX_RESPONSE_SIZE()
    val capped = httpParseHex("FFFFFFFF")
    assertTrue(capped <= HTTP_MAX_RESPONSE_SIZE())
}

@Test fun testParseHexNormalValues() {
    // Normal values should still parse correctly
    assertEquals(255, httpParseHex("ff"))
    assertEquals(4096, httpParseHex("1000"))
    assertEquals(0, httpParseHex("0"))
}

// == Gap D: Invalid hex chars stop parsing ==================================

