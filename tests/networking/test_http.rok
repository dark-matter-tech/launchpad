@Test fun testValidHeaderNames() {
    assertTrue(httpIsValidHeaderName("Content-Type"))
    assertTrue(httpIsValidHeaderName("X-Custom-Header"))
    assertTrue(httpIsValidHeaderName("Accept"))
    assertTrue(httpIsValidHeaderName("X-Request-ID"))
    assertTrue(httpIsValidHeaderName("Cache-Control"))
}

@Test fun testValidHeaderNameSpecialChars() {
    // Token characters: !#$%&'*+-.^_`|~
    assertTrue(httpIsValidHeaderName("X-Header!"))
    assertTrue(httpIsValidHeaderName("X#Header"))
    assertTrue(httpIsValidHeaderName("X-Header~"))
    assertTrue(httpIsValidHeaderName("X_Header"))
    assertTrue(httpIsValidHeaderName("X.Header"))
}

@Test fun testInvalidHeaderNameEmpty() {
    assertFalse(httpIsValidHeaderName(""))
}

@Test fun testInvalidHeaderNameWithSpace() {
    assertFalse(httpIsValidHeaderName("Content Type"))
}

@Test fun testInvalidHeaderNameWithColon() {
    assertFalse(httpIsValidHeaderName("Content:Type"))
}

@Test fun testInvalidHeaderNameWithAt() {
    assertFalse(httpIsValidHeaderName("X@Header"))
}

@Test fun testInvalidHeaderNameWithBrackets() {
    assertFalse(httpIsValidHeaderName("X[Header]"))
}

@Test fun testInvalidHeaderSkippedInParsing() {
    // Headers with invalid names should be skipped during parsing
    val block = "Valid-Name: good\r\nInvalid Name: bad\r\nAnother-Valid: ok"
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    assertEqualsStr("good", toString(mapGet(headers, "Valid-Name")))
    assertEqualsStr("ok", toString(mapGet(headers, "Another-Valid")))
    // Invalid header should not be present
    val badVal = mapGet(headers, "Invalid Name")
    assertTrue(badVal == null)
}

// == Gap 15: Whitespace trimming on header values (RFC 9110 §5.5) ==========

@Test fun testTrimWhitespace() {
    assertEqualsStr("hello", httpTrimWhitespace("  hello  "))
    assertEqualsStr("hello", httpTrimWhitespace("hello"))
    assertEqualsStr("hello world", httpTrimWhitespace("  hello world  "))
    assertEqualsStr("", httpTrimWhitespace(""))
    assertEqualsStr("", httpTrimWhitespace("   "))
}

@Test fun testTrimWhitespaceWithTabs() {
    val tab = intToChar(9)
    val input = stringConcat(tab, stringConcat("value", tab))
    assertEqualsStr("value", httpTrimWhitespace(input))
}

@Test fun testHeaderValueTrimmedInParsing() {
