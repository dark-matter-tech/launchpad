@Test fun testContentLengthZeroPattern() {
    // Verify the pattern is correct via parsing a response with Content-Length: 0
    val raw = "HTTP/1.1 200 OK\r\nContent-Length: 0\r\n\r\n"
    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(200, toInt(mapGet(result, "status")))
    assertEqualsStr("", toString(mapGet(result, "body")))
    assertFalse(httpIsError(result))
}

// == Gap 13: Redirect loop detection (RFC 9110 §15.4) =====================
// (httpFollowRedirects makes network calls, so we test the URL tracking
//  pattern indirectly by testing listContains)

@Test fun testRedirectLoopDetectionPattern() {
    // Verify the listContains pattern used in redirect loop detection
    val visited = listCreate()
    listAppend(visited, "http://example.com/a")
    listAppend(visited, "http://example.com/b")
    assertTrue(listContains(visited, "http://example.com/a"))
    assertTrue(listContains(visited, "http://example.com/b"))
    assertFalse(listContains(visited, "http://example.com/c"))
}

