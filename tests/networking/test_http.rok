    // 'g' is not a valid hex digit — should stop and return parsed portion
    assertEquals(255, httpParseHex("ffg0"))
}

@Test fun testParseHexWithSpaceStops() {
    // Space is not a valid hex digit
    assertEquals(10, httpParseHex("a "))
}

@Test fun testParseHexLeadingInvalid() {
    // Leading invalid character should return 0
    assertEquals(0, httpParseHex("xyz"))
}

@Test fun testParseHexMixedCase() {
    // Mixed case hex should still work
    assertEquals(171, httpParseHex("Ab"))
    assertEquals(171, httpParseHex("aB"))
}

// == Gap E: Duplicate Content-Length detection ==============================

@Test fun testDuplicateContentLengthIdentical() {
    // Multiple identical Content-Length values should be OK
    val crlf = stringConcat(intToChar(13), intToChar(10))
    var raw: String = stringConcat("HTTP/1.1 200 OK", crlf)
    raw = stringConcat(raw, stringConcat("Content-Length: 5", crlf))
    raw = stringConcat(raw, stringConcat("Content-Length: 5", crlf))
    raw = stringConcat(raw, crlf)
    raw = stringConcat(raw, "hello")

    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(200, toInt(mapGet(result, "status")))
    assertEqualsStr("hello", toString(mapGet(result, "body")))
}

@Test fun testDuplicateContentLengthConflict() {
    // Different Content-Length values should produce error
    val crlf = stringConcat(intToChar(13), intToChar(10))
    var raw: String = stringConcat("HTTP/1.1 200 OK", crlf)
    raw = stringConcat(raw, stringConcat("Content-Length: 5", crlf))
    raw = stringConcat(raw, stringConcat("Content-Length: 10", crlf))
    raw = stringConcat(raw, crlf)
    raw = stringConcat(raw, "hello")

    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertTrue(httpIsError(result))
    assertTrue(stringContains(httpErrorMessage(result), "Conflicting Content-Length"))
}

@Test fun testSingleContentLengthNoDuplicate() {
    // Single Content-Length should parse normally
    val raw = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\n\r\nhello"
    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(200, toInt(mapGet(result, "status")))
    assertEqualsStr("hello", toString(mapGet(result, "body")))
    assertFalse(httpIsError(result))
}

// == Gap F: Set-Cookie exemption from comma-combining =======================

@Test fun testSetCookieNewlineSeparated() {
    // Set-Cookie headers should NOT be comma-combined (cookie values can contain commas)
    val block = "Set-Cookie: a=1; Path=/\r\nSet-Cookie: b=2; HttpOnly"
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    val cookieVal = toString(mapGet(headers, "Set-Cookie"))
    // Should be newline-separated, not comma-separated
    assertTrue(stringContains(cookieVal, "\n"))
    assertFalse(stringContains(cookieVal, ", "))
    assertTrue(stringContains(cookieVal, "a=1; Path=/"))
    assertTrue(stringContains(cookieVal, "b=2; HttpOnly"))
}

@Test fun testSetCookieThreeValues() {
    // Three Set-Cookie values should be newline-separated
    val crlf = stringConcat(intToChar(13), intToChar(10))
    var block: String = stringConcat("Set-Cookie: session=abc", crlf)
    block = stringConcat(block, stringConcat("Set-Cookie: theme=dark", crlf))
    block = stringConcat(block, "Set-Cookie: lang=en")
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    val cookieVal = toString(mapGet(headers, "Set-Cookie"))
    assertTrue(stringContains(cookieVal, "session=abc"))
    assertTrue(stringContains(cookieVal, "theme=dark"))
    assertTrue(stringContains(cookieVal, "lang=en"))
    // Verify newline separator
    assertTrue(stringContains(cookieVal, "\n"))
}

@Test fun testNonSetCookieStillCommaCombined() {
    // Other headers should still be comma-combined
    val block = "Via: proxy1\r\nVia: proxy2"
    val headers = mapCreate()
    httpParseHeaders(block, headers)
    assertEqualsStr("proxy1, proxy2", toString(mapGet(headers, "Via")))
}

