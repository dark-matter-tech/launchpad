// == Content-Length Validation =================================================

@Test fun testContentLengthMatch() {
    val raw = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\n\r\nhello"
    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(200, toInt(mapGet(result, "status")))
    assertEqualsStr("hello", toString(mapGet(result, "body")))
    assertEqualsStr("", toString(mapGet(result, "error")))
}

@Test fun testContentLengthMismatch() {
    val raw = "HTTP/1.1 200 OK\r\nContent-Length: 10\r\n\r\nhello"
    val result = mapCreate()
    val headers = mapCreate()
    mapPut(result, "headers", headers)
    httpParseResponse(raw, result, headers)
    assertEquals(200, toInt(mapGet(result, "status")))
    assertTrue(httpIsError(result))
    assertTrue(stringContains(httpErrorMessage(result), "Content-Length mismatch"))
}

