// == Gap 5: RST_STREAM frame length validation ================================

@Test fun testRstStreamExactly4Bytes() {
    // RST_STREAM with exactly 4 bytes is valid
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "rstStreamCount", 0)
    val streams = mapCreate()
    val stream = mapCreate()
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(streams, "1", stream)
    mapPut(conn, "streams", streams)
    val payload = h2EncodeUint32(H2_CANCEL())
    h2HandleRstStream(conn, 1, payload)
    // Stream should be closed
    assertEquals(H2_STREAM_CLOSED_STATE(), toInt(mapGet(stream, "state")))
}

@Test fun testRstStreamTooShort() {
    // RST_STREAM with 3 bytes should be rejected
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "rstStreamCount", 0)
    val streams = mapCreate()
    val stream = mapCreate()
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(streams, "1", stream)
    mapPut(conn, "streams", streams)
    var shortPayload: String = intToChar(0)
    shortPayload = stringConcat(shortPayload, intToChar(0))
    shortPayload = stringConcat(shortPayload, intToChar(8))
    h2HandleRstStream(conn, 1, shortPayload)
    // Stream should NOT have been changed (error detected before processing)
    assertEquals(H2_STREAM_OPEN(), toInt(mapGet(stream, "state")))
}

@Test fun testRstStreamTooLong() {
    // RST_STREAM with 5 bytes should be rejected (was accepted before)
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "rstStreamCount", 0)
    val streams = mapCreate()
    val stream = mapCreate()
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(streams, "1", stream)
    mapPut(conn, "streams", streams)
    var longPayload: String = h2EncodeUint32(H2_CANCEL())
    longPayload = stringConcat(longPayload, intToChar(0))
    assertEquals(5, stringLength(longPayload))
    h2HandleRstStream(conn, 1, longPayload)
    // Stream should NOT have been changed
    assertEquals(H2_STREAM_OPEN(), toInt(mapGet(stream, "state")))
}

