// Tests for rockit.networking.http2
import rockit.testing.probe
import rockit.networking.http2
import rockit.networking.url
import rockit.encoding.hpack

// == Frame Type Constants =====================================================

@Test fun testFrameTypeConstants() {
    assertEquals(0, H2_DATA())
    assertEquals(1, H2_HEADERS())
    assertEquals(2, H2_PRIORITY())
    assertEquals(3, H2_RST_STREAM())
    assertEquals(4, H2_SETTINGS())
    assertEquals(5, H2_PUSH_PROMISE())
    assertEquals(6, H2_PING())
    assertEquals(7, H2_GOAWAY())
    assertEquals(8, H2_WINDOW_UPDATE())
    assertEquals(9, H2_CONTINUATION())
}

// == Error Code Constants =====================================================

@Test fun testErrorCodeConstants() {
    assertEquals(0, H2_NO_ERROR())
    assertEquals(1, H2_PROTOCOL_ERROR())
    assertEquals(2, H2_INTERNAL_ERROR())
    assertEquals(3, H2_FLOW_CONTROL_ERROR())
    assertEquals(4, H2_SETTINGS_TIMEOUT())
    assertEquals(5, H2_STREAM_CLOSED())
    assertEquals(6, H2_FRAME_SIZE_ERROR())
    assertEquals(7, H2_REFUSED_STREAM())
    assertEquals(8, H2_CANCEL())
    assertEquals(9, H2_COMPRESSION_ERROR())
    assertEquals(10, H2_CONNECT_ERROR())
    assertEquals(11, H2_ENHANCE_YOUR_CALM())
    assertEquals(12, H2_INADEQUATE_SECURITY())
    assertEquals(13, H2_HTTP_1_1_REQUIRED())
}

// == Settings Constants =======================================================

@Test fun testSettingsConstants() {
    assertEquals(1, H2_SETTINGS_HEADER_TABLE_SIZE())
    assertEquals(2, H2_SETTINGS_ENABLE_PUSH())
    assertEquals(3, H2_SETTINGS_MAX_CONCURRENT_STREAMS())
    assertEquals(4, H2_SETTINGS_INITIAL_WINDOW_SIZE())
    assertEquals(5, H2_SETTINGS_MAX_FRAME_SIZE())
    assertEquals(6, H2_SETTINGS_MAX_HEADER_LIST_SIZE())
}

@Test fun testDefaultSettings() {
    assertEquals(4096, H2_DEFAULT_HEADER_TABLE_SIZE())
    assertEquals(65535, H2_DEFAULT_INITIAL_WINDOW_SIZE())
    assertEquals(16384, H2_DEFAULT_MAX_FRAME_SIZE())
}

// == Flag Constants ===========================================================

@Test fun testFlagConstants() {
    assertEquals(1, H2_FLAG_END_STREAM())
    assertEquals(4, H2_FLAG_END_HEADERS())
    assertEquals(8, H2_FLAG_PADDED())
    assertEquals(32, H2_FLAG_PRIORITY())
    assertEquals(1, H2_FLAG_ACK())
}

// == Stream State Constants ===================================================

@Test fun testStreamStateConstants() {
    assertEquals(0, H2_STREAM_IDLE())
    assertEquals(1, H2_STREAM_OPEN())
    assertEquals(2, H2_STREAM_HALF_CLOSED_LOCAL())
    assertEquals(3, H2_STREAM_HALF_CLOSED_REMOTE())
    assertEquals(4, H2_STREAM_CLOSED_STATE())
}

// == Bitwise Helpers ==========================================================

@Test fun testH2OrZero() {
    assertEquals(0, h2Or(0, 0))
}

@Test fun testH2OrIdentity() {
    assertEquals(255, h2Or(255, 0))
    assertEquals(255, h2Or(0, 255))
}

@Test fun testH2OrBits() {
    // 0x01 | 0x04 = 0x05
    assertEquals(5, h2Or(1, 4))
    // 0x01 | 0x04 | 0x08 = 0x0D
    assertEquals(13, h2Or(5, 8))
}

@Test fun testH2AndZero() {
    assertEquals(0, h2And(0, 0))
    assertEquals(0, h2And(255, 0))
}

@Test fun testH2AndIdentity() {
    assertEquals(255, h2And(255, 255))
}

@Test fun testH2AndMask() {
    assertEquals(1, h2And(5, 1))   // 0x05 & 0x01 = 0x01
    assertEquals(4, h2And(5, 4))   // 0x05 & 0x04 = 0x04
    assertEquals(0, h2And(5, 2))   // 0x05 & 0x02 = 0x00
}

@Test fun testH2HasFlag() {
    assertTrue(h2HasFlag(5, 1))    // END_STREAM set in 0x05
    assertTrue(h2HasFlag(5, 4))    // END_HEADERS set in 0x05
    assertFalse(h2HasFlag(5, 2))   // bit 1 not set
    assertFalse(h2HasFlag(5, 8))   // PADDED not set
}

@Test fun testH2Pow2() {
    assertEquals(1, h2Pow2(0))
    assertEquals(2, h2Pow2(1))
    assertEquals(256, h2Pow2(8))
    assertEquals(65536, h2Pow2(16))
}

// == Multi-byte Integer Encoding ==============================================

@Test fun testEncodeDecodeUint32() {
    // Only test values whose bytes are all < 128 (intToChar limited to ASCII)
    assertEquals(0, h2DecodeUint32(h2EncodeUint32(0), 0))
    assertEquals(1, h2DecodeUint32(h2EncodeUint32(1), 0))
    assertEquals(127, h2DecodeUint32(h2EncodeUint32(127), 0))
    assertEquals(256, h2DecodeUint32(h2EncodeUint32(256), 0))
    assertEquals(16909060, h2DecodeUint32(h2EncodeUint32(16909060), 0))  // 0x01020304
}

@Test fun testEncodeDecodeUint16() {
    // Both bytes must be 1-127: intToChar(0) produces NUL (truncates string),
    // intToChar(>=128) returns empty string. value = high*256 + low.
    assertEquals(257, h2DecodeUint16(h2EncodeUint16(257), 0))    // 0x0101: 1,1
    assertEquals(513, h2DecodeUint16(h2EncodeUint16(513), 0))    // 0x0201: 2,1
    assertEquals(16447, h2DecodeUint16(h2EncodeUint16(16447), 0))  // 0x403F: 64,63
    assertEquals(32639, h2DecodeUint16(h2EncodeUint16(32639), 0))  // 0x7F7F: 127,127
}

@Test fun testEncodeUint32Bytes() {
    val encoded = h2EncodeUint32(16909060)  // 0x01020304
    assertEquals(4, stringLength(encoded))
    assertEquals(1, charCodeAt(encoded, 0))
    assertEquals(2, charCodeAt(encoded, 1))
    assertEquals(3, charCodeAt(encoded, 2))
    assertEquals(4, charCodeAt(encoded, 3))
}

// == Frame Header Encode/Decode ===============================================

@Test fun testFrameHeaderSize() {
    val header = h2EncodeFrameHeader(0, H2_DATA(), 0, 0)
    assertEquals(9, stringLength(header))
}

@Test fun testFrameHeaderRoundtrip() {
    val header = h2EncodeFrameHeader(100, H2_HEADERS(), 5, 1)
    val decoded = h2DecodeFrameHeader(header, 0)
    assertEquals(100, toInt(mapGet(decoded, "length")))
    assertEquals(1, toInt(mapGet(decoded, "type")))
    assertEquals(5, toInt(mapGet(decoded, "flags")))
    assertEquals(1, toInt(mapGet(decoded, "streamId")))
}

@Test fun testFrameHeaderZeroStream() {
    val header = h2EncodeFrameHeader(0, H2_SETTINGS(), 0, 0)
    val decoded = h2DecodeFrameHeader(header, 0)
    assertEquals(0, toInt(mapGet(decoded, "length")))
    assertEquals(4, toInt(mapGet(decoded, "type")))
    assertEquals(0, toInt(mapGet(decoded, "flags")))
    assertEquals(0, toInt(mapGet(decoded, "streamId")))
}

@Test fun testFrameHeaderLargePayload() {
    val header = h2EncodeFrameHeader(16384, H2_DATA(), 1, 3)
    val decoded = h2DecodeFrameHeader(header, 0)
    assertEquals(16384, toInt(mapGet(decoded, "length")))
    assertEquals(0, toInt(mapGet(decoded, "type")))
    assertEquals(1, toInt(mapGet(decoded, "flags")))
    assertEquals(3, toInt(mapGet(decoded, "streamId")))
}

// == Frame Builders ===========================================================

@Test fun testBuildSettingsFrame() {
    val params = listCreate()
    val p1 = mapCreate()
    mapPut(p1, "id", H2_SETTINGS_ENABLE_PUSH())
    mapPut(p1, "value", 0)
    listAppend(params, p1)
    val frame = h2BuildSettingsFrame(params)
    // 9 byte header + 6 byte payload (1 setting)
    assertEquals(15, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(6, toInt(mapGet(decoded, "length")))
    assertEquals(4, toInt(mapGet(decoded, "type")))
    assertEquals(0, toInt(mapGet(decoded, "streamId")))
}

@Test fun testBuildSettingsAckFrame() {
    val frame = h2BuildSettingsAckFrame()
    assertEquals(9, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(0, toInt(mapGet(decoded, "length")))
    assertEquals(4, toInt(mapGet(decoded, "type")))
    assertEquals(1, toInt(mapGet(decoded, "flags")))
}

@Test fun testBuildPingFrame() {
    val frame = h2BuildPingFrame("12345678", false)
    // 9 byte header + 8 byte payload
    assertEquals(17, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(8, toInt(mapGet(decoded, "length")))
    assertEquals(6, toInt(mapGet(decoded, "type")))
    assertEquals(0, toInt(mapGet(decoded, "flags")))
    assertEquals(0, toInt(mapGet(decoded, "streamId")))
}

@Test fun testBuildPingAckFrame() {
    val frame = h2BuildPingFrame("ABCDEFGH", true)
    assertEquals(17, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(1, toInt(mapGet(decoded, "flags")))  // ACK flag
}

@Test fun testBuildWindowUpdateFrame() {
    // Use increment with all bytes < 128
    val frame = h2BuildWindowUpdateFrame(1, 100)
    // 9 byte header + 4 byte payload
    assertEquals(13, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(4, toInt(mapGet(decoded, "length")))
    assertEquals(8, toInt(mapGet(decoded, "type")))
    assertEquals(1, toInt(mapGet(decoded, "streamId")))
    // Verify increment value
    assertEquals(100, h2DecodeUint32(frame, 9))
}

@Test fun testBuildWindowUpdateConnectionLevel() {
    // Use increment with all bytes < 128
    val frame = h2BuildWindowUpdateFrame(0, 50)
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(0, toInt(mapGet(decoded, "streamId")))
    assertEquals(50, h2DecodeUint32(frame, 9))
}

@Test fun testBuildRstStreamFrame() {
    val frame = h2BuildRstStreamFrame(1, H2_CANCEL())
    // 9 byte header + 4 byte payload
    assertEquals(13, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(4, toInt(mapGet(decoded, "length")))
    assertEquals(3, toInt(mapGet(decoded, "type")))
    assertEquals(1, toInt(mapGet(decoded, "streamId")))
    assertEquals(8, h2DecodeUint32(frame, 9))  // CANCEL = 8
}

@Test fun testBuildGoawayFrame() {
    val frame = h2BuildGoawayFrame(1, H2_NO_ERROR(), "")
    // 9 byte header + 8 byte payload (lastStreamId + errorCode)
    assertEquals(17, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(8, toInt(mapGet(decoded, "length")))
    assertEquals(7, toInt(mapGet(decoded, "type")))
    assertEquals(0, toInt(mapGet(decoded, "streamId")))
}

@Test fun testBuildGoawayWithDebug() {
    val frame = h2BuildGoawayFrame(3, H2_PROTOCOL_ERROR(), "bad")
    // 9 + 8 + 3 = 20
    assertEquals(20, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(11, toInt(mapGet(decoded, "length")))
}

@Test fun testBuildDataFrame() {
    val frame = h2BuildDataFrame(1, "hello", true)
    // 9 byte header + 5 byte payload
    assertEquals(14, stringLength(frame))
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(5, toInt(mapGet(decoded, "length")))
    assertEquals(0, toInt(mapGet(decoded, "type")))
    assertEquals(1, toInt(mapGet(decoded, "flags")))  // END_STREAM
    assertEquals(1, toInt(mapGet(decoded, "streamId")))
}

@Test fun testBuildDataFrameNoEndStream() {
    val frame = h2BuildDataFrame(3, "data", false)
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(0, toInt(mapGet(decoded, "flags")))
}

@Test fun testBuildHeadersFrame() {
    val headerBlock = "dummy"
    val frame = h2BuildHeadersFrame(1, headerBlock, true, true)
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(5, toInt(mapGet(decoded, "length")))
    assertEquals(1, toInt(mapGet(decoded, "type")))
    assertEquals(5, toInt(mapGet(decoded, "flags")))  // END_STREAM | END_HEADERS
    assertEquals(1, toInt(mapGet(decoded, "streamId")))
}

@Test fun testBuildHeadersFrameNoFlags() {
    val frame = h2BuildHeadersFrame(1, "block", false, false)
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(0, toInt(mapGet(decoded, "flags")))
}

// == Client Preface ===========================================================

@Test fun testClientPrefaceLength() {
    val preface = h2ClientPreface()
    // Runtime normalizes \r\n to \n, so 24 bytes becomes 20
    assertEquals(20, stringLength(preface))
}

@Test fun testClientPrefaceContent() {
    val preface = h2ClientPreface()
    // "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    assertStartsWith(preface, "PRI * HTTP/2.0")
}

