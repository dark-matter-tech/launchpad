@Test fun testClientPrefaceMatchesExpected() {
    // Verify the client preface magic string is well-formed
    val preface = h2ClientPreface()
    assertTrue(stringLength(preface) > 0)
    assertStartsWith(preface, "PRI * HTTP/2.0")
    val smIndex = stringIndexOf(preface, "SM")
    assertTrue(smIndex > 0)
}

// == Gap 10: PUSH_PROMISE padding support =====================================

@Test fun testPushPromisePaddingStripped() {
    // PUSH_PROMISE with PADDED flag should strip padding
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", ps)
    // Build padded PUSH_PROMISE payload:
    // pad_length(1) + promised_stream_id(4) + header_block + padding
    val ctx = hpackCreateContext()
    val headerList = listCreate()
    val hdr = mapCreate()
    mapPut(hdr, "name", ":method")
    mapPut(hdr, "value", "GET")
    listAppend(headerList, hdr)
    val headerBlock = hpackEncode(ctx, headerList)
    var payload: String = intToChar(2)  // pad length = 2
    payload = stringConcat(payload, h2EncodeUint32(4))  // promised stream ID = 4
    payload = stringConcat(payload, headerBlock)
    payload = stringConcat(payload, intToChar(0))  // padding byte 1
    payload = stringConcat(payload, intToChar(0))  // padding byte 2
    h2HandlePushPromise(conn, h2Or(H2_FLAG_END_HEADERS(), H2_FLAG_PADDED()), 1, payload)
    val streams = mapGet(conn, "streams")
    val promisedStream = mapGet(streams, "4")
    assertTrue(promisedStream != null)
}

@Test fun testPushPromisePaddingError() {
    // PUSH_PROMISE with invalid padding should trigger PROTOCOL_ERROR
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", ps)
    // pad_length=50 but total payload is only 5 bytes
    var payload: String = intToChar(50)  // pad length = 50
    payload = stringConcat(payload, h2EncodeUint32(4))
    h2HandlePushPromise(conn, h2Or(H2_FLAG_END_HEADERS(), H2_FLAG_PADDED()), 1, payload)
    val streams = mapGet(conn, "streams")
    // Stream should NOT have been created
    assertTrue(mapGet(streams, "4") == null)
}

// == Gap 11: HEADERS frame PRIORITY flag handling =============================

@Test fun testHeadersPriorityFlagSkipsFirst5Bytes() {
    // When PRIORITY flag (0x20) is set, first 5 bytes are priority data
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    mapPut(conn, "expectContinuation", false)
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", ps)
    // Build payload: 5 bytes priority + HPACK encoded headers
    val ctx = hpackCreateContext()
    val headerList = listCreate()
    val hdr = mapCreate()
    mapPut(hdr, "name", ":status")
    mapPut(hdr, "value", "200")
    listAppend(headerList, hdr)
    val headerBlock = hpackEncode(ctx, headerList)
    // Priority data: 4 bytes dependency + 1 byte weight
    var payload: String = h2EncodeUint32(0)  // stream dependency
    payload = stringConcat(payload, intToChar(16))  // weight
    payload = stringConcat(payload, headerBlock)
    // Flags: END_HEADERS | PRIORITY
    val flags = h2Or(H2_FLAG_END_HEADERS(), H2_FLAG_PRIORITY())
    h2HandleHeaders(conn, flags, 1, payload)
    // Stream should have been created with :status header
    val streams = mapGet(conn, "streams")
    val stream = mapGet(streams, "1")
    assertTrue(stream != null)
    val headers = mapGet(stream, "headers")
    assertTrue(listSize(headers) > 0)
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("200", toString(mapGet(listGet(headers, 0), "value")))
}

@Test fun testHeadersPriorityFlagTooShort() {
    // PRIORITY flag set but payload too short (< 5 bytes)
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    mapPut(conn, "expectContinuation", false)
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", ps)
    // Only 3 bytes — not enough for priority data
    var payload: String = intToChar(0)
    payload = stringConcat(payload, intToChar(0))
    payload = stringConcat(payload, intToChar(0))
    val flags = h2Or(H2_FLAG_END_HEADERS(), H2_FLAG_PRIORITY())
    h2HandleHeaders(conn, flags, 1, payload)
    // Stream should NOT have been created
    val streams = mapGet(conn, "streams")
    assertTrue(mapGet(streams, "1") == null)
}

@Test fun testFlagPriorityConstant() {
    assertEquals(32, H2_FLAG_PRIORITY())
}

// == Gap 12: New stream initial window from peer settings =====================

@Test fun testNewStreamUsePeerInitialWindowSize() {
    // When peer has set INITIAL_WINDOW_SIZE to non-default, new streams use it
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    mapPut(conn, "expectContinuation", false)
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 32768)
    mapPut(conn, "peerSettings", ps)
    // Feed a HEADERS frame to create a new stream
    val ctx = hpackCreateContext()
    val headerList = listCreate()
    val hdr = mapCreate()
    mapPut(hdr, "name", ":status")
    mapPut(hdr, "value", "200")
    listAppend(headerList, hdr)
    val headerBlock = hpackEncode(ctx, headerList)
    h2HandleHeaders(conn, h2Or(H2_FLAG_END_HEADERS(), H2_FLAG_END_STREAM()), 1, headerBlock)
    val streams = mapGet(conn, "streams")
    val stream = mapGet(streams, "1")
    assertTrue(stream != null)
    // sendWindow should be peer's initialWindowSize (32768), not default (65535)
    assertEquals(32768, toInt(mapGet(stream, "sendWindow")))
}

