@Test fun testPaddingStripping() {
    // Build padded payload: pad_length(1) + data + padding
    // pad_length = 3, data = "hello" (5 bytes), padding = 3 zero bytes
    var payload: String = intToChar(3)  // pad length = 3
    payload = stringConcat(payload, "hello")
    payload = stringConcat(payload, stringConcat(intToChar(0), stringConcat(intToChar(0), intToChar(0))))
    val stripped = h2StripPadding(H2_FLAG_PADDED(), payload)
    assertEqualsStr("hello", stripped)
}

