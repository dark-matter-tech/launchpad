// == Gap 3: SETTINGS Payload Length Validation =================================

@Test fun testSettingsPayloadLengthMultipleOf6() {
    // Valid: 12 bytes = 2 settings (12 / 6 = 2)
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "peerSettings", mapCreate())
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "error", "")
    mapPut(conn, "settingsState", "UNSENT")
    // Build 2 settings (12 bytes)
    var payload: String = h2EncodeUint16(H2_SETTINGS_HEADER_TABLE_SIZE())
    payload = stringConcat(payload, h2EncodeUint32(4096))
    payload = stringConcat(payload, h2EncodeUint16(H2_SETTINGS_ENABLE_PUSH()))
    payload = stringConcat(payload, h2EncodeUint32(1))
    assertEquals(12, stringLength(payload))
    // Should NOT trigger FRAME_SIZE_ERROR — settings are applied
    h2HandleSettings(conn, 0, payload)
    // Verify settings were applied (not rejected)
    val ps = mapGet(conn, "peerSettings")
    assertEquals(4096, toInt(mapGet(ps, "headerTableSize")))
}

@Test fun testSettingsPayloadLengthNotMultipleOf6() {
    // Invalid: 7 bytes (not a multiple of 6) should trigger FRAME_SIZE_ERROR
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "peerSettings", mapCreate())
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "error", "")
    mapPut(conn, "settingsState", "UNSENT")
    // 7 bytes: not a multiple of 6
    var payload: String = h2EncodeUint16(H2_SETTINGS_HEADER_TABLE_SIZE())
    payload = stringConcat(payload, h2EncodeUint32(4096))
    payload = stringConcat(payload, intToChar(0))
    assertEquals(7, stringLength(payload))
    // Should trigger FRAME_SIZE_ERROR — settings should NOT be applied
    h2HandleSettings(conn, 0, payload)
    // The peerSettings map should not have been updated
    val ps = mapGet(conn, "peerSettings")
    assertTrue(mapGet(ps, "headerTableSize") == null)
}

@Test fun testSettingsPayloadEmpty() {
    // Empty SETTINGS payload (0 bytes) is valid (0 is a multiple of 6)
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "peerSettings", mapCreate())
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "error", "")
    mapPut(conn, "settingsState", "UNSENT")
    // Empty payload — valid
    h2HandleSettings(conn, 0, "")
    // Should not crash or error
}

@Test fun testSettingsPayloadLength5Bytes() {
    // 5 bytes is not a multiple of 6
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val ps = mapCreate()
    mapPut(ps, "headerTableSize", 4096)
    mapPut(conn, "peerSettings", ps)
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "error", "")
    mapPut(conn, "settingsState", "UNSENT")
    var payload: String = ""
    var i: Int = 0
    while (i < 5) {
        payload = stringConcat(payload, intToChar(0))
        i = i + 1
    }
    h2HandleSettings(conn, 0, payload)
    // headerTableSize should still be 4096 (unchanged because settings rejected)
    assertEquals(4096, toInt(mapGet(ps, "headerTableSize")))
}

// == Gap 4: Padding Length Bounds Check ========================================

@Test fun testStripPaddingValid() {
    // Valid padded payload: padLength=2, data="AB", padding=2 zero bytes
    var payload: String = intToChar(2)  // pad length = 2
    payload = stringConcat(payload, "AB")
    payload = stringConcat(payload, stringConcat(intToChar(0), intToChar(0)))
    val stripped = h2StripPadding(H2_FLAG_PADDED(), payload)
    assertEqualsStr("AB", stripped)
}

@Test fun testStripPaddingExceedsPayload() {
    // Invalid: padLength=10 but total payload is only 5 bytes
    var payload: String = intToChar(10)  // pad length = 10
    payload = stringConcat(payload, "ABCD")  // only 4 data bytes, total=5
    val stripped = h2StripPadding(H2_FLAG_PADDED(), payload)
    assertEqualsStr("PADDING_ERROR", stripped)
}

@Test fun testStripPaddingEqualsPayload() {
    // Invalid: padLength equals payload length (leaves no room for data)
    var payload: String = intToChar(3)  // pad length = 3
    payload = stringConcat(payload, stringConcat(intToChar(0), stringConcat(intToChar(0), intToChar(0))))  // 3 padding bytes
    // Total payload = 4 bytes, padLength = 3. padLength < payloadLength (4), so this is valid
    // Actually: padLength(3) < payloadLength(4), so this should work
    val stripped = h2StripPadding(H2_FLAG_PADDED(), payload)
    // After strip: substring(payload, 1, 4-3) = substring(payload, 1, 1) = ""
    assertEqualsStr("", stripped)
}

@Test fun testStripPaddingZeroLength() {
    // Empty padded payload — PADDING_ERROR
    val stripped = h2StripPadding(H2_FLAG_PADDED(), "")
    assertEqualsStr("PADDING_ERROR", stripped)
}

@Test fun testStripPaddingNotPadded() {
    // Non-padded payload should pass through unchanged
    val payload = "hello"
    val stripped = h2StripPadding(0, payload)
    assertEqualsStr("hello", stripped)
}

@Test fun testStripPaddingPadLengthExactlyPayloadLen() {
    // padLength = payloadLength (e.g., padLength=2, total payload=2)
    // This means padLength >= payloadLength, which is an error
    var payload: String = intToChar(2)  // pad length = 2
    payload = stringConcat(payload, intToChar(0))  // total = 2 bytes
    val stripped = h2StripPadding(H2_FLAG_PADDED(), payload)
    assertEqualsStr("PADDING_ERROR", stripped)
}

@Test fun testHandleDataPaddingError() {
    // Verify h2HandleData properly rejects invalid padding
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "connRecvWindow", 65535)
    // Build a DATA payload with invalid padding (padLength > payload)
    var payload: String = intToChar(50)  // pad length = 50
    payload = stringConcat(payload, "ABC")  // total = 4 bytes, padLength=50 > 4
    // Should not crash
    h2HandleData(conn, H2_FLAG_PADDED(), 1, payload)
    // Stream should not have been created (error was returned early)
    val streams = mapGet(conn, "streams")
    assertTrue(mapGet(streams, "1") == null)
}

// == Gap 5: Stream ID Overflow Check ==========================================

@Test fun testCanAllocateStreamIdNormal() {
    val conn = mapCreate()
    mapPut(conn, "nextStreamId", 1)
    assertTrue(h2CanAllocateStreamId(conn))
}

@Test fun testCanAllocateStreamIdAtMax() {
    val conn = mapCreate()
    // Max valid stream ID is 2^31-1 = 2147483647
    mapPut(conn, "nextStreamId", 2147483647)
    assertTrue(h2CanAllocateStreamId(conn))
}

@Test fun testCanAllocateStreamIdOverflow() {
    val conn = mapCreate()
    // Next ID would be 2^31+1 = 2147483649, exceeds max
    mapPut(conn, "nextStreamId", 2147483649)
    assertFalse(h2CanAllocateStreamId(conn))
}

@Test fun testStreamIdOverflowPreventsRequest() {
    val conn = mapCreate()
    mapPut(conn, "fd", 5)
    mapPut(conn, "nextStreamId", 2147483649)
    mapPut(conn, "activeStreamCount", 0)
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "error", "")
    mapPut(conn, "host", "localhost")
    mapPut(conn, "port", 8080)
    mapPut(conn, "hpackEncCtx", hpackCreateContext())
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    val peerSettings = mapCreate()
    mapPut(peerSettings, "maxHeaderListSize", 0)
    mapPut(conn, "peerSettings", peerSettings)
    mapPut(conn, "tls", false)
    // h2Request should return an error about stream ID exhaustion
    // We can't actually call h2Request because it tries to send on fd=5
    // but we can verify the guard function
    assertFalse(h2CanAllocateStreamId(conn))
}

@Test fun testStreamIdOverflowPreventsAsyncRequest() {
    val conn = mapCreate()
    mapPut(conn, "fd", 5)
    mapPut(conn, "nextStreamId", 2147483649)
    mapPut(conn, "activeStreamCount", 0)
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    // h2SendRequestAsync checks h2CanAllocateStreamId and returns -1
    assertFalse(h2CanAllocateStreamId(conn))
}

@Test fun testStreamIdMaxValue() {
    // 2^31 - 1 is the maximum valid stream ID
    assertEquals(2147483647, 2147483647)
    // The next odd stream ID after 2147483647 would be 2147483649
    val nextAfterMax = 2147483647 + 2
    assertEquals(2147483649, nextAfterMax)
}

// == Gap 6: PING Keep-Alive ===================================================

@Test fun testPingKeepAlivePayload() {
    // Verify the PING frame is built correctly for keep-alive
    val frame = h2BuildPingFrame("KEEPALIV", false)
    assertEquals(17, stringLength(frame))  // 9 header + 8 payload
    val decoded = h2DecodeFrameHeader(frame, 0)
    assertEquals(8, toInt(mapGet(decoded, "length")))
    assertEquals(6, toInt(mapGet(decoded, "type")))  // PING
    assertEquals(0, toInt(mapGet(decoded, "flags")))  // Not ACK
    assertEquals(0, toInt(mapGet(decoded, "streamId")))  // Must be stream 0
    // Verify payload contains "KEEPALIV"
    val payloadStart = substring(frame, 9, 17)
    assertEqualsStr("KEEPALIV", payloadStart)
}

@Test fun testPingKeepAliveClosedConn() {
    // PING keep-alive on closed connection returns -1
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val result = h2SendPingKeepAlive(conn)
    assertEquals(0 - 1, result)
}

@Test fun testPingKeepAliveFrameIsNotAck() {
    // Keep-alive PING should NOT set ACK flag
    val frame = h2BuildPingFrame("KEEPALIV", false)
    val decoded = h2DecodeFrameHeader(frame, 0)
    val flags = toInt(mapGet(decoded, "flags"))
    assertFalse(h2HasFlag(flags, H2_FLAG_ACK()))
}

@Test fun testPingKeepAlivePayloadIs8Bytes() {
    // "KEEPALIV" is exactly 8 bytes — no padding needed
    assertEquals(8, stringLength("KEEPALIV"))
}

// == Gap 1: Stream-0 frame type validation (RFC 9113 §6.5, §6.7, §6.8) =======

@Test fun testSettingsOnNonZeroStreamRejected() {
    // SETTINGS MUST be on stream 0; non-zero stream should trigger GOAWAY
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "peerSettings", mapCreate())
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "expectContinuation", false)
    // Dispatch SETTINGS on stream 1 — should be rejected before h2HandleSettings
    h2DispatchFrame(conn, H2_SETTINGS(), 0, 1, "")
    // No crash = success (GOAWAY would be sent if fd were valid)
}

@Test fun testPingOnNonZeroStreamRejected() {
    // PING MUST be on stream 0; non-zero stream should trigger GOAWAY
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "expectContinuation", false)
    mapPut(conn, "pingCount", 0)
    h2DispatchFrame(conn, H2_PING(), 0, 1, "12345678")
    // No crash = success
}

@Test fun testGoawayOnNonZeroStreamRejected() {
    // GOAWAY MUST be on stream 0; non-zero stream should trigger GOAWAY
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "expectContinuation", false)
    mapPut(conn, "shuttingDown", false)
    mapPut(conn, "goawayLastStreamId", 0)
    mapPut(conn, "goawayErrorCode", 0)
    mapPut(conn, "error", "")
    h2DispatchFrame(conn, H2_GOAWAY(), 0, 1, h2EncodeUint32(0))
    // GOAWAY should NOT have been processed (shuttingDown should remain false)
    assertFalse(h2IsShuttingDown(conn))
}

@Test fun testSettingsOnStream0Accepted() {
    // SETTINGS on stream 0 should be accepted
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val ps = mapCreate()
    mapPut(ps, "headerTableSize", 4096)
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(ps, "maxFrameSize", 16384)
    mapPut(conn, "peerSettings", ps)
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "settingsState", "UNSENT")
    mapPut(conn, "error", "")
    mapPut(conn, "expectContinuation", false)
    // Empty SETTINGS is valid on stream 0
    h2DispatchFrame(conn, H2_SETTINGS(), 0, 0, "")
    // No error
}

