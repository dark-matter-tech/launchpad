    // Window should remain unchanged
    assertEquals(65535, toInt(mapGet(conn, "connSendWindow")))
}

@Test fun testWindowUpdateTooShortOnStream() {
    // WINDOW_UPDATE with wrong size on non-zero stream -> RST_STREAM
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val streams = mapCreate()
    val stream = mapCreate()
    mapPut(stream, "sendWindow", 65535)
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(streams, "1", stream)
    mapPut(conn, "streams", streams)
    mapPut(conn, "connSendWindow", 65535)
    var shortPayload: String = intToChar(0)
    shortPayload = stringConcat(shortPayload, intToChar(1))
    h2HandleWindowUpdate(conn, 1, shortPayload)
    // Stream window should remain unchanged
    assertEquals(65535, toInt(mapGet(stream, "sendWindow")))
}

