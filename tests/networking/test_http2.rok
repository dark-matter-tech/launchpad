}

@Test fun testH2IsErrorFalse() {
    val resp = mapCreate()
    mapPut(resp, "error", "")
    assertFalse(h2IsError(resp))
}

@Test fun testH2IsErrorNull() {
    val resp = mapCreate()
    assertFalse(h2IsError(resp))
}

@Test fun testH2ErrorMessage() {
    val resp = mapCreate()
    mapPut(resp, "error", "Connection refused")
