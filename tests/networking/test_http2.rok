}

@Test fun testResponseStatusMissing() {
    val resp = mapCreate()
    assertEquals(0, h2ResponseStatus(resp))
}

@Test fun testResponseBody() {
    val resp = mapCreate()
    mapPut(resp, "body", "hello world")
    assertEqualsStr("hello world", h2ResponseBody(resp))
}

@Test fun testResponseBodyMissing() {
    val resp = mapCreate()
    assertEqualsStr("", h2ResponseBody(resp))
}

@Test fun testResponseHeader() {
    val resp = mapCreate()
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", "content-type")
    mapPut(h1, "value", "text/html")
    listAppend(headers, h1)
    mapPut(resp, "headers", headers)
    assertEqualsStr("text/html", h2ResponseHeader(resp, "content-type"))
