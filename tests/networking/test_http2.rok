// == RFC Conformance Gap 3: PUSH_PROMISE on stream 0 ==========================

@Test fun testPushPromiseOnStream0Rejected() {
    // PUSH_PROMISE MUST NOT be on stream 0 (RFC 9113 §6.6)
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "expectContinuation", false)
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", ps)
    val localSettings = mapCreate()
    mapPut(localSettings, "enablePush", 1)
    mapPut(conn, "localSettings", localSettings)
    // Build a valid PUSH_PROMISE payload
    var payload: String = h2EncodeUint32(2)
    payload = stringConcat(payload, "headers")
    // Dispatch on stream 0 — should be rejected
    h2DispatchFrame(conn, H2_PUSH_PROMISE(), H2_FLAG_END_HEADERS(), 0, payload)
    // Stream 2 should NOT have been created
    val streams = mapGet(conn, "streams")
    assertTrue(mapGet(streams, "2") == null)
}

@Test fun testPushPromiseOnNonZeroStreamAccepted() {
    // PUSH_PROMISE on non-zero stream should be accepted
    // Parent stream (1) must exist in OPEN state per RFC 9113 §6.6
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val streams = mapCreate()
    val stream1 = mapCreate()
    mapPut(stream1, "state", H2_STREAM_OPEN())
    mapPut(stream1, "headers", listCreate())
    mapPut(stream1, "body", "")
    mapPut(stream1, "sendWindow", 65535)
    mapPut(stream1, "recvWindow", 65535)
    mapPut(streams, "1", stream1)
    mapPut(conn, "streams", streams)
    mapPut(conn, "expectContinuation", false)
    mapPut(conn, "hpackDecCtx", hpackCreateContext())
    val ps = mapCreate()
    mapPut(ps, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", ps)
    val localSettings = mapCreate()
    mapPut(localSettings, "enablePush", 1)
    mapPut(conn, "localSettings", localSettings)
    val ctx = hpackCreateContext()
    val headerList = listCreate()
    val hdr = mapCreate()
    mapPut(hdr, "name", ":method")
    mapPut(hdr, "value", "GET")
    listAppend(headerList, hdr)
    val headerBlock = hpackEncode(ctx, headerList)
    var payload: String = h2EncodeUint32(2)
    payload = stringConcat(payload, headerBlock)
    h2DispatchFrame(conn, H2_PUSH_PROMISE(), H2_FLAG_END_HEADERS(), 1, payload)
    // Stream 2 should have been created
    val allStreams = mapGet(conn, "streams")
    assertTrue(mapGet(allStreams, "2") != null)
}

// == RFC Conformance Gap 4: Client rejects PUSH_PROMISE when push disabled ====

@Test fun testPushPromiseRejectedWhenPushDisabled() {
