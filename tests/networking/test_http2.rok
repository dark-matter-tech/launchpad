@Test fun testDataOnNonZeroStreamAccepted() {
    // DATA on non-zero stream should be accepted
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "streams", mapCreate())
    mapPut(conn, "expectContinuation", false)
    mapPut(conn, "connRecvWindow", 65535)
    mapPut(conn, "peerSettings", mapCreate())
    val streams = mapGet(conn, "streams")
    val stream = mapCreate()
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(stream, "headers", listCreate())
    mapPut(stream, "body", "")
    mapPut(stream, "recvWindow", 65535)
    mapPut(stream, "sendWindow", 65535)
    mapPut(streams, "1", stream)
    h2DispatchFrame(conn, H2_DATA(), H2_FLAG_END_STREAM(), 1, "hello")
    // Data should have been stored
    assertEqualsStr("hello", toString(mapGet(stream, "body")))
}

// == Gap 3: SETTINGS ACK with non-zero payload ================================

@Test fun testSettingsAckWithPayloadRejected() {
    // SETTINGS ACK with non-zero payload should trigger FRAME_SIZE_ERROR
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "settingsState", "SENT")
    // Build a non-empty payload
    var payload: String = h2EncodeUint16(1)
    payload = stringConcat(payload, h2EncodeUint32(4096))
    // Call with ACK flag and non-empty payload
    h2HandleSettings(conn, H2_FLAG_ACK(), payload)
    // Settings state should NOT have been updated to ACKED
    val state = toString(mapGet(conn, "settingsState"))
    assertEqualsStr("SENT", state)
}

@Test fun testSettingsAckEmptyPayloadAccepted() {
    // SETTINGS ACK with empty payload is valid
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    mapPut(conn, "settingsState", "SENT")
    h2HandleSettings(conn, H2_FLAG_ACK(), "")
    val state = toString(mapGet(conn, "settingsState"))
    assertEqualsStr("ACKED", state)
}

