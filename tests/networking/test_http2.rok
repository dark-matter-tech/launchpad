// == RFC Conformance Gap 6: INITIAL_WINDOW_SIZE delta overflow =================

@Test fun testInitialWindowSizeDeltaOverflow() {
    // If adjusting stream send window by delta exceeds 2^31-1, send GOAWAY
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val peerSettings = mapCreate()
    mapPut(peerSettings, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", peerSettings)
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    // Create a stream with window near max
    val streams = mapCreate()
    val stream = mapCreate()
    mapPut(stream, "sendWindow", 2147483640)
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(streams, "1", stream)
    mapPut(conn, "streams", streams)
    // Change initial window size to a large value that would cause delta overflow
    // delta = newValue - oldInitial = 2147483647 - 65535 = 2147418112
    // adjusted = 2147483640 + 2147418112 > 2^31-1 -> overflow
    var payload: String = h2EncodeUint16(H2_SETTINGS_INITIAL_WINDOW_SIZE())
    payload = stringConcat(payload, h2EncodeUint32(2147483647))
    h2ApplyPeerSettings(conn, payload)
    // Stream window should NOT have been updated (GOAWAY sent)
    assertEquals(2147483640, toInt(mapGet(stream, "sendWindow")))
}

@Test fun testInitialWindowSizeDeltaNoOverflow() {
    // Normal delta that doesn't overflow should work
    val conn = mapCreate()
    mapPut(conn, "fd", 0 - 1)
    val peerSettings = mapCreate()
    mapPut(peerSettings, "initialWindowSize", 65535)
    mapPut(conn, "peerSettings", peerSettings)
    mapPut(conn, "peerMaxFrameSize", H2_DEFAULT_MAX_FRAME_SIZE())
    mapPut(conn, "peerMaxConcurrentStreams", 100)
    val streams = mapCreate()
    val stream = mapCreate()
    mapPut(stream, "sendWindow", 65535)
    mapPut(stream, "state", H2_STREAM_OPEN())
    mapPut(streams, "1", stream)
    mapPut(conn, "streams", streams)
    // delta = 131070 - 65535 = 65535 -> adjusted = 65535 + 65535 = 131070
    var payload: String = h2EncodeUint16(H2_SETTINGS_INITIAL_WINDOW_SIZE())
    payload = stringConcat(payload, h2EncodeUint32(131070))
    h2ApplyPeerSettings(conn, payload)
    assertEquals(131070, toInt(mapGet(stream, "sendWindow")))
}

