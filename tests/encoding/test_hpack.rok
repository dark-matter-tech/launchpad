    buf3 = stringConcat(buf3, hpackByteToChar(6))     // 0x06
    buf3 = stringConcat(buf3, hpackByteToChar(61))    // 0x3d
    buf3 = stringConcat(buf3, hpackByteToChar(80))    // 0x50
    buf3 = stringConcat(buf3, hpackByteToChar(7))     // 0x07
    val headers = hpackDecode(ctx, buf3, stringLength(buf3))
    assertEquals(6, listSize(headers))
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("200", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr("cache-control", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("private", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr("date", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("Mon, 21 Oct 2013 20:13:22 GMT", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr("location", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("https://www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    assertEqualsStr("content-encoding", toString(mapGet(listGet(headers, 4), "name")))
    assertEqualsStr("gzip", toString(mapGet(listGet(headers, 4), "value")))
    assertEqualsStr("set-cookie", toString(mapGet(listGet(headers, 5), "name")))
    assertEqualsStr("foo=ASDJKHQKBZXOQWEOPIUAXQWEOIU; max-age=3600; version=1", toString(mapGet(listGet(headers, 5), "value")))
    // Dynamic table: 3 entries, size = 215
    assertEquals(3, hpackDynamicTableLength(ctx))
    assertEquals(215, hpackDynamicTableSize(ctx))
}

// == Huffman Encoding (Phase 1) ===============================================

@Test fun testHuffmanEncodedLength() {
    // "www.example.com" has known Huffman length from RFC 7541 C.4
    val len = hpackHuffmanEncodedLength("www.example.com")
    assertEquals(12, len)
}

@Test fun testHuffmanRoundtrip() {
    val input = "hello world"
    val encoded = hpackHuffmanEncode(input)
    val decoded = hpackHuffmanDecode(encoded, 0, stringLength(encoded))
    assertEqualsStr(input, decoded)
}

@Test fun testHuffmanShorterThanRaw() {
    // For typical ASCII text, Huffman should be shorter
    val raw = "www.example.com"
    val huffLen = hpackHuffmanEncodedLength(raw)
    assertTrue(huffLen < stringLength(raw))
}

@Test fun testHuffmanEncodeKnownVector() {
    // RFC 7541 C.4.1: "www.example.com" Huffman encodes to 12 bytes
    val encoded = hpackHuffmanEncode("www.example.com")
    assertEquals(12, stringLength(encoded))
}

@Test fun testEncodeStringChoosesHuffman() {
    // hpackEncodeString should use Huffman when shorter
    val encoded = hpackEncodeString("www.example.com")
    val firstByte = charCodeAt(encoded, 0)
    // H bit should be set (>= 128) when Huffman is shorter
    assertTrue(firstByte >= 128)
}

@Test fun testDecodeIntOverflowProtection() {
    // Build a pathological integer with too many continuation bytes
    // 5-bit prefix all 1s = 31, then many 0x80 bytes (continuation with value 0), then 0x01
    var buf: String = hpackByteToChar(31)  // prefix byte: all 5 bits set
    var i: Int = 0
    while (i < 20) {
        buf = stringConcat(buf, hpackByteToChar(128))  // continuation: value 0, more bit set
        i = i + 1
    }
    buf = stringConcat(buf, hpackByteToChar(1))  // final byte
    val result = hpackDecodeInt(buf, 0, 5)
    val value = toInt(mapGet(result, "value"))
    // Value should be clamped, not overflow
    assertTrue(value <= 2147483647)
}

@Test fun testHpackBombProtection() {
    val ctx = hpackCreateContext()
    hpackSetMaxHeaderFieldSize(ctx, 100)
    // Encode a header with value longer than 100 bytes
    var longValue: String = ""
    var i: Int = 0
    while (i < 120) {
        longValue = stringConcat(longValue, "x")
        i = i + 1
    }
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", "x-big")
    mapPut(h, "value", longValue)
    listAppend(headers, h)
    val encCtx = hpackCreateContext()
    val encoded = hpackEncode(encCtx, headers)
    val decoded = hpackDecode(ctx, encoded, stringLength(encoded))
    // Should contain an error entry
    val first = listGet(decoded, 0)
    assertEqualsStr("hpack-error", toString(mapGet(first, "name")))
}

@Test fun testDynamicSizeUpdateAtStart() {
    // Size update at start of block should succeed
    val ctx = hpackCreateContext()
    val encoded = hpackEncodeDynamicSizeUpdate(2048)
    val decoded = hpackDecode(ctx, encoded, stringLength(encoded))
    // No error entries expected - empty list is fine (size update doesn't add headers)
    assertEquals(0, listSize(decoded))
}

@Test fun testDynamicSizeUpdateMidBlock() {
    val ctx = hpackCreateContext()
    // First encode a normal header, then a size update
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", ":method")
    mapPut(h, "value", "GET")
    listAppend(headers, h)
    val encCtx = hpackCreateContext()
    val headerBlock = hpackEncode(encCtx, headers)
    val sizeUpdate = hpackEncodeDynamicSizeUpdate(2048)
    val combined = stringConcat(headerBlock, sizeUpdate)
    val decoded = hpackDecode(ctx, combined, stringLength(combined))
    // Should have the header plus an error entry for the mid-block size update
    var hasError: Bool = false
    var j: Int = 0
    while (j < listSize(decoded)) {
        val entry = listGet(decoded, j)
        if (toString(mapGet(entry, "name")) == "hpack-error") {
            hasError = true
        }
        j = j + 1
    }
    assertTrue(hasError)
}

// == Encoder Optimization (Final) =============================================

@Test fun testEncoderUsesIndexedForExactStaticMatch() {
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", ":method")
    mapPut(h, "value", "GET")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    // :method GET is static index 2 → indexed representation = 0x82
    assertEquals(1, stringLength(encoded))
    assertEquals(130, charCodeAt(encoded, 0))
}

@Test fun testEncoderUsesIndexedForStatus200() {
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", ":status")
    mapPut(h, "value", "200")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    // :status 200 is static index 8 → indexed representation = 0x88
    assertEquals(1, stringLength(encoded))
    assertEquals(136, charCodeAt(encoded, 0))
}

@Test fun testEncoderReusesDynamicTable() {
    val ctx = hpackCreateContext()
    // First request: custom header added to dynamic table
    val headers1 = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", "x-custom")
    mapPut(h1, "value", "test-value")
    listAppend(headers1, h1)
    val encoded1 = hpackEncode(ctx, headers1)
    // Second request: same header should use indexed representation
    val headers2 = listCreate()
    val h2 = mapCreate()
    mapPut(h2, "name", "x-custom")
    mapPut(h2, "value", "test-value")
    listAppend(headers2, h2)
    val encoded2 = hpackEncode(ctx, headers2)
    // Second encoding should be shorter (indexed vs literal)
    assertTrue(stringLength(encoded2) < stringLength(encoded1))
}

@Test fun testEncoderDynamicNameRef() {
    val ctx = hpackCreateContext()
    // First: encode a custom header to add to dynamic table
    val headers1 = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", "x-custom")
    mapPut(h1, "value", "value1")
    listAppend(headers1, h1)
    hpackEncode(ctx, headers1)
    // Second: same name, different value — should use name reference
    val headers2 = listCreate()
    val h2 = mapCreate()
    mapPut(h2, "name", "x-custom")
    mapPut(h2, "value", "value2")
    listAppend(headers2, h2)
    val encoded2 = hpackEncode(ctx, headers2)
    // Should be shorter than encoding with literal name
    // Literal name "x-custom" is 8 bytes + overhead; name ref is 1-2 bytes
    val encCtx2 = hpackCreateContext()
    val encoded2Fresh = hpackEncode(encCtx2, headers2)
    assertTrue(stringLength(encoded2) < stringLength(encoded2Fresh))
}

@Test fun testProtocolMaxSizePreventsOversize() {
    val ctx = hpackCreateContext()
    hpackSetProtocolMaxSize(ctx, 2048)
    // Try to resize beyond protocol max
    hpackDynamicResize(ctx, 8192)
    // Should still be capped at protocol max or less
    val maxSize = toInt(mapGet(ctx, "maxSize"))
    assertTrue(maxSize <= 2048)
}

@Test fun testProtocolMaxSizeAllowsUndersize() {
    val ctx = hpackCreateContext()
    hpackSetProtocolMaxSize(ctx, 4096)
    hpackDynamicResize(ctx, 2048)
    val maxSize = toInt(mapGet(ctx, "maxSize"))
    assertEquals(2048, maxSize)
}

@Test fun testIndexedRoundtripWithDecoder() {
    val encCtx = hpackCreateContext()
    val decCtx = hpackCreateContext()
    val headers = listCreate()
    val h1 = mapCreate()
    mapPut(h1, "name", ":method")
    mapPut(h1, "value", "GET")
    listAppend(headers, h1)
    val h2m = mapCreate()
    mapPut(h2m, "name", ":path")
    mapPut(h2m, "value", "/")
    listAppend(headers, h2m)
    val encoded = hpackEncode(encCtx, headers)
    val decoded = hpackDecode(decCtx, encoded, stringLength(encoded))
    assertEquals(2, listSize(decoded))
    assertEqualsStr(":method", toString(mapGet(listGet(decoded, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(decoded, 0), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(decoded, 1), "name")))
    assertEqualsStr("/", toString(mapGet(listGet(decoded, 1), "value")))
}

// =============================================================================
// == Gap H1: Huffman Padding Validation (RFC 7541 Section 5.2)
// =============================================================================

@Test fun testGapH1_ValidHuffmanPadding() {
    // Huffman encode "a" — the padding bits should be all 1s (EOS prefix)
    val encoded = hpackHuffmanEncode("a")
    // Decoding valid Huffman should return "a", not an error
    val decoded = hpackHuffmanDecode(encoded, 0, stringLength(encoded))
    assertEqualsStr("a", decoded)
}

@Test fun testGapH1_InvalidHuffmanPaddingNotAllOnes() {
    // Construct a Huffman byte sequence where padding is NOT all 1s
    // 'a' has Huffman code 0x18 (00011) = 5 bits
    // Valid encoding: 00011_111 = 0x1F (padding is 111 = all 1s)
    // Invalid: 00011_000 = 0x18 (padding is 000 = not all 1s)
    val invalidBuf = hpackByteToChar(24)  // 0x18 = 00011000
    val decoded = hpackHuffmanDecode(invalidBuf, 0, 1)
    // Should return error sentinel
    assertEqualsStr("hpack-huffman-error", decoded)
}

@Test fun testGapH1_ValidPaddingSingleChar() {
    // Encode "0" (Huffman code = 00000, 5 bits) -> 00000_111 = 0x07
    val encoded = hpackHuffmanEncode("0")
    val decoded = hpackHuffmanDecode(encoded, 0, stringLength(encoded))
    assertEqualsStr("0", decoded)
}

// =============================================================================
// == Gap H2: EOS Symbol Rejection (RFC 7541 Section 5.2)
// =============================================================================

@Test fun testGapH2_EosSymbolProperties() {
    // EOS symbol (256) should have code 0x3FFFFFFF and length 30
    assertEquals(1073741823, hpackHuffmanCode(256))
    assertEquals(30, hpackHuffmanLen(256))
}

// =============================================================================
// == Gap H3: Integer Overflow Signaling (RFC 7541 Section 5.1)
// =============================================================================

@Test fun testGapH3_NormalIntegerNoOverflow() {
    // Encode a small integer — should not overflow
    val encoded = hpackEncodeInt(42, 7, 0)
    val decoded = hpackDecodeInt(encoded, 0, 7)
    assertEquals(42, toInt(mapGet(decoded, "value")))
    assertTrue(mapGet(decoded, "overflow") == false)
}

@Test fun testGapH3_LargeIntegerNoOverflow() {
    // Encode the max prefix value for 5-bit prefix (31)
    val encoded = hpackEncodeInt(31, 5, 0)
    val decoded = hpackDecodeInt(encoded, 0, 5)
    assertEquals(31, toInt(mapGet(decoded, "value")))
    assertTrue(mapGet(decoded, "overflow") == false)
}

@Test fun testGapH3_MultiByteIntegerNoOverflow() {
    // Encode 1337 with 5-bit prefix — multi-byte but no overflow
    val encoded = hpackEncodeInt(1337, 5, 0)
    val decoded = hpackDecodeInt(encoded, 0, 5)
    assertEquals(1337, toInt(mapGet(decoded, "value")))
    assertTrue(mapGet(decoded, "overflow") == false)
}

@Test fun testGapH3_OverflowDetectedInDecode() {
    // Build a deliberately overflowing integer:
    // 5-bit prefix all 1s (31) followed by 6 continuation bytes (each 0xFF)
    // This exceeds 28 bits of continuation, triggering overflow
    var overflowBuf: String = hpackByteToChar(31)   // 0x1F: prefix all 1s
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))  // continuation
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(127))  // last byte (no continuation)
    val decoded = hpackDecodeInt(overflowBuf, 0, 5)
    assertTrue(mapGet(decoded, "overflow") == true)
}

@Test fun testGapH3_OverflowProducesErrorInHpackDecode() {
    // Build an indexed header field with overflowing index
    // Indexed: top bit = 1, 7-bit prefix
    // 0xFF followed by many continuation bytes
    var overflowBuf: String = hpackByteToChar(255)  // 0xFF: indexed, index=127
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(255))
    overflowBuf = stringConcat(overflowBuf, hpackByteToChar(127))
    val ctx = hpackCreateContext()
    val headers = hpackDecode(ctx, overflowBuf, stringLength(overflowBuf))
    // Should contain an error entry
    assertEquals(1, listSize(headers))
    assertEqualsStr("hpack-error", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("integer overflow in indexed header", toString(mapGet(listGet(headers, 0), "value")))
}

// =============================================================================
// == Gap H4: Index 0 Decoding Error (RFC 7541 Section 6.1)
// =============================================================================

@Test fun testGapH4_IndexZeroIsError() {
    // Indexed header field with index 0: byte 0x80 (top bit=1, index=0)
    val zeroBuf = hpackByteToChar(128)  // 0x80: indexed, index=0
    val ctx = hpackCreateContext()
    val headers = hpackDecode(ctx, zeroBuf, 1)
    // Should contain an error entry
    assertEquals(1, listSize(headers))
    assertEqualsStr("hpack-error", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("indexed header field index 0 is invalid", toString(mapGet(listGet(headers, 0), "value")))
}

@Test fun testGapH4_IndexOneIsValid() {
    // Indexed header field with index 1: byte 0x81 (top bit=1, index=1)
    // Index 1 = :authority with empty value
    val oneBuf = hpackByteToChar(129)  // 0x81: indexed, index=1
    val ctx = hpackCreateContext()
    val headers = hpackDecode(ctx, oneBuf, 1)
    assertEquals(1, listSize(headers))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 0), "name")))
}
