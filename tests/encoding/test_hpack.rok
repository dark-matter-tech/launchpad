// Tests for rockit.encoding.hpack
import rockit.testing.probe
import rockit.encoding.hpack

// == Representation Type Constants ============================================

@Test fun testHpackConstants() {
    assertEquals(1, HPACK_INDEXED())
    assertEquals(2, HPACK_LITERAL_INCREMENTAL())
    assertEquals(3, HPACK_LITERAL_NONE())
    assertEquals(4, HPACK_LITERAL_NEVER())
}

// == Static Table =============================================================

@Test fun testStaticTableEntry1() {
    val entry = hpackStaticEntry(1)
    assertEqualsStr(":authority", toString(mapGet(entry, "name")))
    assertEqualsStr("", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry2() {
    val entry = hpackStaticEntry(2)
    assertEqualsStr(":method", toString(mapGet(entry, "name")))
    assertEqualsStr("GET", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry3() {
    val entry = hpackStaticEntry(3)
    assertEqualsStr(":method", toString(mapGet(entry, "name")))
    assertEqualsStr("POST", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry4() {
    val entry = hpackStaticEntry(4)
    assertEqualsStr(":path", toString(mapGet(entry, "name")))
    assertEqualsStr("/", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry5() {
    val entry = hpackStaticEntry(5)
    assertEqualsStr(":path", toString(mapGet(entry, "name")))
    assertEqualsStr("/index.html", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry8() {
    val entry = hpackStaticEntry(8)
    assertEqualsStr(":status", toString(mapGet(entry, "name")))
    assertEqualsStr("200", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry16() {
    val entry = hpackStaticEntry(16)
    assertEqualsStr("accept-encoding", toString(mapGet(entry, "name")))
    assertEqualsStr("gzip, deflate", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry31() {
    val entry = hpackStaticEntry(31)
    assertEqualsStr("content-type", toString(mapGet(entry, "name")))
    assertEqualsStr("", toString(mapGet(entry, "value")))
}

@Test fun testStaticTableEntry58() {
    val entry = hpackStaticEntry(58)
    assertEqualsStr("user-agent", toString(mapGet(entry, "name")))
}

@Test fun testStaticTableEntry61() {
    val entry = hpackStaticEntry(61)
    assertEqualsStr("www-authenticate", toString(mapGet(entry, "name")))
}

// == Static Table Lookup ======================================================

@Test fun testStaticLookupExactMatch() {
    assertEquals(2, hpackStaticLookup(":method", "GET"))
    assertEquals(3, hpackStaticLookup(":method", "POST"))
    assertEquals(4, hpackStaticLookup(":path", "/"))
    assertEquals(8, hpackStaticLookup(":status", "200"))
}

@Test fun testStaticLookupNoMatch() {
    assertEquals(0, hpackStaticLookup("x-custom", "value"))
}

@Test fun testStaticLookupNameOnly() {
    assertEquals(2, hpackStaticLookupName(":method"))
    assertEquals(4, hpackStaticLookupName(":path"))
    assertEquals(1, hpackStaticLookupName(":authority"))
    assertEquals(0, hpackStaticLookupName("x-custom"))
}

// == Integer Encoding/Decoding (RFC 7541 Section 5.1) =========================

@Test fun testEncodeIntSmall() {
    // Value 10 with 5-bit prefix, no high bits
    val encoded = hpackEncodeInt(10, 5, 0)
    assertEquals(1, stringLength(encoded))
    assertEquals(10, charCodeAt(encoded, 0))
}

@Test fun testEncodeIntBoundary() {
    // Value 30 with 5-bit prefix (max prefix = 31, so fits in one byte)
    val encoded = hpackEncodeInt(30, 5, 0)
    assertEquals(1, stringLength(encoded))
    assertEquals(30, charCodeAt(encoded, 0))
}

@Test fun testEncodeIntMultiByte() {
    // Value 50 with 5-bit prefix: exceeds max prefix (31), needs 2 bytes
    // Expected: 31, 19 (50 - 31 = 19, both < 128)
    val encoded = hpackEncodeInt(50, 5, 0)
    assertEquals(2, stringLength(encoded))
    assertEquals(31, charCodeAt(encoded, 0))
    assertEquals(19, charCodeAt(encoded, 1))
}

@Test fun testDecodeIntSmall() {
    val input = intToChar(10)
    val result = hpackDecodeInt(input, 0, 5)
    assertEquals(10, toInt(mapGet(result, "value")))
    assertEquals(1, toInt(mapGet(result, "pos")))
}

@Test fun testDecodeIntMultiByte() {
    // Decode value 50 from bytes [31, 19] (both < 128)
    var input: String = intToChar(31)
    input = stringConcat(input, intToChar(19))
    val result = hpackDecodeInt(input, 0, 5)
    assertEquals(50, toInt(mapGet(result, "value")))
    assertEquals(2, toInt(mapGet(result, "pos")))
}

@Test fun testIntRoundtrip5bit() {
    // Values 0-30 fit in one byte; values 31-158 produce 2-byte encodings
    // with all bytes < 128. Values >= 159 need continuation bytes >= 128
    // which intToChar can't produce (ASCII-only runtime limitation).
    var v: Int = 0
    while (v <= 158) {
        val encoded = hpackEncodeInt(v, 5, 0)
        val decoded = hpackDecodeInt(encoded, 0, 5)
        assertEquals(v, toInt(mapGet(decoded, "value")))
        v = v + 1
    }
}

@Test fun testIntRoundtrip7bit() {
    val encoded = hpackEncodeInt(42, 7, 0)
    val decoded = hpackDecodeInt(encoded, 0, 7)
    assertEquals(42, toInt(mapGet(decoded, "value")))
}

@Test fun testIntWithPrefixBits() {
    // Encode 10 with 5-bit prefix and high bits 0x40 (64)
    // Result byte: 64 + 10 = 74 (< 128, within ASCII range)
    val encoded = hpackEncodeInt(10, 5, 64)
    assertEquals(1, stringLength(encoded))
    assertEquals(74, charCodeAt(encoded, 0))  // 64 + 10
}

// == String Encoding/Decoding =================================================

@Test fun testEncodeStringEmpty() {
    val encoded = hpackEncodeString("")
    assertEquals(1, stringLength(encoded))
    assertEquals(0, charCodeAt(encoded, 0))  // length = 0, H = 0
}

@Test fun testEncodeStringShort() {
    // "hello" Huffman: h=6, e=5, l=6, l=6, o=5 = 28 bits = 4 bytes (< 5 raw)
    // So Huffman is chosen: H=1, length=4 → first byte = 128 + 4 = 132
    val encoded = hpackEncodeString("hello")
    assertEquals(5, stringLength(encoded))
    assertEquals(132, charCodeAt(encoded, 0))  // length = 4, H = 1
}

@Test fun testDecodeStringRaw() {
    // Build: 0x05 "hello"
    var input: String = intToChar(5)
    input = stringConcat(input, "hello")
    val result = hpackDecodeString(input, 0)
    assertEqualsStr("hello", toString(mapGet(result, "value")))
    assertEquals(6, toInt(mapGet(result, "pos")))
}

@Test fun testStringRoundtrip() {
    val original = "content-type"
    val encoded = hpackEncodeString(original)
    val decoded = hpackDecodeString(encoded, 0)
    assertEqualsStr(original, toString(mapGet(decoded, "value")))
}

@Test fun testStringRoundtripEmpty() {
    val encoded = hpackEncodeString("")
    val decoded = hpackDecodeString(encoded, 0)
    assertEqualsStr("", toString(mapGet(decoded, "value")))
}

// == Header Block Encode/Decode ===============================================

@Test fun testEncodeLiteralWithIndexedName() {
    // :authority with custom value uses incremental indexing (non-sensitive)
    // Byte 0: 0x40 | 1 = 0x41 = 65 (incremental indexing, name index 1)
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", ":authority")
    mapPut(h, "value", "example.com")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    assertEquals(65, charCodeAt(encoded, 0))
    assertGreaterThan(stringLength(encoded), 1)
}

@Test fun testEncodeLiteralNewName() {
    // Custom header with no static table match uses literal with incremental indexing
    // Byte 0: 0x40 = 64 (incremental indexing, name index 0 = new name)
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", "x-custom")
    mapPut(h, "value", "test")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    assertEquals(64, charCodeAt(encoded, 0))
    assertGreaterThan(stringLength(encoded), 1)
}

@Test fun testEncodeLiteralWithNameRef() {
    // :authority with custom value - name is in static table (index 1)
    // Non-sensitive → incremental indexing: 0x40 | 1 = 65
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", ":authority")
    mapPut(h, "value", "example.com")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    assertEquals(65, charCodeAt(encoded, 0))
    assertGreaterThan(stringLength(encoded), 1)
}

@Test fun testHeaderBlockRoundtrip() {
    // Use literal-only headers (no exact static match → avoids indexed bytes >= 128)
    val encCtx = hpackCreateContext()
    val decCtx = hpackCreateContext()
    val headers = listCreate()

    val h1 = mapCreate()
    mapPut(h1, "name", ":authority")
    mapPut(h1, "value", "example.com")
    listAppend(headers, h1)

    val h2 = mapCreate()
    mapPut(h2, "name", "x-request-id")
    mapPut(h2, "value", "abc123")
    listAppend(headers, h2)

    val encoded = hpackEncode(encCtx, headers)
    val decoded = hpackDecode(decCtx, encoded, stringLength(encoded))

    assertEquals(2, listSize(decoded))
    val d1 = listGet(decoded, 0)
    assertEqualsStr(":authority", toString(mapGet(d1, "name")))
    assertEqualsStr("example.com", toString(mapGet(d1, "value")))
    val d2 = listGet(decoded, 1)
    assertEqualsStr("x-request-id", toString(mapGet(d2, "name")))
    assertEqualsStr("abc123", toString(mapGet(d2, "value")))
}

@Test fun testHeaderBlockCustomHeaders() {
    val encCtx = hpackCreateContext()
    val decCtx = hpackCreateContext()
    val headers = listCreate()

    val h1 = mapCreate()
    mapPut(h1, "name", "x-custom")
    mapPut(h1, "value", "test-value")
    listAppend(headers, h1)

    val encoded = hpackEncode(encCtx, headers)
    val decoded = hpackDecode(decCtx, encoded, stringLength(encoded))

    assertEquals(1, listSize(decoded))
    val d1 = listGet(decoded, 0)
    assertEqualsStr("x-custom", toString(mapGet(d1, "name")))
    assertEqualsStr("test-value", toString(mapGet(d1, "value")))
}

@Test fun testHeaderBlockMultipleHeaders() {
    // Use literal-only headers to avoid indexed encoding (bytes >= 128)
    // :authority and :path with non-default values use literal with name index
    // Custom headers use literal with new name — all bytes < 128
    val encCtx = hpackCreateContext()
    val decCtx = hpackCreateContext()
    val headers = listCreate()

    val h1 = mapCreate()
    mapPut(h1, "name", ":authority")
    mapPut(h1, "value", "localhost")
    listAppend(headers, h1)

    val h2 = mapCreate()
    mapPut(h2, "name", ":path")
    mapPut(h2, "value", "/api")
    listAppend(headers, h2)

    val h3 = mapCreate()
    mapPut(h3, "name", "x-custom")
    mapPut(h3, "value", "value1")
    listAppend(headers, h3)

    val h4 = mapCreate()
    mapPut(h4, "name", "x-trace-id")
    mapPut(h4, "value", "abc")
    listAppend(headers, h4)

    val encoded = hpackEncode(encCtx, headers)
    val decoded = hpackDecode(decCtx, encoded, stringLength(encoded))

    assertEquals(4, listSize(decoded))
    assertEqualsStr(":authority", toString(mapGet(listGet(decoded, 0), "name")))
    assertEqualsStr("localhost", toString(mapGet(listGet(decoded, 0), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(decoded, 1), "name")))
    assertEqualsStr("/api", toString(mapGet(listGet(decoded, 1), "value")))
    assertEqualsStr("x-custom", toString(mapGet(listGet(decoded, 2), "name")))
    assertEqualsStr("value1", toString(mapGet(listGet(decoded, 2), "value")))
    assertEqualsStr("x-trace-id", toString(mapGet(listGet(decoded, 3), "name")))
    assertEqualsStr("abc", toString(mapGet(listGet(decoded, 3), "value")))
}

// == Dynamic Table ============================================================

@Test fun testDynamicTableAdd() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "custom-header", "custom-value")
    assertEquals(1, hpackDynamicTableLength(ctx))
    // Size = len("custom-header") + len("custom-value") + 32 = 13 + 12 + 32 = 57
    assertEquals(57, hpackDynamicTableSize(ctx))
}

@Test fun testDynamicTableMultipleEntries() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "name1", "val1")
    hpackDynamicAdd(ctx, "name2", "val2")
    hpackDynamicAdd(ctx, "name3", "val3")
    assertEquals(3, hpackDynamicTableLength(ctx))
    // Each: 5 + 4 + 32 = 41, total = 123
    assertEquals(123, hpackDynamicTableSize(ctx))
}

@Test fun testDynamicTableEviction() {
    val ctx = hpackCreateContext()
    // Set max to 100 bytes — room for 2 entries of size 41 (82) but not 3 (123)
    hpackDynamicResize(ctx, 100)
    hpackDynamicAdd(ctx, "name1", "val1")
    hpackDynamicAdd(ctx, "name2", "val2")
    assertEquals(2, hpackDynamicTableLength(ctx))
    // Adding a third should evict the oldest
    hpackDynamicAdd(ctx, "name3", "val3")
    assertEquals(2, hpackDynamicTableLength(ctx))
    // Remaining: name3 (newest at idx 0) and name2 (idx 1); name1 evicted
    assertEquals(82, hpackDynamicTableSize(ctx))
}

@Test fun testDynamicTableResizeToZero() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "name1", "val1")
    hpackDynamicAdd(ctx, "name2", "val2")
    assertEquals(2, hpackDynamicTableLength(ctx))
    hpackDynamicResize(ctx, 0)
    assertEquals(0, hpackDynamicTableLength(ctx))
    assertEquals(0, hpackDynamicTableSize(ctx))
}

@Test fun testDynamicTableResize() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "name1", "val1")  // 41
    hpackDynamicAdd(ctx, "name2", "val2")  // 41
    hpackDynamicAdd(ctx, "name3", "val3")  // 41, total = 123
    assertEquals(3, hpackDynamicTableLength(ctx))
    // Resize to 50: only room for 1 entry
    hpackDynamicResize(ctx, 50)
    assertEquals(1, hpackDynamicTableLength(ctx))
    assertEquals(41, hpackDynamicTableSize(ctx))
}

@Test fun testDynamicTableSizeCalculation() {
    val ctx = hpackCreateContext()
    // RFC 7541 Section 4.1: entry size = name bytes + value bytes + 32
    hpackDynamicAdd(ctx, "content-type", "text/html")
    // 12 + 9 + 32 = 53
    assertEquals(53, hpackDynamicTableSize(ctx))
}

@Test fun testHpackLookupStatic() {
    val ctx = hpackCreateContext()
    val entry = hpackLookup(ctx, 2)
    assertEqualsStr(":method", toString(mapGet(entry, "name")))
    assertEqualsStr("GET", toString(mapGet(entry, "value")))
}

@Test fun testHpackLookupDynamic() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "x-test", "hello")
    // Dynamic index 62 = newest entry
    val entry = hpackLookup(ctx, 62)
    assertEqualsStr("x-test", toString(mapGet(entry, "name")))
    assertEqualsStr("hello", toString(mapGet(entry, "value")))
}

@Test fun testHpackLookupDynamicMultiple() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "first", "aaa")
    hpackDynamicAdd(ctx, "second", "bbb")
    // Index 62 = newest (second), 63 = oldest (first)
    val e62 = hpackLookup(ctx, 62)
    assertEqualsStr("second", toString(mapGet(e62, "name")))
    val e63 = hpackLookup(ctx, 63)
    assertEqualsStr("first", toString(mapGet(e63, "name")))
}

@Test fun testDecoderIncrementalIndexing() {
    // Build a header block using incremental indexing (0x40 prefix)
    // 0x40 | nameIdx (6-bit prefix) + encoded value
    // :authority (index 1): 0x41 = 65, then string "test.com"
    val ctx = hpackCreateContext()
    var block: String = intToChar(65)  // 0x40 | 1 = literal incremental, name idx 1
    block = stringConcat(block, hpackEncodeString("test.com"))
    val headers = hpackDecode(ctx, block, stringLength(block))
    assertEquals(1, listSize(headers))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("test.com", toString(mapGet(listGet(headers, 0), "value")))
    // Should be added to dynamic table
    assertEquals(1, hpackDynamicTableLength(ctx))
    val dynEntry = hpackLookup(ctx, 62)
    assertEqualsStr(":authority", toString(mapGet(dynEntry, "name")))
    assertEqualsStr("test.com", toString(mapGet(dynEntry, "value")))
}

// == Encoder Enhancement ======================================================

@Test fun testEncoderSensitiveHeaders() {
    // Sensitive headers use never-indexed encoding (0x10 prefix)
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", "authorization")
    mapPut(h, "value", "Bearer token123")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    // authorization is static index 23, so: 0x10 | prefix = hpackEncodeInt(23, 4, 16)
    // 23 fits in 4 bits (max 15), so needs multi-byte: first byte = 16+15 = 31
    assertEquals(31, charCodeAt(encoded, 0))
    // Should NOT be added to dynamic table
    assertEquals(0, hpackDynamicTableLength(ctx))
}

@Test fun testEncoderSensitiveCookie() {
    assertTrue(hpackIsSensitive("authorization"))
    assertTrue(hpackIsSensitive("cookie"))
    assertTrue(hpackIsSensitive("set-cookie"))
    assertTrue(hpackIsSensitive("proxy-authorization"))
    assertFalse(hpackIsSensitive("content-type"))
    assertFalse(hpackIsSensitive(":authority"))
}

@Test fun testEncoderIncrementalIndexing() {
    // Non-sensitive header with static name match uses incremental indexing
    val ctx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", "content-type")
    mapPut(h, "value", "text/html")
    listAppend(headers, h)
    val encoded = hpackEncode(ctx, headers)
    // content-type is static index 31: 0x40 | 31 = 95
    assertEquals(95, charCodeAt(encoded, 0))
    // Should be added to encoder's dynamic table
    assertEquals(1, hpackDynamicTableLength(ctx))
}

@Test fun testEncoderDynamicSizeUpdate() {
    // Dynamic table size update: 001xxxxx prefix
    val encoded = hpackEncodeDynamicSizeUpdate(0)
    assertEquals(1, stringLength(encoded))
    assertEquals(32, charCodeAt(encoded, 0))  // 0x20 = 32 (001 00000)

    val encoded2 = hpackEncodeDynamicSizeUpdate(30)
    assertEquals(1, stringLength(encoded2))
    assertEquals(62, charCodeAt(encoded2, 0))  // 32 + 30 = 62
}

@Test fun testEncoderDecoderRoundtripWithDynamic() {
    // Encode with incremental indexing, decode should populate dynamic table
    val encCtx = hpackCreateContext()
    val decCtx = hpackCreateContext()
    val headers = listCreate()
    val h = mapCreate()
    mapPut(h, "name", "content-type")
    mapPut(h, "value", "application/json")
    listAppend(headers, h)
    val encoded = hpackEncode(encCtx, headers)
    val decoded = hpackDecode(decCtx, encoded, stringLength(encoded))
    assertEquals(1, listSize(decoded))
    assertEqualsStr("content-type", toString(mapGet(listGet(decoded, 0), "name")))
    assertEqualsStr("application/json", toString(mapGet(listGet(decoded, 0), "value")))
    // Both encoder and decoder should have the entry in dynamic table
    assertEquals(1, hpackDynamicTableLength(encCtx))
    assertEquals(1, hpackDynamicTableLength(decCtx))
}

@Test fun testDecoderSizeUpdate() {
    val ctx = hpackCreateContext()
    hpackDynamicAdd(ctx, "name1", "val1")
    hpackDynamicAdd(ctx, "name2", "val2")
    assertEquals(2, hpackDynamicTableLength(ctx))
    // Build a size update to 0 (001 prefix, 5-bit): 0x20 = 32
    var block: String = intToChar(32)  // size update to 0
    val headers = hpackDecode(ctx, block, stringLength(block))
    assertEquals(0, listSize(headers))
    assertEquals(0, hpackDynamicTableLength(ctx))
}

// == Helpers ==================================================================

@Test fun testHpackPow2() {
    assertEquals(1, hpackPow2(0))
    assertEquals(2, hpackPow2(1))
    assertEquals(4, hpackPow2(2))
    assertEquals(8, hpackPow2(3))
    assertEquals(128, hpackPow2(7))
    assertEquals(256, hpackPow2(8))
}

@Test fun testHpackAnd() {
    assertEquals(0, hpackAnd(0, 0))
    assertEquals(0, hpackAnd(255, 0))
    assertEquals(255, hpackAnd(255, 255))
    assertEquals(31, hpackAnd(255, 31))
    assertEquals(127, hpackAnd(255, 127))
}

// == RFC 7541 Appendix C — Test Vectors =======================================

// -- C.1: Integer Encoding Examples -------------------------------------------

@Test fun testRfcC1_1_Encode10With5BitPrefix() {
    // C.1.1: Encode 10 with 5-bit prefix → 0x0a
    val encoded = hpackEncodeInt(10, 5, 0)
    assertEquals(1, stringLength(encoded))
    assertEquals(10, charCodeAt(encoded, 0))
}

@Test fun testRfcC1_2_Encode1337With5BitPrefix() {
    // C.1.2: Encode 1337 with 5-bit prefix → 0x1f 0x9a 0x0a
    val encoded = hpackEncodeInt(1337, 5, 0)
    assertEquals(3, stringLength(encoded))
    assertEquals(31, charCodeAt(encoded, 0))   // 0x1f
    assertEquals(154, charCodeAt(encoded, 1))  // 0x9a
    assertEquals(10, charCodeAt(encoded, 2))   // 0x0a
}

@Test fun testRfcC1_3_Encode42With8BitPrefix() {
    // C.1.3: Encode 42 with 8-bit prefix → 0x2a
    val encoded = hpackEncodeInt(42, 8, 0)
    assertEquals(1, stringLength(encoded))
    assertEquals(42, charCodeAt(encoded, 0))  // 0x2a
}

// -- C.2: Header Field Representations (Decoder Tests) ------------------------

@Test fun testRfcC2_1_LiteralWithIndexing() {
    // C.2.1: Literal Header Field with Incremental Indexing
    // custom-key: custom-header
    // Hex: 40 0a 63 75 73 74 6f 6d 2d 6b 65 79
    //      0d 63 75 73 74 6f 6d 2d 68 65 61 64 65 72
    val ctx = hpackCreateContext()
    var buf: String = hpackByteToChar(64)   // 0x40
    buf = stringConcat(buf, hpackByteToChar(10))  // 0x0a name length
    buf = stringConcat(buf, "custom-key")
    buf = stringConcat(buf, hpackByteToChar(13))  // 0x0d value length
    buf = stringConcat(buf, "custom-header")
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(1, listSize(headers))
    assertEqualsStr("custom-key", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("custom-header", toString(mapGet(listGet(headers, 0), "value")))
    // Dynamic table should be updated
    assertEquals(1, hpackDynamicTableLength(ctx))
    assertEquals(55, hpackDynamicTableSize(ctx))  // 10 + 13 + 32 = 55
}

@Test fun testRfcC2_2_LiteralWithoutIndexing() {
    // C.2.2: Literal Header Field without Indexing
    // :path: /sample/path
    // Hex: 04 0c 2f 73 61 6d 70 6c 65 2f 70 61 74 68
    val ctx = hpackCreateContext()
    var buf: String = hpackByteToChar(4)    // 0x04 = without indexing, name index 4
    buf = stringConcat(buf, hpackByteToChar(12))  // 0x0c value length
    buf = stringConcat(buf, "/sample/path")
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(1, listSize(headers))
    assertEqualsStr(":path", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("/sample/path", toString(mapGet(listGet(headers, 0), "value")))
    // Dynamic table NOT updated
    assertEquals(0, hpackDynamicTableLength(ctx))
}

@Test fun testRfcC2_3_LiteralNeverIndexed() {
    // C.2.3: Literal Header Field Never Indexed
    // password: secret
    // Hex: 10 08 70 61 73 73 77 6f 72 64 06 73 65 63 72 65 74
    val ctx = hpackCreateContext()
    var buf: String = hpackByteToChar(16)   // 0x10 = never indexed, name index 0
    buf = stringConcat(buf, hpackByteToChar(8))   // 0x08 name length
    buf = stringConcat(buf, "password")
    buf = stringConcat(buf, hpackByteToChar(6))   // 0x06 value length
    buf = stringConcat(buf, "secret")
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(1, listSize(headers))
    assertEqualsStr("password", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("secret", toString(mapGet(listGet(headers, 0), "value")))
    // Dynamic table NOT updated
    assertEquals(0, hpackDynamicTableLength(ctx))
}

@Test fun testRfcC2_4_IndexedHeaderField() {
    // C.2.4: Indexed Header Field
    // :method: GET → index 2 → 0x82
    val ctx = hpackCreateContext()
    var buf: String = hpackByteToChar(130)  // 0x82
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(1, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
}

// -- C.3: Request Examples without Huffman Coding (Decoder Tests) -------------

@Test fun testRfcC3_1_FirstRequest() {
    // C.3.1: First Request
    // :method: GET, :scheme: http, :path: /, :authority: www.example.com
    // Hex: 82 86 84 41 0f 77 77 77 2e 65 78 61 6d 70 6c 65 2e 63 6f 6d
    val ctx = hpackCreateContext()
    var buf: String = hpackByteToChar(130)  // 0x82 :method GET
    buf = stringConcat(buf, hpackByteToChar(134))  // 0x86 :scheme http
    buf = stringConcat(buf, hpackByteToChar(132))  // 0x84 :path /
    buf = stringConcat(buf, hpackByteToChar(65))   // 0x41 incremental, name idx 1
    buf = stringConcat(buf, hpackByteToChar(15))   // 0x0f value length
    buf = stringConcat(buf, "www.example.com")
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(4, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr(":scheme", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("http", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("/", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    // Dynamic table: 1 entry (:authority: www.example.com), size = 57
    assertEquals(1, hpackDynamicTableLength(ctx))
    assertEquals(57, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC3_2_SecondRequest() {
    // C.3.2: Second Request (same context as C.3.1)
    // First, replay C.3.1 to populate context
    val ctx = hpackCreateContext()
    var buf1: String = hpackByteToChar(130)
    buf1 = stringConcat(buf1, hpackByteToChar(134))
    buf1 = stringConcat(buf1, hpackByteToChar(132))
    buf1 = stringConcat(buf1, hpackByteToChar(65))
    buf1 = stringConcat(buf1, hpackByteToChar(15))
    buf1 = stringConcat(buf1, "www.example.com")
    hpackDecode(ctx, buf1, stringLength(buf1))

    // Second request: :method GET, :scheme http, :path /,
    //   :authority www.example.com (from dynamic), cache-control: no-cache
    // Hex: 82 86 84 be 58 08 6e 6f 2d 63 61 63 68 65
    var buf2: String = hpackByteToChar(130)  // 0x82 :method GET
    buf2 = stringConcat(buf2, hpackByteToChar(134))  // 0x86 :scheme http
    buf2 = stringConcat(buf2, hpackByteToChar(132))  // 0x84 :path /
    buf2 = stringConcat(buf2, hpackByteToChar(190))  // 0xbe dynamic idx 62
    buf2 = stringConcat(buf2, hpackByteToChar(88))   // 0x58 incremental, name idx 24
    buf2 = stringConcat(buf2, hpackByteToChar(8))    // 0x08 value length
    buf2 = stringConcat(buf2, "no-cache")
    val headers = hpackDecode(ctx, buf2, stringLength(buf2))
    assertEquals(5, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    assertEqualsStr("cache-control", toString(mapGet(listGet(headers, 4), "name")))
    assertEqualsStr("no-cache", toString(mapGet(listGet(headers, 4), "value")))
    // Dynamic table: 2 entries, size = 110
    assertEquals(2, hpackDynamicTableLength(ctx))
    assertEquals(110, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC3_3_ThirdRequest() {
    // C.3.3: Third Request (same context as C.3.1 + C.3.2)
    val ctx = hpackCreateContext()
    // Replay C.3.1
    var buf1: String = hpackByteToChar(130)
    buf1 = stringConcat(buf1, hpackByteToChar(134))
    buf1 = stringConcat(buf1, hpackByteToChar(132))
    buf1 = stringConcat(buf1, hpackByteToChar(65))
    buf1 = stringConcat(buf1, hpackByteToChar(15))
    buf1 = stringConcat(buf1, "www.example.com")
    hpackDecode(ctx, buf1, stringLength(buf1))
    // Replay C.3.2
    var buf2: String = hpackByteToChar(130)
    buf2 = stringConcat(buf2, hpackByteToChar(134))
    buf2 = stringConcat(buf2, hpackByteToChar(132))
    buf2 = stringConcat(buf2, hpackByteToChar(190))
    buf2 = stringConcat(buf2, hpackByteToChar(88))
    buf2 = stringConcat(buf2, hpackByteToChar(8))
    buf2 = stringConcat(buf2, "no-cache")
    hpackDecode(ctx, buf2, stringLength(buf2))

    // Third request:
    // Hex: 82 87 85 bf 40 0a 63 75 73 74 6f 6d 2d 6b 65 79
    //      0c 63 75 73 74 6f 6d 2d 76 61 6c 75 65
    var buf3: String = hpackByteToChar(130)  // 0x82 :method GET
    buf3 = stringConcat(buf3, hpackByteToChar(135))  // 0x87 :scheme https
    buf3 = stringConcat(buf3, hpackByteToChar(133))  // 0x85 :path /index.html
    buf3 = stringConcat(buf3, hpackByteToChar(191))  // 0xbf dynamic idx 63
    buf3 = stringConcat(buf3, hpackByteToChar(64))   // 0x40 incremental, new name
    buf3 = stringConcat(buf3, hpackByteToChar(10))   // 0x0a name length
    buf3 = stringConcat(buf3, "custom-key")
    buf3 = stringConcat(buf3, hpackByteToChar(12))   // 0x0c value length
    buf3 = stringConcat(buf3, "custom-value")
    val headers = hpackDecode(ctx, buf3, stringLength(buf3))
    assertEquals(5, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr(":scheme", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("https", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("/index.html", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr("custom-key", toString(mapGet(listGet(headers, 4), "name")))
    assertEqualsStr("custom-value", toString(mapGet(listGet(headers, 4), "value")))
    // Dynamic table: 3 entries, size = 164
    assertEquals(3, hpackDynamicTableLength(ctx))
    assertEquals(164, hpackDynamicTableSize(ctx))
}

// -- C.5: Response Examples without Huffman Coding (Decoder Tests) ------------

@Test fun testRfcC5_1_FirstResponse() {
    // C.5.1: First Response (max table size = 256)
    // :status 302, cache-control private, date Mon 21 Oct..., location https://www.example.com
    // Hex: 48 03 33 30 32 58 07 70 72 69 76 61 74 65 61 1d
    //      4d 6f 6e 2c 20 32 31 20 4f 63 74 20 32 30 31 33
    //      20 32 30 3a 31 33 3a 32 31 20 47 4d 54 6e 17 68
    //      74 74 70 73 3a 2f 2f 77 77 77 2e 65 78 61 6d 70
    //      6c 65 2e 63 6f 6d
    val ctx = hpackCreateContext()
    hpackDynamicResize(ctx, 256)
    var buf: String = hpackByteToChar(72)   // 0x48 incremental, name idx 8
    buf = stringConcat(buf, hpackByteToChar(3))    // value length 3
    buf = stringConcat(buf, "302")
    buf = stringConcat(buf, hpackByteToChar(88))   // 0x58 incremental, name idx 24
    buf = stringConcat(buf, hpackByteToChar(7))    // value length 7
    buf = stringConcat(buf, "private")
    buf = stringConcat(buf, hpackByteToChar(97))   // 0x61 incremental, name idx 33
    buf = stringConcat(buf, hpackByteToChar(29))   // value length 29
    buf = stringConcat(buf, "Mon, 21 Oct 2013 20:13:21 GMT")
    buf = stringConcat(buf, hpackByteToChar(110))  // 0x6e incremental, name idx 46
    buf = stringConcat(buf, hpackByteToChar(23))   // value length 23
    buf = stringConcat(buf, "https://www.example.com")
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(4, listSize(headers))
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("302", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr("cache-control", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("private", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr("date", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("Mon, 21 Oct 2013 20:13:21 GMT", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr("location", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("https://www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    // Dynamic table: 4 entries, size = 222
    assertEquals(4, hpackDynamicTableLength(ctx))
    assertEquals(222, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC5_2_SecondResponse() {
    // C.5.2: Second Response (same context, table size 256)
    val ctx = hpackCreateContext()
    hpackDynamicResize(ctx, 256)
    // Replay C.5.1
    var buf1: String = hpackByteToChar(72)
    buf1 = stringConcat(buf1, hpackByteToChar(3))
    buf1 = stringConcat(buf1, "302")
    buf1 = stringConcat(buf1, hpackByteToChar(88))
    buf1 = stringConcat(buf1, hpackByteToChar(7))
    buf1 = stringConcat(buf1, "private")
    buf1 = stringConcat(buf1, hpackByteToChar(97))
    buf1 = stringConcat(buf1, hpackByteToChar(29))
    buf1 = stringConcat(buf1, "Mon, 21 Oct 2013 20:13:21 GMT")
    buf1 = stringConcat(buf1, hpackByteToChar(110))
    buf1 = stringConcat(buf1, hpackByteToChar(23))
    buf1 = stringConcat(buf1, "https://www.example.com")
    hpackDecode(ctx, buf1, stringLength(buf1))

    // Second response: :status 307, cache-control private, date ..., location ...
    // Hex: 48 03 33 30 37 c1 c0 bf
    var buf2: String = hpackByteToChar(72)   // 0x48 incremental, name idx 8
    buf2 = stringConcat(buf2, hpackByteToChar(3))    // value length 3
    buf2 = stringConcat(buf2, "307")
    buf2 = stringConcat(buf2, hpackByteToChar(193))  // 0xc1 indexed dynamic 62+1=63
    buf2 = stringConcat(buf2, hpackByteToChar(192))  // 0xc0 indexed dynamic 62+0=62
    buf2 = stringConcat(buf2, hpackByteToChar(191))  // 0xbf indexed dynamic 62-1... wait
    val headers = hpackDecode(ctx, buf2, stringLength(buf2))
    assertEquals(4, listSize(headers))
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("307", toString(mapGet(listGet(headers, 0), "value")))
    // Dynamic table: 4 entries, size = 222
    assertEquals(4, hpackDynamicTableLength(ctx))
    assertEquals(222, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC5_3_ThirdResponse() {
    // C.5.3: Third Response (same context, table size 256)
    val ctx = hpackCreateContext()
    hpackDynamicResize(ctx, 256)
    // Replay C.5.1
    var buf1: String = hpackByteToChar(72)
    buf1 = stringConcat(buf1, hpackByteToChar(3))
    buf1 = stringConcat(buf1, "302")
    buf1 = stringConcat(buf1, hpackByteToChar(88))
    buf1 = stringConcat(buf1, hpackByteToChar(7))
    buf1 = stringConcat(buf1, "private")
    buf1 = stringConcat(buf1, hpackByteToChar(97))
    buf1 = stringConcat(buf1, hpackByteToChar(29))
    buf1 = stringConcat(buf1, "Mon, 21 Oct 2013 20:13:21 GMT")
    buf1 = stringConcat(buf1, hpackByteToChar(110))
    buf1 = stringConcat(buf1, hpackByteToChar(23))
    buf1 = stringConcat(buf1, "https://www.example.com")
    hpackDecode(ctx, buf1, stringLength(buf1))
    // Replay C.5.2
    var buf2: String = hpackByteToChar(72)
    buf2 = stringConcat(buf2, hpackByteToChar(3))
    buf2 = stringConcat(buf2, "307")
    buf2 = stringConcat(buf2, hpackByteToChar(193))
    buf2 = stringConcat(buf2, hpackByteToChar(192))
    buf2 = stringConcat(buf2, hpackByteToChar(191))
    hpackDecode(ctx, buf2, stringLength(buf2))

    // Third response: :status 200, cache-control private, date ...,
    //   location https://www.example.com, content-encoding gzip,
    //   set-cookie foo=ASDJKHQKBZXOQWEOPIUAXQWEOIU; ...
    // Hex: 88 c1 61 1d 4d 6f 6e 2c 20 32 31 20 4f 63 74 20
    //      32 30 31 33 20 32 30 3a 31 33 3a 32 32 20 47 4d
    //      54 c0 5a 04 67 7a 69 70 77 38 66 6f 6f 3d 41 53
    //      44 4a 4b 48 51 4b 42 5a 58 4f 51 57 45 4f 50 49
    //      55 41 58 51 57 45 4f 49 55 3b 20 6d 61 78 2d 61
    //      67 65 3d 33 36 30 30 3b 20 76 65 72 73 69 6f 6e
    //      3d 31
    var buf3: String = hpackByteToChar(136)  // 0x88 indexed static 8 (:status 200)
    buf3 = stringConcat(buf3, hpackByteToChar(193))  // 0xc1 indexed dynamic
    buf3 = stringConcat(buf3, hpackByteToChar(97))   // 0x61 incremental, name idx 33
    buf3 = stringConcat(buf3, hpackByteToChar(29))   // value length 29
    buf3 = stringConcat(buf3, "Mon, 21 Oct 2013 20:13:22 GMT")
    buf3 = stringConcat(buf3, hpackByteToChar(192))  // 0xc0 indexed dynamic
    buf3 = stringConcat(buf3, hpackByteToChar(90))   // 0x5a incremental, name idx 26
    buf3 = stringConcat(buf3, hpackByteToChar(4))    // value length 4
    buf3 = stringConcat(buf3, "gzip")
    buf3 = stringConcat(buf3, hpackByteToChar(119))  // 0x77 incremental, name idx 55
    buf3 = stringConcat(buf3, hpackByteToChar(56))   // value length 56
    buf3 = stringConcat(buf3, "foo=ASDJKHQKBZXOQWEOPIUAXQWEOIU; max-age=3600; version=1")
    val headers = hpackDecode(ctx, buf3, stringLength(buf3))
    assertEquals(6, listSize(headers))
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("200", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr("content-encoding", toString(mapGet(listGet(headers, 4), "name")))
    assertEqualsStr("gzip", toString(mapGet(listGet(headers, 4), "value")))
    assertEqualsStr("set-cookie", toString(mapGet(listGet(headers, 5), "name")))
    // Dynamic table: 3 entries (eviction occurred), size = 215
    assertEquals(3, hpackDynamicTableLength(ctx))
    assertEquals(215, hpackDynamicTableSize(ctx))
}

// -- Extended Integer Roundtrip with hpackByteToChar --------------------------

@Test fun testIntRoundtripExtended() {
    // Now that hpackByteToChar exists, test values beyond 158
    // which require continuation bytes > 127
    var v: Int = 0
    while (v <= 2000) {
        val encoded = hpackEncodeInt(v, 5, 0)
        val decoded = hpackDecodeInt(encoded, 0, 5)
        assertEquals(v, toInt(mapGet(decoded, "value")))
        v = v + 50
    }
}

// == RFC 7541 Appendix C.4 — Request Examples with Huffman Coding =============

@Test fun testRfcC4_1_FirstRequestHuffman() {
    // C.4.1: :method GET, :scheme http, :path /, :authority www.example.com
    // Hex: 82 86 84 41 8c f1 e3 c2 e5 f2 3a 6b a0 ab 90 f4 ff
    val ctx = hpackCreateContext()
    var buf: String = hpackByteToChar(130)  // 0x82 :method GET
    buf = stringConcat(buf, hpackByteToChar(134))  // 0x86 :scheme http
    buf = stringConcat(buf, hpackByteToChar(132))  // 0x84 :path /
    buf = stringConcat(buf, hpackByteToChar(65))   // 0x41 incremental, name idx 1
    buf = stringConcat(buf, hpackByteToChar(140))  // 0x8c H=1, len=12
    buf = stringConcat(buf, hpackByteToChar(241))  // 0xf1
    buf = stringConcat(buf, hpackByteToChar(227))  // 0xe3
    buf = stringConcat(buf, hpackByteToChar(194))  // 0xc2
    buf = stringConcat(buf, hpackByteToChar(229))  // 0xe5
    buf = stringConcat(buf, hpackByteToChar(242))  // 0xf2
    buf = stringConcat(buf, hpackByteToChar(58))   // 0x3a
    buf = stringConcat(buf, hpackByteToChar(107))  // 0x6b
    buf = stringConcat(buf, hpackByteToChar(160))  // 0xa0
    buf = stringConcat(buf, hpackByteToChar(171))  // 0xab
    buf = stringConcat(buf, hpackByteToChar(144))  // 0x90
    buf = stringConcat(buf, hpackByteToChar(244))  // 0xf4
    buf = stringConcat(buf, hpackByteToChar(255))  // 0xff
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(4, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr(":scheme", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("http", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("/", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    // Dynamic table: 1 entry (:authority: www.example.com), size = 57
    assertEquals(1, hpackDynamicTableLength(ctx))
    assertEquals(57, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC4_2_SecondRequestHuffman() {
    // Replay C.4.1, then decode C.4.2
    // C.4.2 Hex: 82 86 84 be 58 86 a8 eb 10 64 9c bf
    val ctx = hpackCreateContext()
    // Replay C.4.1
    var buf1: String = hpackByteToChar(130)
    buf1 = stringConcat(buf1, hpackByteToChar(134))
    buf1 = stringConcat(buf1, hpackByteToChar(132))
    buf1 = stringConcat(buf1, hpackByteToChar(65))
    buf1 = stringConcat(buf1, hpackByteToChar(140))  // 0x8c
    buf1 = stringConcat(buf1, hpackByteToChar(241))
    buf1 = stringConcat(buf1, hpackByteToChar(227))
    buf1 = stringConcat(buf1, hpackByteToChar(194))
    buf1 = stringConcat(buf1, hpackByteToChar(229))
    buf1 = stringConcat(buf1, hpackByteToChar(242))
    buf1 = stringConcat(buf1, hpackByteToChar(58))
    buf1 = stringConcat(buf1, hpackByteToChar(107))
    buf1 = stringConcat(buf1, hpackByteToChar(160))
    buf1 = stringConcat(buf1, hpackByteToChar(171))
    buf1 = stringConcat(buf1, hpackByteToChar(144))
    buf1 = stringConcat(buf1, hpackByteToChar(244))
    buf1 = stringConcat(buf1, hpackByteToChar(255))
    hpackDecode(ctx, buf1, stringLength(buf1))

    // C.4.2: :method GET, :scheme http, :path /,
    //   :authority www.example.com (dynamic), cache-control: no-cache (Huffman)
    var buf2: String = hpackByteToChar(130)  // 0x82 :method GET
    buf2 = stringConcat(buf2, hpackByteToChar(134))  // 0x86 :scheme http
    buf2 = stringConcat(buf2, hpackByteToChar(132))  // 0x84 :path /
    buf2 = stringConcat(buf2, hpackByteToChar(190))  // 0xbe dynamic idx 62
    buf2 = stringConcat(buf2, hpackByteToChar(88))   // 0x58 incremental, name idx 24
    buf2 = stringConcat(buf2, hpackByteToChar(134))  // 0x86 H=1, len=6
    buf2 = stringConcat(buf2, hpackByteToChar(168))  // 0xa8
    buf2 = stringConcat(buf2, hpackByteToChar(235))  // 0xeb
    buf2 = stringConcat(buf2, hpackByteToChar(16))   // 0x10
    buf2 = stringConcat(buf2, hpackByteToChar(100))  // 0x64
    buf2 = stringConcat(buf2, hpackByteToChar(156))  // 0x9c
    buf2 = stringConcat(buf2, hpackByteToChar(191))  // 0xbf
    val headers = hpackDecode(ctx, buf2, stringLength(buf2))
    assertEquals(5, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr(":scheme", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("http", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("/", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    assertEqualsStr("cache-control", toString(mapGet(listGet(headers, 4), "name")))
    assertEqualsStr("no-cache", toString(mapGet(listGet(headers, 4), "value")))
    // Dynamic table: 2 entries, size = 110
    assertEquals(2, hpackDynamicTableLength(ctx))
    assertEquals(110, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC4_3_ThirdRequestHuffman() {
    // Replay C.4.1+C.4.2, then decode C.4.3
    // C.4.3 Hex: 82 87 85 bf 40 88 25 a8 49 e9 5b a9 7d 7f 89 25 a8 49 e9 5b b8 e8 b4 bf
    val ctx = hpackCreateContext()
    // Replay C.4.1
    var buf1: String = hpackByteToChar(130)
    buf1 = stringConcat(buf1, hpackByteToChar(134))
    buf1 = stringConcat(buf1, hpackByteToChar(132))
    buf1 = stringConcat(buf1, hpackByteToChar(65))
    buf1 = stringConcat(buf1, hpackByteToChar(140))
    buf1 = stringConcat(buf1, hpackByteToChar(241))
    buf1 = stringConcat(buf1, hpackByteToChar(227))
    buf1 = stringConcat(buf1, hpackByteToChar(194))
    buf1 = stringConcat(buf1, hpackByteToChar(229))
    buf1 = stringConcat(buf1, hpackByteToChar(242))
    buf1 = stringConcat(buf1, hpackByteToChar(58))
    buf1 = stringConcat(buf1, hpackByteToChar(107))
    buf1 = stringConcat(buf1, hpackByteToChar(160))
    buf1 = stringConcat(buf1, hpackByteToChar(171))
    buf1 = stringConcat(buf1, hpackByteToChar(144))
    buf1 = stringConcat(buf1, hpackByteToChar(244))
    buf1 = stringConcat(buf1, hpackByteToChar(255))
    hpackDecode(ctx, buf1, stringLength(buf1))
    // Replay C.4.2
    var buf2: String = hpackByteToChar(130)
    buf2 = stringConcat(buf2, hpackByteToChar(134))
    buf2 = stringConcat(buf2, hpackByteToChar(132))
    buf2 = stringConcat(buf2, hpackByteToChar(190))
    buf2 = stringConcat(buf2, hpackByteToChar(88))
    buf2 = stringConcat(buf2, hpackByteToChar(134))
    buf2 = stringConcat(buf2, hpackByteToChar(168))
    buf2 = stringConcat(buf2, hpackByteToChar(235))
    buf2 = stringConcat(buf2, hpackByteToChar(16))
    buf2 = stringConcat(buf2, hpackByteToChar(100))
    buf2 = stringConcat(buf2, hpackByteToChar(156))
    buf2 = stringConcat(buf2, hpackByteToChar(191))
    hpackDecode(ctx, buf2, stringLength(buf2))

    // C.4.3: :method GET, :scheme https, :path /index.html,
    //   :authority www.example.com (dynamic), custom-key: custom-value (Huffman)
    var buf3: String = hpackByteToChar(130)  // 0x82 :method GET
    buf3 = stringConcat(buf3, hpackByteToChar(135))  // 0x87 :scheme https
    buf3 = stringConcat(buf3, hpackByteToChar(133))  // 0x85 :path /index.html
    buf3 = stringConcat(buf3, hpackByteToChar(191))  // 0xbf dynamic idx 63
    buf3 = stringConcat(buf3, hpackByteToChar(64))   // 0x40 incremental, new name
    buf3 = stringConcat(buf3, hpackByteToChar(136))  // 0x88 H=1, len=8 (name)
    buf3 = stringConcat(buf3, hpackByteToChar(37))   // 0x25
    buf3 = stringConcat(buf3, hpackByteToChar(168))  // 0xa8
    buf3 = stringConcat(buf3, hpackByteToChar(73))   // 0x49
    buf3 = stringConcat(buf3, hpackByteToChar(233))  // 0xe9
    buf3 = stringConcat(buf3, hpackByteToChar(91))   // 0x5b
    buf3 = stringConcat(buf3, hpackByteToChar(169))  // 0xa9
    buf3 = stringConcat(buf3, hpackByteToChar(125))  // 0x7d
    buf3 = stringConcat(buf3, hpackByteToChar(127))  // 0x7f
    buf3 = stringConcat(buf3, hpackByteToChar(137))  // 0x89 H=1, len=9 (value)
    buf3 = stringConcat(buf3, hpackByteToChar(37))   // 0x25
    buf3 = stringConcat(buf3, hpackByteToChar(168))  // 0xa8
    buf3 = stringConcat(buf3, hpackByteToChar(73))   // 0x49
    buf3 = stringConcat(buf3, hpackByteToChar(233))  // 0xe9
    buf3 = stringConcat(buf3, hpackByteToChar(91))   // 0x5b
    buf3 = stringConcat(buf3, hpackByteToChar(184))  // 0xb8
    buf3 = stringConcat(buf3, hpackByteToChar(232))  // 0xe8
    buf3 = stringConcat(buf3, hpackByteToChar(180))  // 0xb4
    buf3 = stringConcat(buf3, hpackByteToChar(191))  // 0xbf
    val headers = hpackDecode(ctx, buf3, stringLength(buf3))
    assertEquals(5, listSize(headers))
    assertEqualsStr(":method", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("GET", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr(":scheme", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("https", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr(":path", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("/index.html", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr(":authority", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    assertEqualsStr("custom-key", toString(mapGet(listGet(headers, 4), "name")))
    assertEqualsStr("custom-value", toString(mapGet(listGet(headers, 4), "value")))
    // Dynamic table: 3 entries, size = 164
    assertEquals(3, hpackDynamicTableLength(ctx))
    assertEquals(164, hpackDynamicTableSize(ctx))
}

// == RFC 7541 Appendix C.6 — Response Examples with Huffman Coding ============

@Test fun testRfcC6_1_FirstResponseHuffman() {
    // C.6.1: :status 302, cache-control private, date Mon..., location https://www.example.com
    // Dynamic table max size = 256
    val ctx = hpackCreateContext()
    hpackDynamicResize(ctx, 256)
    // 48 82 64 02 58 85 ae c3 77 1a 4b
    // 61 96 d0 7a be 94 10 54 d4 44 a8 20 05 95 04 0b 81 66 e0 82 a6 2d 1b ff
    // 6e 91 9d 29 ad 17 18 63 c7 8f 0b 97 c8 e9 ae 82 ae 43 d3
    var buf: String = hpackByteToChar(72)    // 0x48 incremental, name idx 8 (:status)
    buf = stringConcat(buf, hpackByteToChar(130))   // 0x82 H=1, len=2
    buf = stringConcat(buf, hpackByteToChar(100))   // 0x64
    buf = stringConcat(buf, hpackByteToChar(2))     // 0x02
    buf = stringConcat(buf, hpackByteToChar(88))    // 0x58 incremental, name idx 24
    buf = stringConcat(buf, hpackByteToChar(133))   // 0x85 H=1, len=5
    buf = stringConcat(buf, hpackByteToChar(174))   // 0xae
    buf = stringConcat(buf, hpackByteToChar(195))   // 0xc3
    buf = stringConcat(buf, hpackByteToChar(119))   // 0x77
    buf = stringConcat(buf, hpackByteToChar(26))    // 0x1a
    buf = stringConcat(buf, hpackByteToChar(75))    // 0x4b
    buf = stringConcat(buf, hpackByteToChar(97))    // 0x61 incremental, name idx 33 (date)
    buf = stringConcat(buf, hpackByteToChar(150))   // 0x96 H=1, len=22
    buf = stringConcat(buf, hpackByteToChar(208))   // 0xd0
    buf = stringConcat(buf, hpackByteToChar(122))   // 0x7a
    buf = stringConcat(buf, hpackByteToChar(190))   // 0xbe
    buf = stringConcat(buf, hpackByteToChar(148))   // 0x94
    buf = stringConcat(buf, hpackByteToChar(16))    // 0x10
    buf = stringConcat(buf, hpackByteToChar(84))    // 0x54
    buf = stringConcat(buf, hpackByteToChar(212))   // 0xd4
    buf = stringConcat(buf, hpackByteToChar(68))    // 0x44
    buf = stringConcat(buf, hpackByteToChar(168))   // 0xa8
    buf = stringConcat(buf, hpackByteToChar(32))    // 0x20
    buf = stringConcat(buf, hpackByteToChar(5))     // 0x05
    buf = stringConcat(buf, hpackByteToChar(149))   // 0x95
    buf = stringConcat(buf, hpackByteToChar(4))     // 0x04
    buf = stringConcat(buf, hpackByteToChar(11))    // 0x0b
    buf = stringConcat(buf, hpackByteToChar(129))   // 0x81
    buf = stringConcat(buf, hpackByteToChar(102))   // 0x66
    buf = stringConcat(buf, hpackByteToChar(224))   // 0xe0
    buf = stringConcat(buf, hpackByteToChar(130))   // 0x82
    buf = stringConcat(buf, hpackByteToChar(166))   // 0xa6
    buf = stringConcat(buf, hpackByteToChar(45))    // 0x2d
    buf = stringConcat(buf, hpackByteToChar(27))    // 0x1b
    buf = stringConcat(buf, hpackByteToChar(255))   // 0xff
    buf = stringConcat(buf, hpackByteToChar(110))   // 0x6e incremental, name idx 46 (location)
    buf = stringConcat(buf, hpackByteToChar(145))   // 0x91 H=1, len=17
    buf = stringConcat(buf, hpackByteToChar(157))   // 0x9d
    buf = stringConcat(buf, hpackByteToChar(41))    // 0x29
    buf = stringConcat(buf, hpackByteToChar(173))   // 0xad
    buf = stringConcat(buf, hpackByteToChar(23))    // 0x17
    buf = stringConcat(buf, hpackByteToChar(24))    // 0x18
    buf = stringConcat(buf, hpackByteToChar(99))    // 0x63
    buf = stringConcat(buf, hpackByteToChar(199))   // 0xc7
    buf = stringConcat(buf, hpackByteToChar(143))   // 0x8f
    buf = stringConcat(buf, hpackByteToChar(11))    // 0x0b
    buf = stringConcat(buf, hpackByteToChar(151))   // 0x97
    buf = stringConcat(buf, hpackByteToChar(200))   // 0xc8
    buf = stringConcat(buf, hpackByteToChar(233))   // 0xe9
    buf = stringConcat(buf, hpackByteToChar(174))   // 0xae
    buf = stringConcat(buf, hpackByteToChar(130))   // 0x82
    buf = stringConcat(buf, hpackByteToChar(174))   // 0xae
    buf = stringConcat(buf, hpackByteToChar(67))    // 0x43
    buf = stringConcat(buf, hpackByteToChar(211))   // 0xd3
    val headers = hpackDecode(ctx, buf, stringLength(buf))
    assertEquals(4, listSize(headers))
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("302", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr("cache-control", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("private", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr("date", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("Mon, 21 Oct 2013 20:13:21 GMT", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr("location", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("https://www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    // Dynamic table: 4 entries, size = 222
    assertEquals(4, hpackDynamicTableLength(ctx))
    assertEquals(222, hpackDynamicTableSize(ctx))
}

@Test fun testRfcC6_2_SecondResponseHuffman() {
    // Replay C.6.1, then decode C.6.2
    // C.6.2 Hex: 48 83 64 0e ff c1 c0 bf
