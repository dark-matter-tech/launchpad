    buf1 = stringConcat(buf1, hpackByteToChar(150))
    buf1 = stringConcat(buf1, hpackByteToChar(208))
    buf1 = stringConcat(buf1, hpackByteToChar(122))
    buf1 = stringConcat(buf1, hpackByteToChar(190))
    buf1 = stringConcat(buf1, hpackByteToChar(148))
    buf1 = stringConcat(buf1, hpackByteToChar(16))
    buf1 = stringConcat(buf1, hpackByteToChar(84))
    buf1 = stringConcat(buf1, hpackByteToChar(212))
    buf1 = stringConcat(buf1, hpackByteToChar(68))
    buf1 = stringConcat(buf1, hpackByteToChar(168))
    buf1 = stringConcat(buf1, hpackByteToChar(32))
    buf1 = stringConcat(buf1, hpackByteToChar(5))
    buf1 = stringConcat(buf1, hpackByteToChar(149))
    buf1 = stringConcat(buf1, hpackByteToChar(4))
    buf1 = stringConcat(buf1, hpackByteToChar(11))
    buf1 = stringConcat(buf1, hpackByteToChar(129))
    buf1 = stringConcat(buf1, hpackByteToChar(102))
    buf1 = stringConcat(buf1, hpackByteToChar(224))
    buf1 = stringConcat(buf1, hpackByteToChar(130))
    buf1 = stringConcat(buf1, hpackByteToChar(166))
    buf1 = stringConcat(buf1, hpackByteToChar(45))
    buf1 = stringConcat(buf1, hpackByteToChar(27))
    buf1 = stringConcat(buf1, hpackByteToChar(255))
    buf1 = stringConcat(buf1, hpackByteToChar(110))
    buf1 = stringConcat(buf1, hpackByteToChar(145))
    buf1 = stringConcat(buf1, hpackByteToChar(157))
    buf1 = stringConcat(buf1, hpackByteToChar(41))
    buf1 = stringConcat(buf1, hpackByteToChar(173))
    buf1 = stringConcat(buf1, hpackByteToChar(23))
    buf1 = stringConcat(buf1, hpackByteToChar(24))
    buf1 = stringConcat(buf1, hpackByteToChar(99))
    buf1 = stringConcat(buf1, hpackByteToChar(199))
    buf1 = stringConcat(buf1, hpackByteToChar(143))
    buf1 = stringConcat(buf1, hpackByteToChar(11))
    buf1 = stringConcat(buf1, hpackByteToChar(151))
    buf1 = stringConcat(buf1, hpackByteToChar(200))
    buf1 = stringConcat(buf1, hpackByteToChar(233))
    buf1 = stringConcat(buf1, hpackByteToChar(174))
    buf1 = stringConcat(buf1, hpackByteToChar(130))
    buf1 = stringConcat(buf1, hpackByteToChar(174))
    buf1 = stringConcat(buf1, hpackByteToChar(67))
    buf1 = stringConcat(buf1, hpackByteToChar(211))
    hpackDecode(ctx, buf1, stringLength(buf1))

    // C.6.2: :status 307, cache-control private, date ..., location ...
    var buf2: String = hpackByteToChar(72)    // 0x48 incremental, name idx 8
    buf2 = stringConcat(buf2, hpackByteToChar(131))   // 0x83 H=1, len=3
    buf2 = stringConcat(buf2, hpackByteToChar(100))   // 0x64
    buf2 = stringConcat(buf2, hpackByteToChar(14))    // 0x0e
    buf2 = stringConcat(buf2, hpackByteToChar(255))   // 0xff
    buf2 = stringConcat(buf2, hpackByteToChar(193))   // 0xc1 indexed dynamic
    buf2 = stringConcat(buf2, hpackByteToChar(192))   // 0xc0 indexed dynamic
    buf2 = stringConcat(buf2, hpackByteToChar(191))   // 0xbf indexed dynamic
    val headers = hpackDecode(ctx, buf2, stringLength(buf2))
    assertEquals(4, listSize(headers))
    assertEqualsStr(":status", toString(mapGet(listGet(headers, 0), "name")))
    assertEqualsStr("307", toString(mapGet(listGet(headers, 0), "value")))
    assertEqualsStr("cache-control", toString(mapGet(listGet(headers, 1), "name")))
    assertEqualsStr("private", toString(mapGet(listGet(headers, 1), "value")))
    assertEqualsStr("date", toString(mapGet(listGet(headers, 2), "name")))
    assertEqualsStr("Mon, 21 Oct 2013 20:13:21 GMT", toString(mapGet(listGet(headers, 2), "value")))
    assertEqualsStr("location", toString(mapGet(listGet(headers, 3), "name")))
    assertEqualsStr("https://www.example.com", toString(mapGet(listGet(headers, 3), "value")))
    // Dynamic table: 4 entries, size = 222
    assertEquals(4, hpackDynamicTableLength(ctx))
    assertEquals(222, hpackDynamicTableSize(ctx))
}

